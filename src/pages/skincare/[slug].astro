---
import SkincareLayout from '../../layouts/SkincareLayout.astro';
import { SKINCARE_TOPICS, getSkincareTopic } from '../../data/skincare';

export async function getStaticPaths() {
  return SKINCARE_TOPICS.map(topic => ({
    params: { slug: topic.slug },
    props: { topic },
  }));
}

const { topic } = Astro.props;
const hasSections = topic.sections && topic.sections.length > 0;
---

<SkincareLayout
  title={`${topic.title} — 海得宝科学护肤`}
  description={hasSections ? topic.sections[0].body : topic.body}
  category={topic.category}
  topicSlug={topic.slug}
>
  <div class="topic-split">
    <div class="topic-split-text">
      <h1 class="topic-split-title">{topic.title}</h1>
      {topic.subtitle && <p class="topic-split-subtitle">{topic.subtitle}</p>}

      <div class="topic-split-content">
        {hasSections ? (
          <div class="topic-sections">
            {topic.sections.map(section => (
              <div class="topic-section">
                <h2 class="section-heading">{section.heading}</h2>
                <p class="section-body">{section.body}</p>
              </div>
            ))}
          </div>
        ) : (
          <div class="topic-description">
            <p>{topic.body}</p>
          </div>
        )}
      </div>
    </div>
    <div class="topic-split-image">
      <img src={topic.image} alt={topic.imageAlt || topic.title} loading="lazy" />
    </div>
  </div>
</SkincareLayout>

<style>
  .topic-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    margin-left: calc(-1 * var(--content-padding));
    margin-right: calc(-1 * var(--content-padding));
    align-items: start;
  }

  .topic-split-text {
    align-self: center;
    justify-self: center;
    padding: var(--space-3xl) 0;
    max-width: 480px;
  }

  .topic-split-title {
    font-size: var(--text-3xl);
    font-weight: 200;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .topic-split-subtitle {
    font-size: var(--text-base);
    font-weight: 300;
    color: var(--color-text-soft);
    margin-bottom: var(--space-2xl);
    letter-spacing: var(--tracking-wide);
  }

  .topic-split-content {
    font-size: var(--text-base);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text);
  }

  .topic-sections {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .topic-section {
    padding-left: var(--space-lg);
    border-left: 2px solid var(--color-brand-subtle);
  }

  .section-heading {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
    line-height: var(--leading-snug);
  }

  .section-body {
    font-size: var(--text-sm);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text-soft);
  }

  .topic-description {
    font-size: var(--text-base);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text-soft);
  }

  .topic-split-image {
    overflow: hidden;
    border-radius: var(--radius-lg) 0 0 var(--radius-lg);
    max-width: 855px;
  }

  .topic-split-image img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1/1;
    object-fit: cover;
  }

  @media (max-width: 768px) {
    .topic-split {
      grid-template-columns: 1fr;
      margin-left: 0;
      margin-right: 0;
    }

    .topic-split-text {
      padding: 0;
      max-width: none;
    }

    .topic-split-title {
      font-size: var(--text-2xl);
    }

    .topic-split-image {
      width: calc(100% + 2 * var(--content-padding));
      max-width: none;
      margin-left: calc(-1 * var(--content-padding));
      margin-right: calc(-1 * var(--content-padding));
      border-radius: 0;
    }
  }
</style>
