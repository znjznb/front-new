---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
---

<BaseLayout title="敏感性肌肤知识 — 海得宝 MarTempo" description="科学认识敏感肌：了解过敏与敏感的差异、敏感肌分类、成因及常见反应，从根源理解肌肤诉求。">
  <Nav />
  <main>
    <!-- ── Hero ── -->
    <section class="guide-hero">
      <div class="guide-hero-bg" aria-hidden="true"></div>
      <div class="section-inner">
        <nav class="guide-breadcrumb" aria-label="面包屑导航">
          <a href="/">首页</a>
          <span class="sep">›</span>
          <span class="current">敏感性肌肤知识</span>
        </nav>
        <div class="guide-hero-content">
          <div class="guide-hero-accent" aria-hidden="true"></div>
          <h1 class="guide-hero-title">敏感性肌肤知识</h1>
          <p class="guide-hero-subtitle">科学认识敏感肌，从根源理解肌肤诉求</p>
        </div>
      </div>
    </section>

    <!-- ── 1. 关于过敏与敏感 ── -->
    <section class="guide-section reveal reveal-rise">
      <div class="section-inner">
        <div class="guide-block">
          <div class="guide-block-text">
            <h2 class="guide-section-title">关于过敏与敏感</h2>
            <p class="guide-section-body lead">过敏是一种症状，敏感性皮肤是一种问题性皮肤。两者有本质区别。</p>
            <div class="guide-defs">
              <div class="guide-def">
                <h3 class="guide-def-title">过敏</h3>
                <p class="guide-def-body">抗体对外来物质引起反应，这种反应就被称作"过敏"。与某种物质多次接触后，体内产生一种抵抗物质（抗体）。引起过敏的物质被称作过敏源，有特定体质的人才会发生过敏。</p>
              </div>
              <div class="guide-def">
                <h3 class="guide-def-title">敏感性皮肤</h3>
                <p class="guide-def-body">任何肤质中都可能有敏感性肌肤。就如各种肤质都可能有老化肤质、痘痘肤质等。是属于亚健康的皮肤状态。皮肤敏感是由于皮肤屏障功能的缺损造成的。</p>
              </div>
            </div>
            <div class="guide-symptoms">
              <span class="guide-symptoms-label">常见表现</span>
              <div class="guide-symptoms-tags">
                <span class="symptom-tag">紧绷干燥</span>
                <span class="symptom-tag">发痒刺痛</span>
                <span class="symptom-tag">泛红发烫</span>
                <span class="symptom-tag">外油内干</span>
              </div>
            </div>
          </div>
          <div class="guide-block-image">
            <img src="/assets/skincare/1555820585.jpg" alt="敏感肌护理示意" class="guide-img guide-img--portrait" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <!-- ── 2. 敏感肌分类 ── -->
    <section class="guide-section guide-section--alt reveal reveal-rise">
      <div class="section-inner">
        <div class="guide-block-center">
          <h2 class="guide-section-title">敏感肌分类</h2>
          <p class="guide-section-body lead">敏感肌并非只有一种，了解自己的类型才能精准护理。</p>
        </div>
        <div class="guide-cards">
          <div class="guide-card">
            <h3 class="guide-card-title">原发性敏感肌</h3>
            <p class="guide-card-body">皮肤出现较高的经皮水分流失（TEWL）和异常脱屑，表现为干燥紧绷。即为屏障功能受损型敏感肌，多为干敏性肌肤。</p>
          </div>
          <div class="guide-card">
            <h3 class="guide-card-title">继发性敏感肌</h3>
            <p class="guide-card-body">原本肌肤屏障功能正常，因错用护肤品等让皮肤当中存在炎症变化和免疫反应，如发痒、泛红等，为炎症型敏感肌（玫瑰痤疮、脂溢性皮炎等），多为油敏肌肤。</p>
          </div>
          <div class="guide-card">
            <h3 class="guide-card-title">神经性敏感肌</h3>
            <p class="guide-card-body">屏障功能正常，没有炎症反应，但出现神经功能失调（如辣椒素受体TPRV-1过度反应），产生神经刺痛、灼热感。有可能是干敏皮也有可能是油敏皮。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── 3. 为什么会敏感 ── -->
    <section class="guide-section reveal reveal-rise">
      <div class="section-inner">
        <div class="guide-block guide-block--reverse">
          <div class="guide-block-text">
            <h2 class="guide-section-title">为什么会敏感？</h2>
            <div class="guide-highlight">
              <p>多数人以为敏感肌只是「屏障受损」，但海得宝通过临床研究发现：<strong>屏障受损是「果」，底层炎症才是「因」。</strong></p>
              <p>当肌肤长期受外界刺激或不当护肤影响，炎症因子会持续攻击角质层细胞，破坏细胞间的脂质连接，最终导致屏障失守、敏感反复。</p>
            </div>
            <div class="guide-causes">
              <div class="guide-cause">
                <div>
                  <h3 class="guide-cause-title">过度清洁</h3>
                  <p class="guide-cause-body">过度使用清洁力很强的表面活性剂（如皂类）或过度摩擦皮肤，长期使用皂基或有磨砂颗粒的洁面。</p>
                </div>
              </div>
              <div class="guide-cause">
                <div>
                  <h3 class="guide-cause-title">过度使用面膜</h3>
                  <p class="guide-cause-body">过度使用面膜，使皮肤长期处于高水合状态，导致角质细胞之间的连接变得松散，削弱皮肤屏障功能。</p>
                </div>
              </div>
              <div class="guide-cause">
                <div>
                  <h3 class="guide-cause-title">过度护肤</h3>
                  <p class="guide-cause-body">盲目使用高浓度酸类、A醇、酒精等成分，会直接损伤角质细胞，诱发氧化应激反应，导致角质层变薄。</p>
                </div>
              </div>
              <div class="guide-cause">
                <div>
                  <h3 class="guide-cause-title">环境刺激</h3>
                  <p class="guide-cause-body">日晒导致皮肤屏障损伤、血管扩张、自由基增多；冷风刺激使皮肤水分流失过多，加重敏感反应。</p>
                </div>
              </div>
            </div>
          </div>
          <div class="guide-block-image">
            <img src="/assets/skincare/1581182800629.jpg" alt="敏感肌成因示意" class="guide-img guide-img--square" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <!-- ── 4. 敏感肌常见反应 ── -->
    <section class="guide-section guide-section--alt reveal reveal-rise">
      <div class="section-inner">
        <div class="guide-block-center">
          <h2 class="guide-section-title">敏感肌常见反应</h2>
          <p class="guide-section-body lead">了解不同反应的机制，有助于准确判断肌肤状态并采取正确的护理方式。</p>
        </div>
        <div class="guide-reaction-list">
          <div class="guide-reaction-item">
<div class="guide-reaction-card">
              <div class="guide-reaction-header">
                <span class="guide-reaction-icon" aria-hidden="true">急</span>
                <div>
                  <h3 class="guide-reaction-title">应激反应</h3>
                  <span class="guide-reaction-badge">短期 · 突发</span>
                </div>
              </div>
              <p class="guide-reaction-desc">短期炎症——突发、小范围、快消。天气与生活环境发生变化，皮肤进行的自我抵抗以及自我对战的一种反应。使用护肤品后出现皮肤发红、发痒、起疹子、风团等现象。</p>
            </div>
          </div>
          <div class="guide-reaction-item">
<div class="guide-reaction-card">
              <div class="guide-reaction-header">
                <span class="guide-reaction-icon" aria-hidden="true">耐</span>
                <div>
                  <h3 class="guide-reaction-title">不耐受</h3>
                  <span class="guide-reaction-badge">长期 · 可改善</span>
                </div>
              </div>
              <p class="guide-reaction-desc">长期性、可改善。原因一是产品含有某些刺激成分（小分子防腐剂、香精香料等）穿透角质层进入皮肤；原因二是皮肤自身屏障受损（经常去角质、过度敷面膜、过度清洁）。天气变化导致皮肤干燥、屏障能力降低，或搭配使用其他刺激性产品均可造成不耐受。</p>
            </div>
          </div>
          <div class="guide-reaction-item">
<div class="guide-reaction-card">
              <div class="guide-reaction-header">
                <span class="guide-reaction-icon" aria-hidden="true">炎</span>
                <div>
                  <h3 class="guide-reaction-title">炎症</h3>
                  <span class="guide-reaction-badge">根源 · 屏障关联</span>
                </div>
              </div>
              <p class="guide-reaction-desc">身体每时每刻都有炎症的发生，这是身体在抵御各种外因、内因刺激的表现。屏障越弱，越容易出现炎症。炎症还会进一步影响肌肤屏障的健康，进入恶性循环。修护、强化皮肤屏障对抗炎也有一定的帮助。</p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <RelatedArticles currentSlug="knowledge" />
  <Footer />

  <script>
    import '../../scripts/reveal.js';
  </script>
</BaseLayout>

<style>
  /* ── Hero ── */
  .guide-hero {
    padding: 120px var(--content-padding) var(--space-4xl);
    position: relative;
    overflow: hidden;
  }

  .guide-hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, oklch(96% 0.015 185) 0%, oklch(98% 0.008 185) 50%, #ffffff 100%);
    z-index: 0;
  }

  .guide-hero > .section-inner {
    position: relative;
    z-index: 1;
  }

  .guide-breadcrumb {
    font-size: var(--text-xs);
    margin-bottom: var(--space-3xl);
  }

  .guide-breadcrumb a {
    color: oklch(50% 0.01 260 / 0.6);
    text-decoration: none;
    transition: color var(--duration-fast) ease;
  }

  .guide-breadcrumb a:hover {
    color: var(--color-brand);
  }

  .guide-breadcrumb .sep {
    margin: 0 6px;
    color: oklch(50% 0.01 260 / 0.5);
  }

  .guide-breadcrumb .current {
    color: oklch(35% 0.015 260 / 0.7);
    font-weight: 500;
  }

  .guide-hero-accent {
    width: 40px;
    height: 2px;
    background: var(--color-brand);
    margin-bottom: var(--space-xl);
  }

  .guide-hero-title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 200;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    margin-bottom: var(--space-lg);
  }

  .guide-hero-subtitle {
    font-size: var(--text-lg);
    font-weight: 300;
    color: var(--guide-text, var(--color-text-soft));
    max-width: 40ch;
  }

  /* ── Shared section ── */
  .guide-section {
    --guide-text: oklch(28% 0.025 260);
    padding: var(--space-6xl) var(--content-padding);
    background: #ffffff;
  }

  .guide-section--alt {
    background: oklch(98.5% 0.005 185);
  }

  .guide-block-center {
    text-align: center;
    max-width: 600px;
    margin: 0 auto var(--space-4xl);
  }

  .guide-section-title {
    font-size: var(--text-3xl);
    font-weight: 200;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    margin-bottom: var(--space-lg);
  }

  .guide-section-body.lead {
    font-size: var(--text-base);
    font-weight: 300;
    color: var(--guide-text, var(--color-text-soft));
    line-height: var(--leading-relaxed);
  }

  /* ── Image + text block ── */
  .guide-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: start;
  }

  .guide-block--reverse .guide-block-image {
    order: -1;
  }

  .guide-img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    object-fit: cover;
  }

  .guide-img--portrait { aspect-ratio: 3/4; }
  .guide-img--square { aspect-ratio: 1/1; }
  .guide-img--landscape { aspect-ratio: 4/3; }
  .guide-img--wide { aspect-ratio: 16/9; }

  /* ── Definition blocks ── */
  .guide-defs {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    margin-top: var(--space-2xl);
  }

  .guide-def-title {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .guide-def-body {
    font-size: var(--text-sm);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--guide-text, var(--color-text-soft));
  }

  .guide-symptoms {
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
  }

  .guide-symptoms-label {
    display: block;
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
    letter-spacing: var(--tracking-wide);
  }

  .guide-symptoms-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .symptom-tag {
    display: inline-block;
    padding: 6px 14px;
    font-size: var(--text-sm);
    font-weight: 300;
    color: var(--color-brand-dark);
    background: oklch(95% 0.03 185 / 0.4);
    border-radius: var(--radius-pill);
  }

  /* ── Cards (分类) ── */
  .guide-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .guide-card {
    padding: var(--space-2xl);
    background: #ffffff;
    border-radius: var(--radius);
    transition: box-shadow var(--duration-fast) ease;
  }

  .guide-card:hover {
    box-shadow: 0 4px 20px oklch(0% 0 0 / 0.04);
  }

  .guide-card-title {
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: var(--space-md);
    letter-spacing: var(--tracking-wide);
  }

  .guide-card-body {
    font-size: var(--text-sm);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--guide-text, var(--color-text-soft));
  }

  /* ── Highlight box (为什么敏感) ── */
  .guide-highlight {
    padding: var(--space-xl) var(--space-2xl);
    background: oklch(95% 0.03 185 / 0.3);
    border-radius: var(--radius);
    margin-bottom: var(--space-2xl);
    font-size: var(--text-sm);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text);
    position: relative;
  }

  .guide-highlight::before {
    content: '';
    position: absolute;
    top: 0;
    left: var(--space-2xl);
    right: var(--space-2xl);
    height: 2px;
    background: var(--color-brand);
    border-radius: 1px;
  }

  .guide-highlight strong {
    color: var(--color-brand-dark);
    font-weight: 500;
  }

  .guide-highlight p + p {
    margin-top: var(--space-md);
  }

  /* ── Causes ── */
  .guide-causes {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .guide-cause {
    display: flex;
    gap: var(--space-lg);
    align-items: flex-start;
  }

  .guide-cause-title {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }

  .guide-cause-body {
    font-size: var(--text-sm);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--guide-text, var(--color-text-soft));
  }

  /* ── Reactions (vertical timeline) ── */
  .guide-reaction-list {
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .guide-reaction-item {
    padding-bottom: var(--space-2xl);
  }

  .guide-reaction-item:last-child {
    padding-bottom: 0;
  }

  .guide-reaction-card {
    padding: var(--space-xl) var(--space-2xl);
    background: #ffffff;
    border-radius: var(--radius);
    transition: box-shadow var(--duration-fast) ease;
  }

  .guide-reaction-card:hover {
    box-shadow: 0 4px 20px oklch(0% 0 0 / 0.04);
  }

  .guide-reaction-header {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .guide-reaction-header > div {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .guide-reaction-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-inverse);
    background: var(--color-brand);
    border-radius: 50%;
    position: relative;
    z-index: 1;
  }

  .guide-reaction-title {
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: var(--tracking-wide);
  }

  .guide-reaction-badge {
    font-size: 0.75rem;
    font-weight: 400;
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
  }

  .guide-reaction-desc {
    font-size: var(--text-sm);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--guide-text, var(--color-text-soft));
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .guide-block, .guide-block--reverse {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .guide-block--reverse .guide-block-image {
      order: 0;
    }

    .guide-block-image {
      max-width: 500px;
      margin: 0 auto;
    }

    .guide-cards {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .guide-section {
      padding: var(--space-4xl) var(--content-padding);
    }

    .guide-hero {
      padding: 100px var(--content-padding) var(--space-3xl);
    }

    .guide-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
