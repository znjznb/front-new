---
// News detail page

import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const news = await getCollection('news');
  return news.map(item => ({
    params: { slug: item.id.replace(/\.md$/, '') },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);

// 文章结构化数据（BlogPosting + BreadcrumbList）—— GEO
const SITE_URL = 'https://www.martempo.com.cn';
const newsUrl = `${SITE_URL}/news/${item.id.replace(/\.md$/, '')}`;
const newsImgAbs = item.data.image ? new URL(item.data.image, SITE_URL).href : undefined;
const newsDateISO = new Date(item.data.date).toISOString();
const articleLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BlogPosting',
      '@id': `${newsUrl}#article`,
      headline: item.data.title,
      description: item.data.summary,
      ...(newsImgAbs ? { image: newsImgAbs } : {}),
      datePublished: newsDateISO,
      dateModified: newsDateISO,
      inLanguage: 'zh-CN',
      mainEntityOfPage: newsUrl,
      author: item.data.author
        ? { '@type': 'Person', name: item.data.author }
        : { '@id': `${SITE_URL}/#organization` },
      publisher: { '@id': `${SITE_URL}/#organization` },
      speakable: { '@type': 'SpeakableSpecification', cssSelector: ['.news-detail-title'] },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: '首页', item: `${SITE_URL}/` },
        { '@type': 'ListItem', position: 2, name: '新闻动态', item: `${SITE_URL}/news` },
        { '@type': 'ListItem', position: 3, name: item.data.title, item: newsUrl },
      ],
    },
  ],
};
---

<BaseLayout
  title={`${item.data.title} — 海得宝 MARTEMPO`}
  description={item.data.summary}
  ogType="article"
  jsonld={articleLd}
>
  <Nav />
  <main>
  <article class="news-detail">
    <div class="news-detail-inner">
      <nav class="news-breadcrumb">
        <a href="/news/">新闻动态</a>
        <span class="news-breadcrumb-sep">/</span>
        <span>{item.data.title}</span>
      </nav>

      <time class="news-detail-date">{new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }).format(item.data.date)}</time>
      {item.data.author && (
        <div class="news-detail-source">
          <p class="news-detail-source-line">*本文为「{item.data.author}」原创内容</p>
          <p class="news-detail-source-url">{item.data.author}：{item.data.sourceUrl}</p>
        </div>
      )}
      <h1 class="news-detail-title">{item.data.title}</h1>

      <div class="news-detail-body">
        <Content />
      </div>

      <div class="news-detail-nav">
        <a href="/news/" class="news-detail-back">← 返回新闻列表</a>
        {item.data.sourceUrl && (
          <a href={item.data.sourceUrl} class="news-detail-original" target="_blank" rel="noopener noreferrer">阅读原文 →</a>
        )}
      </div>
    </div>
  </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  .news-detail {
    padding: 144px var(--content-padding) var(--space-6xl);
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  .news-detail-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .news-breadcrumb {
    font-size: var(--text-sm);
    font-weight: 300;
    color: var(--color-text-muted);
    margin-bottom: var(--space-2xl);
  }

  .news-breadcrumb a {
    color: var(--color-brand-dark);
    text-decoration: none;
  }

  .news-breadcrumb a:hover {
    text-decoration: underline;
  }

  .news-breadcrumb-sep {
    margin: 0 var(--space-sm);
  }

  .news-detail-date {
    display: block;
    font-size: var(--text-sm);
    font-weight: 400;
    letter-spacing: var(--tracking-wide);
    color: var(--color-brand);
    margin-bottom: var(--space-lg);
  }

  .news-detail-source {
    font-size: var(--text-sm);
    font-weight: 300;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
    padding: var(--space-sm) var(--space-md);
    background: var(--color-surface-alt, #f8f8f8);
    border-left: 3px solid var(--color-brand);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .news-detail-source-line {
    margin-bottom: 4px;
  }

  .news-detail-source-url {
    word-break: break-all;
    font-size: var(--text-xs);
  }

  .news-detail-title {
    font-size: var(--text-3xl);
    font-weight: 500;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-2xl);
  }

  .news-detail-body {
    font-size: var(--text-base);
    font-weight: 400;
    line-height: var(--leading-relaxed);
    color: var(--color-text);
  }

  .news-detail-body p {
    margin-bottom: var(--space-lg);
  }

  .news-detail-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: var(--space-3xl);
  }

  .news-detail-back,
  .news-detail-original {
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--color-brand-dark);
    text-decoration: none;
  }

  .news-detail-back:hover,
  .news-detail-original:hover {
    text-decoration: underline;
  }
</style>
