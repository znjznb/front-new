---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout title="环保可持续 — 海得宝 MARTEMPO" description="海得宝空瓶回收计划：源自纯净海域，共促海洋可持续发展。让每一个空瓶，都有一个回归海洋的使命。">
  <Nav />
  <main>

    <!-- ── Hero ── -->
    <section class="eco-hero">
      <div class="eco-hero-img-wrap">
        <img
          src="/assets/eco/cape-hero.webp"
          alt="南非好望角纯净海域"
          class="eco-hero-img"
          loading="eager"
          fetchpriority="high"
        />
        <div class="eco-hero-overlay" aria-hidden="true"></div>
      </div>
      <div class="eco-hero-content section-inner">
        <nav class="eco-breadcrumb" aria-label="面包屑导航">
          <a href="/">首页</a>
          <span class="sep">›</span>
          <a href="/brand/charity">品牌探索</a>
          <span class="sep">›</span>
          <span class="current">环保可持续</span>
        </nav>
        <div class="eco-hero-text">
          <div class="eco-hero-accent" aria-hidden="true"></div>
          <h1 class="eco-hero-title">环保可持续</h1>
          <p class="eco-hero-subtitle">海得宝 × 空瓶回收计划</p>
        </div>
      </div>
    </section>

    <!-- ── Split: text + image（保持不变）── -->
    <div class="eco-main">
      <div class="section-inner">
        <div class="eco-split">
          <div class="eco-split-text">
            <p class="eco-split-kicker">海得宝 × 空瓶回收计划</p>
            <div class="eco-split-content">
              <blockquote class="eco-intro-quote">
                让每一个空瓶，都有一个回归海洋的使命。
              </blockquote>
              <p class="eco-intro-body">
                海得宝的核心成分贻贝钙肽CAPCS源自全球不到1%的纯净海域——这片珍稀水域是我们成分品质的根基，也是品牌灵魂的起点。
              </p>
              <p class="eco-intro-body">
                我们希望，在从大海中汲取天然力量的同时，也为海洋的可持续发展奉献一份力所能及的责任。海得宝邀您一同，从一支小小的空瓶开始，守护我们共同的蓝色家园。
              </p>
            </div>
          </div>
          <div class="eco-split-image">
            <img
              src="/assets/eco-hero.jpg"
              alt="贝壳中的瓶盖，海得宝空瓶回收计划"
              loading="eager"
              fetchpriority="high"
            />
          </div>
        </div>
      </div>
    </div>

    <!-- ── 为什么发起 ── -->
    <section class="eco-section reveal reveal-rise">
      <div class="eco-prose">
        <h2 class="eco-h2">为什么发起空瓶回收计划</h2>
        <p class="eco-p">海洋是海得宝的灵魂所在，也是品牌赖以生存的根本。我们希望在从大海中汲取天然力量的同时，也能为海洋的可持续发展，奉献一份力所能及的责任。</p>
        <p class="eco-p">然而，每一支使用完的空瓶，如果被随意丢弃或填埋，需要数百年才能自然降解。作为敏感肌家庭的专业护肤品牌，海得宝不仅关注肌肤的修复，更关注地球的“肌肤”——海洋与生态环境的修复。因此，我们发起“空瓶回收计划”，号召每一位用户加入到守护纯净海域的行动中来。</p>
        <ol class="eco-list">
          <li class="eco-list-item">
            <span class="eco-list-num">01</span>
            <div class="eco-list-text">
              <h3 class="eco-list-title">空瓶难以降解</h3>
              <p class="eco-list-body">每一支使用完的空瓶，如果被随意丢弃或填埋，需要数百年才能自然降解，对土壤和海洋生态构成长期威胁。</p>
            </div>
          </li>
          <li class="eco-list-item">
            <span class="eco-list-num">02</span>
            <div class="eco-list-text">
              <h3 class="eco-list-title">品牌的责任</h3>
              <p class="eco-list-body">作为敏感肌家庭的专业护肤品牌，海得宝不仅关注肌肤的修复，更关注地球的“肌肤”——海洋与生态环境的修复与保护。</p>
            </div>
          </li>
          <li class="eco-list-item">
            <span class="eco-list-num">03</span>
            <div class="eco-list-text">
              <h3 class="eco-list-title">从用户开始</h3>
              <p class="eco-list-body">我们号召每一位用户加入守护纯净海域的行动——每回收一个空瓶，就是为海洋的未来投下一票。</p>
            </div>
          </li>
        </ol>
      </div>
    </section>

    <!-- ── 如何参与 ── -->
    <section class="eco-section reveal reveal-rise">
      <div class="eco-prose">
        <p class="eco-kicker">空瓶回收计划</p>
        <h2 class="eco-h2 eco-h2--tight">如何参与</h2>
        <p class="eco-p eco-p--muted">三步行动，守护蓝色家园。</p>
        <ol class="eco-list">
          <li class="eco-list-item">
            <span class="eco-list-num">01</span>
            <div class="eco-list-text">
              <h3 class="eco-list-title">收集空瓶</h3>
              <p class="eco-list-body">将用完的海得宝产品空瓶清洗干净，保留原包装，积攒一定数量后即可参与回收。</p>
            </div>
          </li>
          <li class="eco-list-item">
            <span class="eco-list-num">02</span>
            <div class="eco-list-text">
              <h3 class="eco-list-title">联系寄回</h3>
              <p class="eco-list-body">通过微信公众号「海得宝 MARTEMPO」联系客服，获取回收地址，将空瓶寄回至指定回收点。</p>
            </div>
          </li>
          <li class="eco-list-item">
            <span class="eco-list-num">03</span>
            <div class="eco-list-text">
              <h3 class="eco-list-title">获得回馈</h3>
              <p class="eco-list-body">每次回收均可获得品牌专属回馈权益，与我们共同记录每一个为海洋而做的小小行动。</p>
            </div>
          </li>
        </ol>
      </div>
    </section>

    <!-- ── 承诺 ── -->
    <section class="eco-section reveal reveal-rise">
      <div class="eco-pledge">
        <div class="eco-pledge-line" aria-hidden="true"></div>
        <p class="eco-pledge-text">
          海洋给了我们最纯净的成分，<br />我们用行动回馈海洋最诚挚的守护。
        </p>
        <p class="eco-pledge-brand">— 海得宝 MARTEMPO</p>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    import '../../scripts/reveal.js';
  </script>
</BaseLayout>

<style>
  /* ── Hero ── */
  .eco-hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .eco-hero-img-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .eco-hero-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 45%;
  }

  .eco-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      oklch(10% 0.02 185 / 0.2) 0%,
      oklch(10% 0.02 185 / 0.48) 58%,
      oklch(10% 0.02 185 / 0.72) 100%
    );
  }

  .eco-hero-content {
    position: relative;
    z-index: 1;
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 140px var(--content-padding) var(--space-4xl);
  }

  .eco-breadcrumb {
    font-size: var(--text-xs);
  }

  .eco-breadcrumb a,
  .eco-breadcrumb .sep,
  .eco-breadcrumb .current {
    color: oklch(95% 0.01 185 / 0.78);
    text-decoration: none;
  }

  .eco-breadcrumb a:hover { color: #fff; }
  .eco-breadcrumb .sep { margin: 0 6px; }
  .eco-breadcrumb .current { font-weight: 500; }

  .eco-hero-text {
    margin-top: auto;
  }

  .eco-hero-accent {
    width: 40px;
    height: 2px;
    background: var(--color-brand);
    margin-bottom: var(--space-xl);
  }

  .eco-hero-title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 200;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-wide);
    color: #ffffff;
    margin-bottom: var(--space-md);
  }

  .eco-hero-subtitle {
    font-size: var(--text-xl);
    font-weight: 300;
    color: oklch(95% 0.02 185 / 0.9);
  }

  /* ── Main split area ── */
  .eco-main {
    padding: var(--space-5xl) var(--content-padding) var(--space-6xl);
    background: #ffffff;
  }

  .eco-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    margin-left: calc(-1 * var(--content-padding));
    margin-right: calc(-1 * var(--content-padding));
    align-items: start;
  }

  .eco-split-text {
    align-self: center;
    justify-self: center;
    padding: var(--space-3xl) 0;
    max-width: 480px;
  }

  .eco-split-kicker {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-brand);
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-lg);
  }

  .eco-split-content {
    font-size: var(--text-base);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text);
  }

  .eco-intro-quote {
    font-size: var(--text-lg);
    font-weight: 300;
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    margin: 0 0 var(--space-xl);
    padding: 0;
    border: none;
    quotes: none;
  }

  .eco-intro-body {
    font-size: var(--text-sm);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text-soft);
    margin-bottom: var(--space-md);
  }

  .eco-intro-body:last-child { margin-bottom: 0; }

  .eco-split-image {
    overflow: hidden;
    border-radius: var(--radius-lg) 0 0 var(--radius-lg);
    max-width: 855px;
  }

  .eco-split-image img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 3/4;
    object-fit: cover;
    object-position: center center;
  }

  /* ── 正文：编辑式版面（全白 · 居中文章流 · 编号列表）── */
  .eco-section {
    padding: var(--space-4xl) var(--content-padding);
    background: #ffffff;
  }

  .eco-prose {
    max-width: 720px;
    margin: 0 auto;
  }

  .eco-kicker {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-brand);
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-sm);
  }

  .eco-h2 {
    position: relative;
    font-size: var(--text-2xl);
    font-weight: 200;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    padding-top: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .eco-h2::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 40px;
    height: 2px;
    background: var(--color-brand);
  }

  .eco-h2--tight {
    padding-top: 0;
    margin-bottom: var(--space-sm);
  }

  .eco-h2--tight::before { display: none; }

  .eco-p {
    font-size: var(--text-base);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text-soft);
    margin-bottom: var(--space-lg);
  }

  .eco-p:last-child { margin-bottom: 0; }

  .eco-p--muted {
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }

  /* 编号列表（替代网格卡片）*/
  .eco-list {
    list-style: none;
    margin: var(--space-xl) 0 0;
    padding: 0;
  }

  .eco-list-item {
    display: flex;
    gap: var(--space-lg);
    padding: var(--space-xl) 0;
    align-items: flex-start;
  }

  .eco-list-item + .eco-list-item {
    border-top: 1px solid var(--color-border-light);
  }

  .eco-list-num {
    flex: none;
    width: 24px;
    height: 24px;
    font-size: 0;
    background: url('/assets/list-marker.png') center / contain no-repeat;
    margin-top: 0.2em;
  }

  .eco-list-title {
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-sm);
  }

  .eco-list-body {
    font-size: var(--text-sm);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text-soft);
  }

  /* 承诺 */
  .eco-pledge {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  .eco-pledge-line {
    width: 40px;
    height: 2px;
    background: var(--color-brand);
    margin: 0 auto var(--space-2xl);
  }

  .eco-pledge-text {
    font-size: var(--text-xl);
    font-weight: 200;
    line-height: var(--leading-relaxed);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    margin-bottom: var(--space-lg);
  }

  .eco-pledge-brand {
    font-size: var(--text-sm);
    font-weight: 300;
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wider);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .eco-hero-content {
      padding: 100px var(--content-padding) var(--space-4xl);
    }

    .eco-main {
      padding: var(--space-3xl) var(--content-padding) var(--space-5xl);
    }

    .eco-split {
      grid-template-columns: 1fr;
      margin-left: 0;
      margin-right: 0;
    }

    .eco-split-text {
      padding: 0 0 var(--space-2xl);
      max-width: none;
    }

    .eco-split-title {
      font-size: var(--text-2xl);
    }

    .eco-split-image {
      width: calc(100% + 2 * var(--content-padding));
      max-width: none;
      margin-left: calc(-1 * var(--content-padding));
      margin-right: calc(-1 * var(--content-padding));
      border-radius: 0;
    }

    .eco-section {
      padding: var(--space-3xl) var(--content-padding);
    }

    .eco-list-item {
      gap: var(--space-md);
    }
  }
</style>
