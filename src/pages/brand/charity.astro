---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout title="公益责任 — 海得宝 MARTEMPO" description="海得宝×蝴蝶宝贝关爱中心「春光计划」：自2024年起，海得宝正式启动长期公益计划，为遗传性大疱性表皮松解症（EB）患者家庭提供产品捐赠、护理指导、科研支持和公众倡导。">
  <Nav />
  <main>

    <!-- ── Hero ── -->
    <section class="charity-hero">
      <div class="charity-hero-img-wrap">
        <img
          src="/assets/charity/img1.jpg"
          alt="蝴蝶宝贝关爱"
          class="charity-hero-img"
          loading="eager"
          fetchpriority="high"
        />
        <div class="charity-hero-overlay" aria-hidden="true"></div>
      </div>
      <div class="charity-hero-content section-inner">
        <nav class="charity-breadcrumb" aria-label="面包屑导航">
          <a href="/">首页</a>
          <span class="sep">›</span>
          <a href="/about">品牌探索</a>
          <span class="sep">›</span>
          <span class="current">公益责任</span>
        </nav>
        <div class="charity-hero-text">
          <div class="charity-hero-accent" aria-hidden="true"></div>
          <h1 class="charity-hero-title">公益责任</h1>
          <p class="charity-hero-subtitle">海得宝 × 蝴蝶宝贝关爱中心</p>
          <div class="charity-hero-badge">「春光计划」</div>
        </div>
      </div>
    </section>

    <!-- ── 计划概述 ── -->
    <section class="charity-section reveal reveal-rise">
      <div class="section-inner">
        <div class="charity-intro">
          <p class="charity-intro-body">
            自2024年起，海得宝正式启动 <strong>「海得宝×蝴蝶宝贝关爱中心」长期公益计划</strong>，通过产品捐赠、一对一护理指导、科研支持与公众倡导，为EB患者家庭提供切实支持，陪伴每一个罕见病家庭走过艰难时刻。
          </p>
        </div>
      </div>
    </section>

    <!-- ── 关于蝴蝶宝贝 ── -->
    <section class="charity-section charity-section--alt reveal reveal-rise">
      <div class="section-inner">
        <div class="charity-block">
          <div class="charity-block-text">
            <h2 class="charity-block-title">关于蝴蝶宝贝</h2>
            <p class="charity-block-body">
              "蝴蝶宝贝"是对遗传性大疱性表皮松解症（EB）患者的昵称。EB是一种罕见的遗传性皮肤病，患者的皮肤和黏膜如同蝴蝶翅膀般脆弱，轻微摩擦或碰撞就会导致水疱、破溃和创伤。
            </p>
            <p class="charity-block-body">
              目前，这一疾病尚无根治方法，日常护理的核心在于减少摩擦、预防感染、促进创面愈合。
            </p>
            <div class="charity-highlight">
              <span class="charity-highlight-marker" aria-hidden="true"></span>
              每一位蝴蝶宝贝的皮肤，都值得被最温柔的方式呵护。
            </div>
          </div>
          <div class="charity-block-media">
            <img src="/assets/charity/img1.jpg" alt="蝴蝶宝贝关爱" loading="lazy" class="charity-img" />
          </div>
        </div>
      </div>
    </section>

    <!-- ── 为什么是海得宝 ── -->
    <section class="charity-section reveal reveal-rise">
      <div class="section-inner">
        <div class="charity-block charity-block--reverse">
          <div class="charity-block-text">
            <h2 class="charity-block-title">为什么是海得宝？</h2>
            <p class="charity-block-body">
              海得宝自创立以来，始终将"用心呵护敏感，用爱温暖家庭"作为品牌使命。我们自主研发的专利成分CAPCS（凯普斯泰/贻贝提取物）具备天然无激素止痒、抑菌、促进屏障修复三大核心功效。
            </p>
            <div class="charity-features">
              <div class="charity-feature">
                <span class="charity-feature-dot" aria-hidden="true"></span>
                天然无激素止痒
              </div>
              <div class="charity-feature">
                <span class="charity-feature-dot" aria-hidden="true"></span>
                抑菌防感染
              </div>
              <div class="charity-feature">
                <span class="charity-feature-dot" aria-hidden="true"></span>
                促进屏障修复
              </div>
            </div>
            <p class="charity-block-body">
              同时通过五维安全金标准（经口无毒、入眼无刺激、人体斑贴无刺激、多次皮肤刺激无刺激、4000+争议成分不添加），其温和性与安全性与EB患者的护理需求高度契合。
            </p>
          </div>
          <div class="charity-block-media">
            <img src="/assets/charity/img2.jpg" alt="海得宝成分科研" loading="lazy" class="charity-img" />
          </div>
        </div>
      </div>
    </section>

    <!-- ── 视频 ── -->
    <section class="charity-section charity-section--alt reveal reveal-rise">
      <div class="section-inner">
        <div class="charity-video-wrap">
          <div class="charity-video-label">蝴蝶宝贝 · 世界罕见病日</div>
          <div class="charity-video-container">
            <video
              src="/assets/charity/butterfly-video.mp4"
              controls
              preload="metadata"
              class="charity-video"
              poster="/assets/charity/img1.jpg"
              aria-label="蝴蝶宝贝公益视频"
            ></video>
          </div>
        </div>
      </div>
    </section>

    <!-- ── 春光计划四项行动 ── -->
    <section class="charity-section reveal reveal-rise">
      <div class="section-inner">
        <div class="charity-plan-header">
          <div class="charity-plan-badge">春光计划</div>
          <h2 class="charity-section-title">四项支持行动</h2>
          <p class="charity-section-subtitle">从产品到科研，从个体到社会，全方位守护蝴蝶宝贝</p>
        </div>
        <div class="charity-actions">
          <div class="charity-action">
            <div class="charity-action-num">01</div>
            <div class="charity-action-content">
              <h3 class="charity-action-title">产品捐赠</h3>
              <p class="charity-action-body">定期向指定罕见病关爱机构捐赠海得宝全系护理产品，用于蝴蝶宝贝的日常皮肤护理，降低家庭经济负担。</p>
            </div>
          </div>
          <div class="charity-action">
            <div class="charity-action-num">02</div>
            <div class="charity-action-content">
              <h3 class="charity-action-title">一对一护理指导</h3>
              <p class="charity-action-body">海得宝专业顾问团队（具备皮肤管理师、护士资质）为蝴蝶宝贝家庭提供免费在线护理咨询，包括：产品使用方案定制、创面护理建议、日常防护注意事项等。</p>
            </div>
          </div>
          <div class="charity-action">
            <div class="charity-action-num">03</div>
            <div class="charity-action-content">
              <h3 class="charity-action-title">科研支持</h3>
              <p class="charity-action-body">海得宝研发中心持续优化配方，针对EB患者特殊肤质开展适应性的产品迭代研究，力求提供更精准的护理解决方案。</p>
            </div>
          </div>
          <div class="charity-action">
            <div class="charity-action-num">04</div>
            <div class="charity-action-content">
              <h3 class="charity-action-title">公众倡导</h3>
              <p class="charity-action-body">通过品牌官方渠道普及EB疾病知识，呼吁社会减少对罕见病患者的误解，营造更有温度的关怀环境。</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── 图片画廊 ── -->
    <section class="charity-section charity-section--alt reveal reveal-rise">
      <div class="section-inner">
        <div class="charity-gallery">
          <img src="/assets/charity/img3.jpg" alt="公益活动现场" loading="lazy" class="charity-gallery-img" />
          <img src="/assets/charity/logo.jpg" alt="蝴蝶宝贝关爱中心" loading="lazy" class="charity-gallery-img charity-gallery-img--sm" />
        </div>
      </div>
    </section>

    <!-- ── 承诺 & 联系 ── -->
    <section class="charity-section reveal reveal-rise">
      <div class="section-inner">
        <div class="charity-promise">
          <div class="charity-promise-quote">
            <div class="charity-promise-line" aria-hidden="true"></div>
            <blockquote class="charity-promise-text">
              让每一寸脆弱的皮肤，都得到最专业的守护。
            </blockquote>
            <p class="charity-promise-body">
              海得宝将持续关注蝴蝶宝贝群体的护理需求，用深耕的科研实力，陪伴每个罕见病家庭走过艰难时刻。我们相信，每一次温和的修护，都是对生命最有力的支持。
            </p>
          </div>
          <div class="charity-contact">
            <div class="charity-contact-title">申领产品 · 护理咨询</div>
            <p class="charity-contact-body">
              如果您是EB患者家庭或相关公益机构，需要了解产品申领或护理咨询，请通过以下方式联系我们：
            </p>
            <div class="charity-contact-method">
              <span class="charity-contact-method-label">微信公众号</span>
              <strong class="charity-contact-method-value">海得宝MARTEMPO</strong>
            </div>
            <p class="charity-contact-closing">
              让我们一同，为蝴蝶宝贝撑起温暖的保护伞。
            </p>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    import '../../scripts/reveal.js';
  </script>
</BaseLayout>

<style>
  /* ── Hero ── */
  .charity-hero {
    position: relative;
    width: 100%;
    min-height: 65vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .charity-hero-img-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .charity-hero-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .charity-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      oklch(10% 0.02 185 / 0.3) 0%,
      oklch(10% 0.02 185 / 0.6) 60%,
      oklch(10% 0.02 185 / 0.78) 100%
    );
  }

  .charity-hero-content {
    position: relative;
    z-index: 1;
    padding-top: 140px;
    padding-bottom: var(--space-5xl);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 65vh;
  }

  .charity-breadcrumb {
    font-size: var(--text-xs);
    margin-bottom: auto;
    padding-bottom: var(--space-4xl);
  }

  .charity-breadcrumb a,
  .charity-breadcrumb .sep,
  .charity-breadcrumb .current {
    color: oklch(95% 0.01 185 / 0.75);
    text-decoration: none;
  }

  .charity-breadcrumb a:hover { color: #fff; }
  .charity-breadcrumb .sep { margin: 0 6px; }

  .charity-hero-accent {
    width: 40px;
    height: 2px;
    background: var(--color-brand);
    margin-bottom: var(--space-xl);
  }

  .charity-hero-title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 200;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-wide);
    color: #ffffff;
    margin-bottom: var(--space-md);
  }

  .charity-hero-subtitle {
    font-size: var(--text-xl);
    font-weight: 300;
    color: oklch(95% 0.02 185 / 0.9);
    margin-bottom: var(--space-xl);
  }

  .charity-hero-badge {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: var(--tracking-wider);
    color: var(--color-brand-dark);
    background: oklch(92% 0.06 185);
    padding: var(--space-sm) var(--space-lg);
  }

  /* ── Shared section ── */
  .charity-section {
    padding: var(--space-6xl) var(--content-padding);
    background: #ffffff;
  }

  .charity-section--alt {
    background: var(--color-bg-light);
  }

  .charity-section-title {
    font-size: var(--text-3xl);
    font-weight: 200;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .charity-section-subtitle {
    font-size: var(--text-base);
    font-weight: 300;
    color: var(--color-text-soft);
  }

  /* ── Intro ── */
  .charity-intro {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }

  .charity-intro-body {
    font-size: var(--text-lg);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text-soft);
  }

  /* ── Block (image + text) ── */
  .charity-block {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: center;
  }

  .charity-block--reverse {
    grid-template-columns: 1fr 1fr;
  }

  .charity-block--reverse .charity-block-text {
    order: 1;
  }

  .charity-block--reverse .charity-block-media {
    order: 0;
  }

  .charity-block-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-widest);
    color: var(--color-brand);
    text-transform: uppercase;
    margin-bottom: var(--space-lg);
  }

  .charity-block-title {
    font-size: var(--text-2xl);
    font-weight: 200;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    margin-bottom: var(--space-xl);
  }

  .charity-block-body {
    font-size: var(--text-base);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text-soft);
    margin-bottom: var(--space-lg);
  }

  .charity-block-body:last-child { margin-bottom: 0; }

  .charity-img {
    display: block;
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    box-shadow: 0 12px 40px oklch(30% 0.02 200 / 0.12);
  }

  .charity-highlight {
    display: flex;
    gap: var(--space-md);
    align-items: baseline;
    font-size: var(--text-base);
    font-weight: 400;
    color: var(--color-brand-dark);
    line-height: var(--leading-relaxed);
    padding: var(--space-lg) var(--space-xl);
    background: oklch(95% 0.04 185);
    border: 1px solid oklch(85% 0.06 185);
    margin-top: var(--space-xl);
  }

  .charity-highlight-marker {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    margin-top: 0.5em;
    background: var(--color-brand);
    border-radius: 50%;
  }

  .charity-features {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .charity-feature {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-brand-dark);
    background: oklch(95% 0.04 185);
    padding: var(--space-sm) var(--space-lg);
  }

  .charity-feature-dot {
    width: 6px;
    height: 6px;
    background: var(--color-brand);
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── Video ── */
  .charity-video-wrap {
    max-width: 900px;
    margin: 0 auto;
  }

  .charity-video-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wider);
    color: var(--color-brand);
    text-transform: uppercase;
    margin-bottom: var(--space-lg);
    text-align: center;
  }

  .charity-video-container {
    position: relative;
    width: 100%;
  }

  .charity-video {
    display: block;
    width: 100%;
    aspect-ratio: 16/9;
    background: oklch(10% 0 0);
    box-shadow: 0 16px 48px oklch(30% 0.02 200 / 0.15);
  }

  /* ── Plan ── */
  .charity-plan-header {
    margin-bottom: var(--space-4xl);
  }

  .charity-plan-badge {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wider);
    color: #ffffff;
    background: var(--color-brand);
    padding: 4px var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .charity-actions {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
  }

  .charity-action {
    display: flex;
    gap: var(--space-xl);
    padding: var(--space-2xl);
    background: var(--color-bg-light);
    border-top: 3px solid var(--color-brand);
    align-items: flex-start;
  }

  .charity-action-num {
    font-size: clamp(2rem, 3vw, 2.75rem);
    font-weight: 700;
    color: var(--color-brand-subtle);
    letter-spacing: var(--tracking-tight);
    line-height: 1;
    flex-shrink: 0;
  }

  .charity-action-title {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-md);
    letter-spacing: var(--tracking-wide);
  }

  .charity-action-body {
    font-size: var(--text-sm);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text-soft);
  }

  /* ── Gallery ── */
  .charity-gallery {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .charity-gallery-img {
    display: block;
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
    box-shadow: 0 8px 24px oklch(30% 0.02 200 / 0.1);
  }

  .charity-gallery-img--sm {
    aspect-ratio: 4/3;
  }

  /* ── Promise ── */
  .charity-promise {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5xl);
    align-items: start;
  }

  .charity-promise-line {
    width: 40px;
    height: 2px;
    background: var(--color-brand);
    margin-bottom: var(--space-xl);
  }

  .charity-promise-text {
    font-size: var(--text-xl);
    font-weight: 200;
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    margin: 0 0 var(--space-xl);
    padding: 0;
    border: none;
    quotes: none;
  }

  .charity-promise-body {
    font-size: var(--text-base);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text-soft);
  }

  .charity-contact {
    padding: var(--space-2xl);
    background: var(--color-bg-light);
    border-top: 3px solid var(--color-brand);
  }

  .charity-contact-title {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-lg);
  }

  .charity-contact-body {
    font-size: var(--text-sm);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text-soft);
    margin-bottom: var(--space-xl);
  }

  .charity-contact-method {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
    padding: var(--space-lg);
    background: oklch(95% 0.04 185);
  }

  .charity-contact-method-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wider);
    color: var(--color-brand);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .charity-contact-method-value {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-brand-dark);
  }

  .charity-contact-closing {
    font-size: var(--text-sm);
    font-weight: 400;
    line-height: var(--leading-relaxed);
    color: var(--color-text-soft);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .charity-block,
    .charity-block--reverse {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .charity-block--reverse .charity-block-text { order: 0; }
    .charity-block--reverse .charity-block-media { order: 1; }

    .charity-actions {
      grid-template-columns: 1fr;
    }

    .charity-gallery {
      grid-template-columns: 1fr;
    }

    .charity-promise {
      grid-template-columns: 1fr;
      gap: var(--space-3xl);
    }
  }

  @media (max-width: 768px) {
    .charity-hero {
