---
// Dev server & production: Decap CMS admin page
// Uses JS-based manual init instead of config.yml for reliability
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>海得宝 — 内容管理</title>
  <style>
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      color: #555;
    }
    /* 全屏加载层，decap 渲染完成后由脚本淡出移除 */
    #loading {
      position: fixed;
      inset: 0;
      z-index: 9999;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      background: #f5f5f5;
      transition: opacity 0.4s ease;
    }
    #loading.hidden {
      opacity: 0;
      pointer-events: none;
    }
    #loading h1 {
      font-size: 1.5rem;
      font-weight: 400;
      margin-bottom: 0.5rem;
    }
    #loading p {
      font-size: 0.9rem;
      color: #999;
    }
  </style>
</head>
<body>
  <div class="loading" id="loading">
    <h1>海得宝 · 内容管理</h1>
    <p>正在加载管理后台...</p>
  </div>
  <script is:inline>
    window.CMS_MANUAL_INIT = true;
  </script>
  <script is:inline src="https://unpkg.com/decap-cms@3.14.1/dist/decap-cms.js"></script>
  <!-- HTML→Markdown 转换库，用于「原始模式」下粘贴图文时保留格式与图片 -->
  <script is:inline src="https://unpkg.com/turndown@7.2.0/dist/turndown.js"></script>
  <script is:inline src="https://unpkg.com/turndown-plugin-gfm@1.0.2/dist/turndown-plugin-gfm.js"></script>
  <script is:inline>
    // ── 粘贴处理 ──
    // 原始模式(CodeMirror)：把剪贴板 HTML 转成 Markdown 再插入，图文一起带进来
    // 富文本模式(Slate)：直接吃图片 HTML 会崩溃，只插纯文本防崩
    var _turndown = null;
    function getTurndown() {
      if (_turndown) return _turndown;
      if (!window.TurndownService) return null;
      _turndown = new window.TurndownService({
        headingStyle: 'atx',
        hr: '---',
        bulletListMarker: '-',
        codeBlockStyle: 'fenced',
        emDelimiter: '*',
        linkStyle: 'inlined',
      });
      if (window.turndownPluginGfm && window.turndownPluginGfm.gfm) {
        _turndown.use(window.turndownPluginGfm.gfm);
      }
      _turndown.remove(['script', 'style', 'noscript', 'head']);
      // base64 内嵌图片(data:URI)体积巨大会撑爆内容文件，替换为提示
      _turndown.addRule('dropDataImage', {
        filter: function (node) {
          return node.nodeName === 'IMG' && /^data:/i.test(node.getAttribute('src') || '');
        },
        replacement: function () { return '（此处有图片，请用底部图片按钮上传）'; },
      });
      return _turndown;
    }
    function htmlToMarkdown(html) {
      var td = getTurndown();
      if (!td) return '';
      try { return td.turndown(html).trim(); } catch (err) { return ''; }
    }

    document.addEventListener('paste', function (e) {
      var el = e.target;
      if (!el || !el.closest) return;

      var cmEl = el.closest('.CodeMirror');            // CodeMirror 源码编辑器
      var slateEl = el.closest('[data-slate-editor]'); // Slate 富文本编辑器
      var textarea = el.tagName === 'TEXTAREA' ? el : null; // 普通文本框（正文 text 组件）
      if (!cmEl && !slateEl && !textarea) return;

      var cd = e.clipboardData || window.clipboardData;
      if (!cd) return;
      var html = cd.getData('text/html');
      var plain = cd.getData('text/plain');

      // 普通文本框（正文源码框）：剪贴板带富文本 HTML 时转 Markdown 插入，
      // 否则不拦截、交给浏览器默认粘贴纯文本（不影响摘要等其它文本框）
      if (textarea) {
        if (html) {
          var mdT = htmlToMarkdown(html);
          if (mdT) {
            e.preventDefault();
            e.stopPropagation();
            document.execCommand('insertText', false, mdT);
          }
        }
        return;
      }

      // 原始模式：HTML → Markdown 后插入（保留标题/加粗/列表/链接/图片）
      if (cmEl && cmEl.CodeMirror) {
        e.preventDefault();
        e.stopPropagation();
        var md = html ? htmlToMarkdown(html) : '';
        cmEl.CodeMirror.replaceSelection(md || plain || '');
        return;
      }

      // 富文本模式：只插纯文本，防止 Slate 解析图片 HTML 时崩溃
      if (slateEl) {
        e.preventDefault();
        e.stopPropagation();
        if (plain) document.execCommand('insertText', false, plain);
      }
    }, true);

    CMS.init({
      config: {
        load_config_file: false,
        backend: {
          name: 'github',
          repo: 'znjznb/front-new',
          branch: 'main',
          base_url: 'https://www.martempo.com.cn',
          auth_endpoint: 'oauth/auth',
        },
        media_folder: 'public/assets',
        public_folder: '/assets',
        locale: 'zh_Hans',
        collections: [
          {
            name: 'news',
            label: '新闻',
            label_singular: '新闻',
            folder: 'src/content/news',
            create: true,
            delete: true,
            format: 'frontmatter',
            slug: '{{slug}}',
            preview_path: 'news/{{slug}}/',
            media_folder: '../../public/images/news',
            public_folder: '/images/news',
            editor: {
              preview: false,
            },
            fields: [
              { label: '标题', name: 'title', widget: 'string' },
              { label: '发布日期', name: 'date', widget: 'datetime', format: 'YYYY-MM-DD', date_format: 'YYYY-MM-DD', time_format: false },
              { label: '摘要', name: 'summary', widget: 'text', hint: '首页新闻卡片上显示的一两句话，建议不超过100字' },
              { label: '来源媒体', name: 'author', widget: 'string', required: false, hint: '如：新华社、美妆头条、青眼、化妆品观察' },
              { label: '原文链接', name: 'sourceUrl', widget: 'string', required: false, hint: '文章原始出处URL，填写后详情页底部显示"阅读原文"按钮' },
              { label: '正文配图上传（备用）', name: 'body_images', widget: 'list', required: false, allow_add: true, hint: '备用上传通道。正常情况下请直接用正文框上方的「🖼 在光标处插入图片」按钮，会自动上传并插入。此处仅在按钮不可用时备用：上传后在正文写 ![](/images/news/文件名) 引用。', field: { label: '图片', name: 'src', widget: 'image' } },
              { label: '正文', name: 'body', widget: 'text', hint: '文章正文（Markdown 源码框，稳定不崩、可自由删改）。粘贴：直接从网页复制粘贴即可，标题/加粗/列表/链接会自动转为 Markdown。插入图片：把图片存到电脑后，点正文框上方的「🖼 在光标处插入图片」按钮选图即可，自动在光标处插入、无需手写代码。（微信复制的图片会显示为「图片」二字，用来标记该插图的位置。）' },
            ],
          },
          {
            name: 'products',
            label: '产品',
            label_singular: '产品',
            folder: 'src/cms-products',
            create: true,
            delete: true,
            format: 'json',
            slug: '{{slug}}',
            fields: [
              // ── Basic info ──
              { label: '产品名称', name: 'name', widget: 'string' },
              { label: '副标题', name: 'nickname', widget: 'string', required: false, hint: '商品名下方显示的一句话，如"5分钟即刻修护 一帖告别EMO唇"' },
              { label: '描述', name: 'desc', widget: 'text', required: false, hint: '不影响详情页展示，仅作备注参考' },

              // ── Classification ──
              { label: '产品线', name: 'line', widget: 'select', options: ['专业线｜Expert Collection', '婴童线｜Primal Comfort', '女性线｜Féminine Collection', '医用敷料｜Biocellulaire Therapy'], required: false, hint: '仅供 CMS 标记，不影响网站显示' },
              { label: '产品类型', name: 'types', widget: 'select', multiple: true, options: ['精华/面霜', '水/洁面', '身体护理', '唇部护理', '院线同款'], required: false, hint: '可多选，留空则根据名称自动推断' },
              { label: '销售状态', name: 'status', widget: 'select', options: ['在售', '即将上市', '即将更换包装', '即将停售'], required: false, hint: '控制详情页是否显示状态徽章' },

              // ── Media ──
              { label: '主图', name: 'image', widget: 'file', media_folder: '/public/assets', public_folder: '/assets', hint: '商品卡片和详情页主图' },
              { label: '轮播图列表', name: 'images', widget: 'list', field: { label: '图片', name: 'src', widget: 'file', media_folder: '/public/assets', public_folder: '/assets', hint: '上传轮播图片' }, required: false, hint: '详情页多图轮播，留空自动组合' },

              // ── Product details ──
              { label: '适用肤质', name: 'skin_type', widget: 'string', required: false, hint: '如"干性和极干性, 敏感肌"（多值用逗号分隔）' },
              { label: '适用人群', name: 'audience', widget: 'string', required: false, hint: '如"成人, 儿童"（多值用逗号分隔）' },
              { label: '功效标签', name: 'efficacy', widget: 'list', required: false, hint: '每行一个，如：保湿 / 舒缓 / 修护' },
              { label: 'SKU 规格', name: 'skus', widget: 'list', required: false, hint: '如有多个容量或颜色，在此添加', fields: [
                { label: '规格名称', name: 'label', widget: 'string', hint: '如 150g、350g、8g' },
                { label: '规格图片', name: 'image', widget: 'file', media_folder: '/public/assets', public_folder: '/assets', hint: '该规格对应的产品图' },
                { label: '销售状态', name: 'status', widget: 'select', options: ['在售', '即将上市', '即将更换包装', '即将停售'], required: false, hint: '留空默认 "在售"' },
              ] },
              { label: '产品成分', name: 'ingredients', widget: 'text', required: false, hint: '一行一个，或用 "水"，"甘油"，... 格式（引号+顿号分隔）' },

              // ── Product details tab ──
              { label: '功效数据', name: 'can_claim', widget: 'text', required: false, hint: '详情页"产品详情"标签的数据来源。用 / 分隔每条数据，支持自动提取数值卡片和认证徽章' },
              { label: '产品详情（自定义）', name: 'detail_description', widget: 'markdown', required: false, hint: '填写后替代自动解析的功效数据，完全自定义"产品详情"标签内容' },

              // ── Commerce ──
              { label: '购买链接', name: 'buy_url', widget: 'string', required: false, hint: '立即购买跳转链接，留空使用默认淘宝链接' },
              { label: '排序', name: 'order', widget: 'number', value_type: 'int', required: false, hint: '数字越小越靠前，留空则排在最后' },
            ],
          },
        ],
      },
    });
  </script>
  <script is:inline>
    // decap 渲染出后台界面后，淡出并移除加载层
    (function () {
      var loading = document.getElementById('loading');
      if (!loading) return;
      function hide() {
        loading.classList.add('hidden');
        setTimeout(function () { if (loading.parentNode) loading.parentNode.removeChild(loading); }, 500);
      }
      function ready() {
        return Array.prototype.some.call(document.body.children, function (el) {
          return el.id !== 'loading' && el.tagName !== 'SCRIPT' && el.children.length > 0;
        });
      }
      if (ready()) { hide(); return; }
      var obs = new MutationObserver(function () { if (ready()) { obs.disconnect(); hide(); } });
      obs.observe(document.body, { childList: true, subtree: true });
      setTimeout(function () { obs.disconnect(); hide(); }, 12000);
    })();
  </script>
  <script is:inline>
    // ── 正文「在光标处插入图片」按钮 ──
    // 选择本地图片 → 用登录令牌直传 GitHub 仓库 → 在正文光标处插入 ![](路径)
    (function () {
      var REPO = 'znjznb/front-new';
      var BRANCH = 'main';
      var UPLOAD_DIR = 'public/images/news';   // 图片提交到的仓库目录
      var PUBLIC_PREFIX = '/images/news';       // 正文引用前缀（对应 public 目录）

      function getToken() {
        try {
          var u = JSON.parse(localStorage.getItem('decap-cms-user') || 'null');
          return (u && (u.token || (u.data && u.data.token))) || null;
        } catch (e) { return null; }
      }

      // 通过 label 文本「正文」精确定位正文文本框
      function findBodyTextarea() {
        var labels = document.querySelectorAll('label');
        for (var i = 0; i < labels.length; i++) {
          if (labels[i].textContent.trim() !== '正文') continue;
          var forId = labels[i].getAttribute('for');
          if (forId) {
            var ta = document.getElementById(forId);
            if (ta && ta.tagName === 'TEXTAREA') return ta;
          }
          var wrap = labels[i].parentNode;
          for (var d = 0; d < 4 && wrap; d++) {
            var t = wrap.querySelector && wrap.querySelector('textarea');
            if (t) return t;
            wrap = wrap.parentNode;
          }
        }
        return null;
      }

      var lastSel = { start: null, end: null };
      function trackCursor(ta) {
        function save() { lastSel.start = ta.selectionStart; lastSel.end = ta.selectionEnd; }
        ['keyup', 'mouseup', 'select', 'blur', 'input', 'click'].forEach(function (ev) {
          ta.addEventListener(ev, save);
        });
      }
      function insertAtCursor(ta, text) {
        ta.focus();
        var s = lastSel.start, e = lastSel.end;
        if (s == null) { s = e = ta.value.length; }
        ta.setSelectionRange(s, e);
        document.execCommand('insertText', false, text); // 触发 React onChange
        lastSel.start = lastSel.end = s + text.length;
      }
      function extOf(name) {
        var m = /\.([a-zA-Z0-9]+)$/.exec(name || '');
        var ext = m ? m[1].toLowerCase() : 'jpg';
        return ext === 'jpeg' ? 'jpg' : ext;
      }

      function uploadAndInsert(file, ta, statusEl, btn) {
        var token = getToken();
        if (!token) { statusEl.textContent = '未取到登录令牌，请重新登录后台再试'; return; }
        var filename = 'img_' + Date.now() + '.' + extOf(file.name);
        var path = UPLOAD_DIR + '/' + filename;
        btn.disabled = true;
        statusEl.textContent = '上传中…';
        var reader = new FileReader();
        reader.onload = function () {
          var base64 = String(reader.result).split(',')[1];
          fetch('https://api.github.com/repos/' + REPO + '/contents/' + path, {
            method: 'PUT',
            headers: {
              'Authorization': 'token ' + token,
              'Accept': 'application/vnd.github+json',
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({ message: 'CMS上传正文图片 ' + filename, content: base64, branch: BRANCH }),
          }).then(function (res) {
            if (!res.ok) return res.text().then(function (t) { throw new Error(res.status + ' ' + t.slice(0, 120)); });
            return res.json();
          }).then(function () {
            insertAtCursor(ta, '\n\n![](' + PUBLIC_PREFIX + '/' + filename + ')\n\n');
            statusEl.textContent = '已在光标处插入 ✓';
            btn.disabled = false;
            setTimeout(function () { statusEl.textContent = ''; }, 4000);
          }).catch(function (err) {
            statusEl.textContent = '上传失败：' + (err && err.message ? err.message : err);
            btn.disabled = false;
          });
        };
        reader.onerror = function () { statusEl.textContent = '读取图片失败'; btn.disabled = false; };
        reader.readAsDataURL(file);
      }

      function injectButton(ta) {
        if (ta.__imgBtnInjected) return;
        ta.__imgBtnInjected = true;
        trackCursor(ta);

        var bar = document.createElement('div');
        bar.style.cssText = 'display:flex;align-items:center;gap:10px;margin:6px 0;';
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.textContent = '🖼 在光标处插入图片';
        btn.style.cssText = 'padding:6px 12px;font-size:13px;cursor:pointer;border:1px solid #c4c6d0;border-radius:5px;background:#fff;color:#333;';
        var fileInput = document.createElement('input');
        fileInput.type = 'file';
        fileInput.accept = 'image/*';
        fileInput.style.display = 'none';
        var status = document.createElement('span');
        status.style.cssText = 'font-size:12px;color:#888;';

        btn.addEventListener('click', function () { fileInput.value = ''; fileInput.click(); });
        fileInput.addEventListener('change', function () {
          if (fileInput.files && fileInput.files[0]) uploadAndInsert(fileInput.files[0], ta, status, btn);
        });
        bar.appendChild(btn); bar.appendChild(status); bar.appendChild(fileInput);
        ta.parentNode.insertBefore(bar, ta);
      }

      var obs = new MutationObserver(function () {
        var ta = findBodyTextarea();
        if (ta) injectButton(ta);
      });
      obs.observe(document.body, { childList: true, subtree: true });
      var t0 = findBodyTextarea();
      if (t0) injectButton(t0);
    })();
  </script>
</body>
</html>
