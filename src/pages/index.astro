---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import DeepSeaStory from '../components/DeepSeaStory.astro';
import CapcsSection from '../components/CapcsSection.astro';
import ProductGallery from '../components/ProductGallery.astro';
import TrustSection from '../components/TrustSection.astro';
import QaSection from '../components/QaSection.astro';
import NewsSection from '../components/NewsSection.astro';
import VideoSection from '../components/VideoSection.astro';
import CtaSection from '../components/CtaSection.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Nav />
  <main>
    <Hero />
    <DeepSeaStory />
    <CapcsSection />
    <ProductGallery />
    <TrustSection />
    <QaSection />
    <NewsSection />
    <VideoSection />
    <CtaSection />
  </main>
  <Footer />

  <script>
    import '../scripts/reveal.js';
  </script>
</BaseLayout>
