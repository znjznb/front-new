---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import DeepSeaStory from '../components/DeepSeaStory.astro';
import CapcsSection from '../components/CapcsSection.astro';
import ProductGallery from '../components/ProductGallery.astro';
import TrustSection from '../components/TrustSection.astro';
import QaSection from '../components/QaSection.astro';
import NewsSection from '../components/NewsSection.astro';
import VideoSection from '../components/VideoSection.astro';
import CtaSection from '../components/CtaSection.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Nav />
  <main>
    <Hero />
    <DeepSeaStory />
    <CapcsSection />
    <ProductGallery />
    <TrustSection />
    <QaSection maxItems={5} />
    <NewsSection />
    <VideoSection />
    <CtaSection />
  </main>
  <Footer />

  <button class="back-to-top" id="backToTop" aria-label="返回顶部">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 15l-6-6-6 6"/>
    </svg>
  </button>

  <script>
    import '../scripts/reveal.js';
  </script>
</BaseLayout>

<style>
  .back-to-top {
    position: fixed;
    bottom: 32px;
    right: 32px;
    z-index: 1000;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--color-border-light);
    background: rgba(255,255,255,0.9);
    backdrop-filter: blur(8px);
    color: var(--color-text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(12px);
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s ease, color var(--duration-fast) ease;
    box-shadow: 0 2px 12px oklch(0% 0 0 / 0.06);
  }

  .back-to-top.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .back-to-top:hover {
    color: var(--color-brand);
    border-color: var(--color-brand);
  }

  @media (max-width: 768px) {
    .back-to-top {
      bottom: 20px;
      right: 20px;
      width: 40px;
      height: 40px;
    }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const btn = document.getElementById('backToTop');
  if (!btn) return;

  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(() => {
        btn.classList.toggle('visible', window.scrollY > 400);
        ticking = false;
      });
      ticking = true;
    }
  });

  btn.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
});
</script>
