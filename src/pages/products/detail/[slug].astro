---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import {
  getAllProducts,
  getProductSlug,
  getLineDisplayName,
  getLineEnName,
  getLineImage,
  getLineAccentColor,
  getLineHeroGradient,
  getProductTypes,
  getProductImages,
  getProductImage,
  getProductBuyUrl,
  getProductSkus,
} from '../../../data/products';

export async function getStaticPaths() {
  const products = getAllProducts();
  return products.map(p => ({
    params: { slug: getProductSlug(p) },
    props: { product: p },
  }));
}

const { product } = Astro.props;

const lineName = getLineDisplayName(product.line);
const lineEnName = getLineEnName(product.line);
const accentColor = getLineAccentColor(product.line);
const heroGradient = getLineHeroGradient(product.line);
const skus = getProductSkus(product);
const productImages = skus
  ? skus.map(s => s.image).slice(0, product.name === 'тцДуЎйу«АуЅ╣Тіцжюю' ? 2 : 8)
  : getProductImages(product);
const activeColor = accentColor;
const defaultStatus = skus && skus[0] && skus[0].status ? skus[0].status : (product.status || '');
const buyUrl = getProductBuyUrl(product);

// Parse ingredients into array
function parseIngredients(raw) {
  if (!raw || raw === '/' || raw === '') return [];
  if (Array.isArray(raw)) {
    // Elements contain quoted-comma fragments split across lines; join and reparse
    if (raw.some(s => s.includes('"№╝ї'))) {
      return raw.join(',').split(/№╝ї"?/).map(s => s.replace(/^"/, '').replace(/"$/, '').trim()).filter(Boolean);
    }
    // Each element is a standalone ingredient
    return raw.map(s => s.trim()).filter(Boolean);
  }
  // JSON array format: ["Т░┤"№╝ї"ућўТ▓╣"...]  (uses Chinese commas)
  if (raw.startsWith('[')) {
    try {
      return JSON.parse(raw.replace(/№╝ї/g, ','));
    } catch {
      return raw.replace(/[\[\]"]/g, '').split(/№╝ї/).map(s => s.trim()).filter(Boolean);
    }
  }
  // Quoted string format: "Т░┤"№╝ї"ућўТ▓╣"...
  // Split by the pattern "№╝ї" (closing quote + Chinese comma + opening quote)
  return raw.split(/"№╝ї"?/).map(s => s.replace(/^"/, '').replace(/"$/, '').trim()).filter(Boolean);
}

const ingredients = parseIngredients(product.ingredients);

// Skin type display
const skinTypeLabel = Array.isArray(product.skin_type)
  ? product.skin_type.filter(Boolean)
  : (product.skin_type && product.skin_type !== 'None'
    ? product.skin_type.split(',').map(s => s.trim()).filter(Boolean)
    : []);

// Audience display
const audienceLabel = Array.isArray(product.audience)
  ? product.audience.filter(Boolean)
  : (product.audience && product.audience !== 'None'
    ? product.audience.split(',').map(s => s.trim()).filter(Boolean)
    : []);

// Efficacy display
const efficacyTags = Array.isArray(product.efficacy)
  ? product.efficacy.filter(Boolean)
  : (product.efficacy && product.efficacy !== 'None'
    ? product.efficacy.split(',').map(s => s.trim()).filter(Boolean)
    : []);

// РћђРћђ Parse claims into structured cards РћђРћђ
function parseClaimsForCards(raw) {
  if (!raw || raw === '/' || raw === '') return { highlights: [], certs: [], fullText: [] };

  const items = raw.split(/[\/\n]+/).map(s => s.trim()).filter(Boolean);
  const highlights = [];
  const certSet = new Set();
  const fullText = [];

  const certKeywords = ['ТЌаТ┐ђу┤а', 'ТЌажў▓УЁљтЅѓ', 'тЁЦтЈБТЌаТ»њ', 'тЁЦую╝ТЌатѕ║Т┐ђ', 'ТЋЈТёЪУѓїжђѓуће', 'ТќЉУ┤┤ТЌатѕ║Т┐ђ', 'ТќЉУ┤┤ТЌаСИЇУЅ»тЈЇт║ћ'];

  for (const item of items) {
    // Strip leading numbering (1сђЂ 2. 3) etc., keep digits inside words like "1h"
    const clean = item.replace(/^\d+[сђЂ.№╝ј\s]\s*/, '').trim();

    // Extract cert keywords
    for (const kw of certKeywords) {
      if (clean.includes(kw)) certSet.add(kw);
    }

    // РћђРћђ Single-value metrics РћђРћђ

    // Water content: "тљФТ░┤жЄЈТћ╣тќёС║є 27.27%" or "27.27% Т░┤тѕєтљФжЄЈТћ╣тќёујЄ"
    let m = clean.match(/(\d+\.?\d*)%\s*(?:Т░┤тѕє|тљФТ░┤).?жЄЈ/);
    if (!m) m = clean.match(/(?:Т░┤тѕє|тљФТ░┤).?жЄЈ.*?Тћ╣тќё[С║єујЄ].*?(\d+\.?\d*)%/);
    if (m) highlights.push({ value: m[1] + '%', label: 'тљФТ░┤жЄЈТћ╣тќё' });

    // Redness: "у║бУЅ▓у┤аТїЄТаЄТћ╣тќёС║єX%" or "Уцфу║б/УАђу║бу┤аТћ╣тќёујЄX%"
    m = clean.match(/(Уцфу║б|УАђу║бу┤а|у║бУЅ▓у┤а).*?Тћ╣тќё[С║єујЄ].*?(\d+\.?\d*)%/);
    if (m) highlights.push({ value: m[2] + '%', label: m[1] === 'УАђу║бу┤а' ? 'УАђу║бу┤аТћ╣тќё' : 'Уцфу║бТћ╣тќё' });

    // TEWL: "у╗Јуџ«Т░┤тѕєТхЂтц▒TEWLТћ╣тќёС║єX%"
    m = clean.match(/у╗Јуџ«Т░┤тѕєТхЂтц▒.*?Тћ╣тќё[С║єујЄ].*?(\d+\.?\d*)%/);
    if (m) highlights.push({ value: m[1] + '%', label: 'т▒ЈжџюС┐«Тіц' });

    // РћђРћђ Multi-value: "XТћ╣тќёујЄтѕєтѕФТў» A%сђЂB%сђЂC%сђЂD%" РћђРћђ
    // Matches patterns like:
    //   "ТГбуЌњТћ╣тќёујЄтѕєтѕФТў» 24.24%сђЂ27.27%сђЂ33.33%тњї45.45%"
    //   "Aтђ╝№╝ѕУѕњу╝Њ№╝ЅТћ╣тќёујЄтѕєтѕФТў» 2.81%сђЂ6.16%сђЂ14.20%тњї 22.45%"
    // Extract the symptom name and the last value (longest duration)
    m = clean.match(/(?:Aтђ╝[№╝ѕ(]\s*([^№╝Ѕ)]+)\s*[№╝Ѕ)]|(Уѕњу╝Њ|ТГбуЌњ|тѕ║уЌЏ|уЂ╝уЃГ|у║бТќЉ|Уё▒т▒Љ))\s*Тћ╣тќёујЄтѕєтѕФТў»\s*(\d+\.?\d*)%[сђЂ№╝ї]\s*(\d+\.?\d*)%[сђЂ№╝ї]\s*(\d+\.?\d*)%[тњї&]?\s*(\d+\.?\d*)%/);
    if (m) {
      const sym = m[1] || m[2];
      const symLabelMap = { 'Уѕњу╝Њ': 'Уѕњу╝Њ', 'ТГбуЌњ': 'ТГбуЌњ', 'тѕ║уЌЏ': 'тѕ║уЌЏ', 'уЂ╝уЃГ': 'уЂ╝уЃГ', 'у║бТќЉ': 'у║бТќЉ', 'Уё▒т▒Љ': 'Уё▒т▒Љ' };
      highlights.push({ value: m[6] + '%', label: symLabelMap[sym] + '№╝ѕ2h№╝Ѕ' });
    }

    // РћђРћђ Single-value relief metrics (existing) РћђРћђ
    for (const sym of ['уЂ╝уЃГ', 'уўЎуЌњ', 'тѕ║уЌЏ', 'у║бТќЉ']) {
      const durations = [
        { re: new RegExp(sym + 'у╝ЊУДБ.*?2h\\s*[-РђЊРђћ+](\\d+\\.?\\d*)%'), label: '2h' },
        { re: new RegExp(sym + 'у╝ЊУДБ.*?15min\\s*[-РђЊРђћ+](\\d+\\.?\\d*)%'), label: '15min' },
        { re: new RegExp(sym + 'у╝ЊУДБ.*?5min\\s*[-РђЊРђћ+](\\d+\\.?\\d*)%'), label: '5min' },
        { re: new RegExp(sym + 'у╝ЊУДБ.*?1min\\s*[-РђЊРђћ+](\\d+\\.?\\d*)%'), label: '1min' },
      ];
      for (const { re, label } of durations) {
        m = clean.match(re);
        if (m) {
          highlights.push({ value: m[1] + '%', label: sym + 'у╝ЊУДБ№╝ѕ' + label + '№╝Ѕ' });
          break;
        }
      }
    }
    // Extract skin elasticity improvement
    m = clean.match(/(уџ«Уѓцт╝╣ТђД|у┤ДУЄ┤т║д).*?Тћ╣тќёујЄ.*?(\d+\.?\d*)%/);
    if (m) highlights.push({ value: m[2] + '%', label: 'у┤ДУЄ┤ТЈљтЇЄ' });

    // Extract wrinkle improvement
    m = clean.match(/(уџ▒у║╣|ТіЌуџ▒).*?Тћ╣тќёујЄ.*?(\d+\.?\d*)%/);
    if (m) highlights.push({ value: m[1] + '%', label: 'ТиАу║╣' });

    // Extract oil control
    m = clean.match(/Т▓╣УёѓТћ╣тќёујЄ.*?(\d+\.?\d*)%/);
    if (m) highlights.push({ value: m[1] + '%', label: 'ТјДТ▓╣' });

    // Extract acne improvement
    m = clean.match(/уЌўуѓ╣.*?Тћ╣тќёујЄ.*?(\d+\.?\d*)%/);
    if (m) highlights.push({ value: m[1] + '%', label: 'уЦЏуЌўТћ╣тќё' });

    // Collect full text (skip very short items that are just cert statements)
    if (clean.length > 8) fullText.push(clean);
  }

  // Deduplicate highlights (keep first occurrence)
  const seen = new Set();
  const deduped = highlights.filter(h => {
    const key = h.value + h.label;
    if (seen.has(key)) return false;
    seen.add(key);
    return true;
  });

  return {
    highlights: deduped.slice(0, 8),
    certs: [...certSet],
    fullText,
  };
}

const { highlights, certs, fullText } = parseClaimsForCards(product.can_claim);
const detailDescription = product.detail_description || '';
---

<BaseLayout
  title={`${product.name} Рђћ ТхитЙЌт«Ю MarTempo`}
  description={product.nickname || product.desc || `${product.name} Рђћ ${getLineDisplayName(product.line)}С║ДтЊЂ`}
>
  <Nav />
  <main>
    <!-- Product Hero -->
    <section class="detail-hero" style={`background: ${heroGradient}`}>
      <nav class="detail-breadcrumb" aria-label="жЮбтїЁт▒Љт»╝Уѕф">
        <div class="breadcrumb-inner">
          <a href="/">ждќжАх</a>
          <span class="sep">Рђ║</span>
          <a href="/products/series">С║ДтЊЂу│╗тѕЌ</a>
          <span class="sep">Рђ║</span>
          <a href={`/products/${product.line === 'СИЊСИџу║┐' ? 'professional' : product.line.includes('тЦ│ТђДу║┐') ? 'feminine' : 'baby'}`}>
            {lineName}
          </a>
          <span class="sep">Рђ║</span>
          <span class="current">{product.name}</span>
        </div>
      </nav>
      <div class="detail-hero-inner">
        <div class="detail-gallery" id="productGallery">
          <div class="detail-gallery-main">
            <button class="gallery-arrow gallery-prev" id="galleryPrev" aria-label="СИіСИђт╝а">Рђ╣</button>
            <div class="gallery-track" id="galleryTrack">
              {productImages.map((img, i) => (
                <div class="gallery-slide" data-index={i}>
                  <img src={img} alt={`${product.name} - тЏЙуЅЄ${i + 1}`} width="600" height="450" loading={i === 0 ? 'eager' : 'lazy'} />
                </div>
              ))}
            </div>
            <button class="gallery-arrow gallery-next" id="galleryNext" aria-label="СИІСИђт╝а">Рђ║</button>
            <span id="skuStatusBadge" class="detail-status-badge" data-init-status={defaultStatus}></span>
          </div>
          {productImages.length > 1 && (
            <div class="gallery-thumbs" id="galleryThumbs">
              {productImages.map((img, i) => (
                <button class:list={['gallery-thumb', { active: i === 0 }]} data-index={i}>
                  <img src={img} alt={`${product.name} - у╝ЕуЋЦтЏЙ${i + 1}`} width="80" height="60" loading="lazy" />
                </button>
              ))}
            </div>
          )}
        </div>
        <div class="detail-info">
          <div class="detail-line-label" style={`--accent: ${activeColor}`}>
            {lineName}<span class="line-en">{lineEnName}</span>
          </div>
          <h1 class="detail-name">{product.name}</h1>
          {product.nickname && (
            <p class="detail-nickname">{product.nickname}</p>
          )}
          {!product.nickname && product.desc && (
            <p class="detail-nickname">{product.desc}</p>
          )}
          {efficacyTags.length > 0 && (
            <div class="detail-tags">
              {efficacyTags.map(tag => (
                <span class="detail-tag">{tag}</span>
              ))}
            </div>
          )}
          <div class="detail-meta">
            {skinTypeLabel.length > 0 && (
              <div class="meta-row">
                <span class="meta-label">жђѓућеУѓцУ┤е</span>
                <span class="meta-value">{skinTypeLabel.join('сђЂ')}</span>
              </div>
            )}
            {audienceLabel.length > 0 && (
              <div class="meta-row">
                <span class="meta-label">жђѓућеС║║уЙц</span>
                <span class="meta-value">{audienceLabel.join('сђЂ')}</span>
              </div>
            )}
          </div>
          {skus && (
            <div class="sku-selector">
              <span class="sku-label">УДёТа╝ / жбюУЅ▓</span>
              <div class="sku-options">
                {skus.map((sku, i) => (
                  <button class:list={['sku-btn', { active: i === 0 }]} data-sku-index={i} data-sku-status={sku.status || 'тюетћ«'} aria-label={sku.label}>
                    {sku.label}
                  </button>
                ))}
              </div>
            </div>
          )}
          <div class="cta-wrapper">
            <a class="detail-cta" style={`--accent: ${activeColor}`} href={buyUrl} target="_blank" rel="noopener noreferrer">
              <span>уФІтЇ│У┤ГС╣░</span>
              <span class="cta-arrow">Рєњ</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Tabbed Content -->
    <section class="detail-tabs-section">
      <div class="section-inner">
        <div class="tabs-nav" role="tablist">
          <button class="tab-btn active" role="tab" data-tab="detail">С║ДтЊЂУ»дТЃЁ</button>
          {ingredients.length > 0 && (
            <button class="tab-btn" role="tab" data-tab="ingredients">С║ДтЊЂТѕљтѕє</button>
          )}
        </div>

        <div class="tabs-content">
          <!-- Tab: С║ДтЊЂУ»дТЃЁ -->
          <div class="tab-panel active" id="tab-detail" role="tabpanel">
            {detailDescription ? (
              <div class="detail-markdown" set:html={detailDescription}></div>
            ) : (
              <>
                {highlights.length > 0 && (
                  <div class="metric-grid" style={`--card-accent: ${activeColor}`}>
                    {highlights.map(h => (
                      <div class="metric-card">
                        <span class="metric-value">{h.value}</span>
                        <span class="metric-label">{h.label}</span>
                      </div>
                    ))}
                  </div>
                )}
                {certs.length > 0 && (
                  <div class="cert-row">
                    {certs.map(c => <span class="cert-badge">{c}</span>)}
                  </div>
                )}
                {highlights.length > 0 && fullText.length > 0 && (
                  <details class="detail-expand">
                    <summary class="detail-expand-summary">ТЪЦуюІт«їТЋ┤тіЪТЋѕТЋ░ТЇ«</summary>
                    <ul class="claim-list">
                      {fullText.map(item => <li>{item}</li>)}
                    </ul>
                  </details>
                )}
                {highlights.length === 0 && fullText.length > 0 && (
                  <ul class="claim-list">
                    {fullText.map(item => <li>{item}</li>)}
                  </ul>
                )}
                {highlights.length === 0 && fullText.length === 0 && (
                  <p class="tab-empty">ТџѓТЌаУ»ду╗єС┐АТЂ»сђѓ</p>
                )}
              </>
            )}
          </div>

          <!-- Tab: С║ДтЊЂТѕљтѕє -->
          {ingredients.length > 0 && (
            <div class="tab-panel" id="tab-ingredients" role="tabpanel">
              <p class="ingredients-note">С╗ЦСИІСИ║С║ДтЊЂтЁеТѕљтѕєтѕЌУАе№╝їТїЅТхЊт║джЎЇт║ЈТјњтѕЌсђѓ</p>
              <ul class="ingredients-list">
                {ingredients.map(ing => (
                  <li>{ing}</li>
                ))}
              </ul>
            </div>
          )}

        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
document.addEventListener('DOMContentLoaded', () => {
  // РћђРћђ Tabs РћђРћђ
  const tabs = document.querySelectorAll('.tab-btn');
  const panels = {
    detail: document.getElementById('tab-detail'),
    ingredients: document.getElementById('tab-ingredients'),
  };

  tabs.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.tab;
      tabs.forEach(b => b.classList.remove('active'));
      Object.values(panels).forEach(p => { if (p) p.classList.remove('active'); });
      btn.classList.add('active');
      if (panels[target]) panels[target].classList.add('active');
    });
  });

  // РћђРћђ Gallery Carousel РћђРћђ
  const track = document.getElementById('galleryTrack');
  const slides = track?.querySelectorAll('.gallery-slide');
  const thumbs = document.querySelectorAll('.gallery-thumb');
  const prevBtn = document.getElementById('galleryPrev');
  const nextBtn = document.getElementById('galleryNext');

  if (!track || !slides?.length) return;

  let currentIndex = 0;

  function goTo(index) {
    if (index < 0) index = slides.length - 1;
    if (index >= slides.length) index = 0;
    currentIndex = index;
    track.style.transform = `translateX(-${currentIndex * 100}%)`;
    thumbs.forEach(t => t.classList.toggle('active', parseInt(t.dataset.index) === currentIndex));
  }

  prevBtn?.addEventListener('click', () => goTo(currentIndex - 1));
  nextBtn?.addEventListener('click', () => goTo(currentIndex + 1));

  thumbs.forEach(thumb => {
    thumb.addEventListener('click', () => goTo(parseInt(thumb.dataset.index)));
  });

  // Keyboard navigation
  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowLeft') goTo(currentIndex - 1);
    if (e.key === 'ArrowRight') goTo(currentIndex + 1);
  });

  // РћђРћђ SKU Status Badge РћђРћђ
  const statusBadge = document.getElementById('skuStatusBadge');

  function getStatusDisplay(status) {
    if (!status || status === 'тюетћ«' || status === 'ти▓СИітИѓ') return null;
    const map = { 'тЇ│т░єСИітИѓ': 'тЇ│т░єСИітИѓ', 'тЇ│т░єТЏ┤ТЇбтїЁУБЁ': 'тЇ│т░єТЇбТќ░', 'тЇ│т░єтЂютћ«': 'тЇ│т░єтЂютћ«' };
    return map[status] || null;
  }

  function updateStatusBadge(status) {
    if (!statusBadge) return;
    const display = getStatusDisplay(status);
    if (!display) {
      statusBadge.style.display = 'none';
      return;
    }
    statusBadge.style.display = '';
    statusBadge.textContent = display;
    statusBadge.className = 'detail-status-badge';
    if (status === 'тЇ│т░єТЏ┤ТЇбтїЁУБЁ') statusBadge.classList.add('badge-warn');
    if (status === 'тЇ│т░єтЂютћ«') statusBadge.classList.add('badge-muted');
  }

  // РћђРћђ SKU Variant Selector РћђРћђ
  const skuBtns = document.querySelectorAll('.sku-btn');
  if (skuBtns.length > 0) {
    updateStatusBadge(skuBtns[0].dataset.skuStatus);
  } else if (statusBadge && statusBadge.dataset.initStatus) {
    updateStatusBadge(statusBadge.dataset.initStatus);
  }

  skuBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const index = parseInt(btn.dataset.skuIndex);
      skuBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      goTo(index);
      updateStatusBadge(btn.dataset.skuStatus);
    });
  });
});
</script>

<style>
  /* РћђРћђ Breadcrumb РћђРћђ */
  .detail-breadcrumb {
    padding: 100px var(--content-padding) var(--space-xl);
  }

  .detail-breadcrumb .breadcrumb-inner {
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  .detail-breadcrumb a {
    font-size: var(--text-xs);
    color: oklch(50% 0.01 260 / 0.6);
    text-decoration: none;
    transition: color var(--duration-fast) ease;
  }

  .detail-breadcrumb a:hover {
    color: var(--color-brand);
  }

  .detail-breadcrumb .sep {
    margin: 0 6px;
    color: oklch(50% 0.01 260 / 0.5);
    font-size: var(--text-xs);
  }

  .detail-breadcrumb .current {
    font-size: var(--text-xs);
    color: oklch(35% 0.015 260 / 0.7);
    font-weight: 500;
  }

  /* РћђРћђ Hero РћђРћђ */
  .detail-hero {
    padding: 0 var(--content-padding) var(--space-4xl);
  }

  .detail-hero-inner {
    max-width: var(--content-max-width);
