---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Nav from '../../../components/Nav.astro';
import Footer from '../../../components/Footer.astro';
import {
  getAllProducts,
  getProductSlug,
  getLineDisplayName,
  getLineEnName,
  getLineImage,
  getLineAccentColor,
  getLineHeroGradient,
  getProductTypes,
  getProductImages,
  getProductImage,
  getProductBuyUrl,
  getProductSkus,
} from '../../../data/products';

export async function getStaticPaths() {
  const products = getAllProducts();
  return products.map(p => ({
    params: { slug: getProductSlug(p) },
    props: { product: p },
  }));
}

const { product } = Astro.props;

const lineName = getLineDisplayName(product.line);
const lineEnName = getLineEnName(product.line);
const accentColor = getLineAccentColor(product.line);
const heroGradient = getLineHeroGradient(product.line);
const skus = getProductSkus(product);
const productImages = skus
  ? skus.map(s => s.image).slice(0, product.name === '大白管特护霜' ? 2 : 8)
  : getProductImages(product);
const activeColor = accentColor;
const defaultStatus = skus && skus[0] && skus[0].status ? skus[0].status : (product.status || '');
const buyUrl = getProductBuyUrl(product);

// Parse ingredients into array
function parseIngredients(raw) {
  if (!raw || raw === '/' || raw === '') return [];
  if (Array.isArray(raw)) return raw.filter(Boolean);
  // JSON array format: ["水"，"甘油"...]  (uses Chinese commas)
  if (raw.startsWith('[')) {
    try {
      return JSON.parse(raw.replace(/，/g, ','));
    } catch {
      return raw.replace(/[\[\]"]/g, '').split(/，/).map(s => s.trim()).filter(Boolean);
    }
  }
  // Quoted string format: "水"，"甘油"...
  // Split by the pattern "，" (closing quote + Chinese comma + opening quote)
  return raw.split(/"，"?/).map(s => s.replace(/^"/, '').replace(/"$/, '').trim()).filter(Boolean);
}

const ingredients = parseIngredients(product.ingredients);

// Skin type display
const skinTypeLabel = Array.isArray(product.skin_type)
  ? product.skin_type.filter(Boolean)
  : (product.skin_type && product.skin_type !== 'None'
    ? product.skin_type.split(',').map(s => s.trim()).filter(Boolean)
    : []);

// Audience display
const audienceLabel = Array.isArray(product.audience)
  ? product.audience.filter(Boolean)
  : (product.audience && product.audience !== 'None'
    ? product.audience.split(',').map(s => s.trim()).filter(Boolean)
    : []);

// Efficacy display
const efficacyTags = Array.isArray(product.efficacy)
  ? product.efficacy.filter(Boolean)
  : (product.efficacy && product.efficacy !== 'None'
    ? product.efficacy.split(',').map(s => s.trim()).filter(Boolean)
    : []);

// ── Parse claims into structured cards ──
function parseClaimsForCards(raw) {
  if (!raw || raw === '/' || raw === '') return { highlights: [], certs: [], fullText: [] };

  const items = raw.split(/[\/\n]+/).map(s => s.trim()).filter(Boolean);
  const highlights = [];
  const certSet = new Set();
  const fullText = [];

  const certKeywords = ['无激素', '无防腐剂', '入口无毒', '入眼无刺激', '敏感肌适用', '斑贴无刺激', '斑贴无不良反应'];

  for (const item of items) {
    // Strip leading numbering (1、 2. 3) etc., keep digits inside words like "1h"
    const clean = item.replace(/^\d+[、.．\s]\s*/, '').trim();

    // Extract cert keywords
    for (const kw of certKeywords) {
      if (clean.includes(kw)) certSet.add(kw);
    }

    // Extract water content improvement: "Xh后的含水量/水分含量改善率Y%"
    let m = clean.match(/(\d+\.?\d*)%\s*(?:水分|含水).?量/);
    if (!m) m = clean.match(/(?:水分|含水).?量.*?改善率.*?(\d+\.?\d*)%/);
    if (m) highlights.push({ value: m[1] + '%', label: '含水量改善' });

    // Extract redness reduction: "褪红（a值）改善率Y%" or "血红素改善率Y%"
    m = clean.match(/(褪红|血红素).*?改善率.*?(\d+\.?\d*)%/);
    if (m) highlights.push({ value: m[2] + '%', label: m[1] === '血红素' ? '血红素改善' : '褪红改善' });

    // Extract TEWL: "经皮水分流失改善率Y%"
    m = clean.match(/经皮水分流失.*?改善率.*?(\d+\.?\d*)%/);
    if (m) highlights.push({ value: m[1] + '%', label: '屏障修护' });

    // Extract relief metrics — try 2h first, then 15min, 5min, 1min
    for (const sym of ['灼热', '瘙痒', '刺痛', '红斑']) {
      const durations = [
        { re: new RegExp(sym + '缓解.*?2h\\s*[-–—+](\\d+\\.?\\d*)%'), label: '2h' },
        { re: new RegExp(sym + '缓解.*?15min\\s*[-–—+](\\d+\\.?\\d*)%'), label: '15min' },
        { re: new RegExp(sym + '缓解.*?5min\\s*[-–—+](\\d+\\.?\\d*)%'), label: '5min' },
        { re: new RegExp(sym + '缓解.*?1min\\s*[-–—+](\\d+\\.?\\d*)%'), label: '1min' },
      ];
      for (const { re, label } of durations) {
        m = clean.match(re);
        if (m) {
          highlights.push({ value: m[1] + '%', label: sym + '缓解（' + label + '）' });
          break;
        }
      }
    }
    // Extract skin elasticity improvement
    m = clean.match(/(皮肤弹性|紧致度).*?改善率.*?(\d+\.?\d*)%/);
    if (m) highlights.push({ value: m[2] + '%', label: '紧致提升' });

    // Extract wrinkle improvement
    m = clean.match(/(皱纹|抗皱).*?改善率.*?(\d+\.?\d*)%/);
    if (m) highlights.push({ value: m[1] + '%', label: '淡纹' });

    // Extract oil control
    m = clean.match(/油脂改善率.*?(\d+\.?\d*)%/);
    if (m) highlights.push({ value: m[1] + '%', label: '控油' });

    // Extract acne improvement
    m = clean.match(/痘点.*?改善率.*?(\d+\.?\d*)%/);
    if (m) highlights.push({ value: m[1] + '%', label: '祛痘改善' });

    // Collect full text (skip very short items that are just cert statements)
    if (clean.length > 8) fullText.push(clean);
  }

  // Deduplicate highlights (keep first occurrence)
  const seen = new Set();
  const deduped = highlights.filter(h => {
    const key = h.value + h.label;
    if (seen.has(key)) return false;
    seen.add(key);
    return true;
  });

  return {
    highlights: deduped.slice(0, 8),
    certs: [...certSet],
    fullText,
  };
}

const { highlights, certs, fullText } = parseClaimsForCards(product.can_claim);
const detailDescription = product.detail_description || '';
---

<BaseLayout
  title={`${product.name} — 海得宝 MarTempo`}
  description={product.nickname || product.desc || `${product.name} — ${getLineDisplayName(product.line)}产品`}
>
  <Nav />
  <main>
    <!-- Product Hero -->
    <section class="detail-hero" style={`background: ${heroGradient}`}>
      <nav class="detail-breadcrumb" aria-label="面包屑导航">
        <div class="breadcrumb-inner">
          <a href="/">首页</a>
          <span class="sep">›</span>
          <a href="/products/series">产品系列</a>
          <span class="sep">›</span>
          <a href={`/products/${product.line === '专业线' ? 'professional' : product.line.includes('女性线') ? 'feminine' : 'baby'}`}>
            {lineName}
          </a>
          <span class="sep">›</span>
          <span class="current">{product.name}</span>
        </div>
      </nav>
      <div class="detail-hero-inner">
        <div class="detail-gallery" id="productGallery">
          <div class="detail-gallery-main">
            <button class="gallery-arrow gallery-prev" id="galleryPrev" aria-label="上一张">‹</button>
            <div class="gallery-track" id="galleryTrack">
              {productImages.map((img, i) => (
                <div class="gallery-slide" data-index={i}>
                  <img src={img} alt={`${product.name} - 图片${i + 1}`} width="600" height="450" loading={i === 0 ? 'eager' : 'lazy'} />
                </div>
              ))}
            </div>
            <button class="gallery-arrow gallery-next" id="galleryNext" aria-label="下一张">›</button>
            <span id="skuStatusBadge" class="detail-status-badge" data-init-status={defaultStatus}></span>
          </div>
          {productImages.length > 1 && (
            <div class="gallery-thumbs" id="galleryThumbs">
              {productImages.map((img, i) => (
                <button class:list={['gallery-thumb', { active: i === 0 }]} data-index={i}>
                  <img src={img} alt={`${product.name} - 缩略图${i + 1}`} width="80" height="60" loading="lazy" />
                </button>
              ))}
            </div>
          )}
        </div>
        <div class="detail-info">
          <div class="detail-line-label" style={`--accent: ${activeColor}`}>
            {lineName}<span class="line-en">{lineEnName}</span>
          </div>
          <h1 class="detail-name">{product.name}</h1>
          {product.nickname && (
            <p class="detail-nickname">{product.nickname}</p>
          )}
          {!product.nickname && product.desc && (
            <p class="detail-nickname">{product.desc}</p>
          )}
          {efficacyTags.length > 0 && (
            <div class="detail-tags">
              {efficacyTags.map(tag => (
                <span class="detail-tag">{tag}</span>
              ))}
            </div>
          )}
          <div class="detail-meta">
            {skinTypeLabel.length > 0 && (
              <div class="meta-row">
                <span class="meta-label">适用肤质</span>
                <span class="meta-value">{skinTypeLabel.join('、')}</span>
              </div>
            )}
            {audienceLabel.length > 0 && (
              <div class="meta-row">
                <span class="meta-label">适用人群</span>
                <span class="meta-value">{audienceLabel.join('、')}</span>
              </div>
            )}
          </div>
          {skus && (
            <div class="sku-selector">
              <span class="sku-label">规格 / 颜色</span>
              <div class="sku-options">
                {skus.map((sku, i) => (
                  <button class:list={['sku-btn', { active: i === 0 }]} data-sku-index={i} data-sku-status={sku.status || '在售'} aria-label={sku.label}>
                    {sku.label}
                  </button>
                ))}
              </div>
            </div>
          )}
          <div class="cta-wrapper">
            <a class="detail-cta" style={`--accent: ${activeColor}`} href={buyUrl} target="_blank" rel="noopener noreferrer">
              <span>立即购买</span>
              <span class="cta-arrow">→</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Tabbed Content -->
    <section class="detail-tabs-section">
      <div class="section-inner">
        <div class="tabs-nav" role="tablist">
          <button class="tab-btn active" role="tab" data-tab="detail">产品详情</button>
          {ingredients.length > 0 && (
            <button class="tab-btn" role="tab" data-tab="ingredients">产品成分</button>
          )}
        </div>

        <div class="tabs-content">
          <!-- Tab: 产品详情 -->
          <div class="tab-panel active" id="tab-detail" role="tabpanel">
            {detailDescription ? (
              <div class="detail-markdown" set:html={detailDescription}></div>
            ) : (
              <>
                {highlights.length > 0 && (
                  <div class="metric-grid" style={`--card-accent: ${activeColor}`}>
                    {highlights.map(h => (
                      <div class="metric-card">
                        <span class="metric-value">{h.value}</span>
                        <span class="metric-label">{h.label}</span>
                      </div>
                    ))}
                  </div>
                )}
                {certs.length > 0 && (
                  <div class="cert-row">
                    {certs.map(c => <span class="cert-badge">{c}</span>)}
                  </div>
                )}
                {highlights.length > 0 && fullText.length > 0 && (
                  <details class="detail-expand">
                    <summary class="detail-expand-summary">查看完整功效数据</summary>
                    <ul class="claim-list">
                      {fullText.map(item => <li>{item}</li>)}
                    </ul>
                  </details>
                )}
                {highlights.length === 0 && fullText.length > 0 && (
                  <ul class="claim-list">
                    {fullText.map(item => <li>{item}</li>)}
                  </ul>
                )}
                {highlights.length === 0 && fullText.length === 0 && (
                  <p class="tab-empty">暂无详细信息。</p>
                )}
              </>
            )}
          </div>

          <!-- Tab: 产品成分 -->
          {ingredients.length > 0 && (
            <div class="tab-panel" id="tab-ingredients" role="tabpanel">
              <p class="ingredients-note">以下为产品全成分列表，按浓度降序排列。</p>
              <ul class="ingredients-list">
                {ingredients.map(ing => (
                  <li>{ing}</li>
                ))}
              </ul>
            </div>
          )}

        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
document.addEventListener('DOMContentLoaded', () => {
  // ── Tabs ──
  const tabs = document.querySelectorAll('.tab-btn');
  const panels = {
    detail: document.getElementById('tab-detail'),
    ingredients: document.getElementById('tab-ingredients'),
  };

  tabs.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.tab;
      tabs.forEach(b => b.classList.remove('active'));
      Object.values(panels).forEach(p => { if (p) p.classList.remove('active'); });
      btn.classList.add('active');
      if (panels[target]) panels[target].classList.add('active');
    });
  });

  // ── Gallery Carousel ──
  const track = document.getElementById('galleryTrack');
  const slides = track?.querySelectorAll('.gallery-slide');
  const thumbs = document.querySelectorAll('.gallery-thumb');
  const prevBtn = document.getElementById('galleryPrev');
  const nextBtn = document.getElementById('galleryNext');

  if (!track || !slides?.length) return;

  let currentIndex = 0;

  function goTo(index) {
    if (index < 0) index = slides.length - 1;
    if (index >= slides.length) index = 0;
    currentIndex = index;
    track.style.transform = `translateX(-${currentIndex * 100}%)`;
    thumbs.forEach(t => t.classList.toggle('active', parseInt(t.dataset.index) === currentIndex));
  }

  prevBtn?.addEventListener('click', () => goTo(currentIndex - 1));
  nextBtn?.addEventListener('click', () => goTo(currentIndex + 1));

  thumbs.forEach(thumb => {
    thumb.addEventListener('click', () => goTo(parseInt(thumb.dataset.index)));
  });

  // Keyboard navigation
  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowLeft') goTo(currentIndex - 1);
    if (e.key === 'ArrowRight') goTo(currentIndex + 1);
  });

  // ── SKU Status Badge ──
  const statusBadge = document.getElementById('skuStatusBadge');

  function getStatusDisplay(status) {
    if (!status || status === '在售' || status === '已上市') return null;
    const map = { '即将上市': '即将上市', '即将更换包装': '即将换新', '即将停售': '即将停售' };
    return map[status] || null;
  }

  function updateStatusBadge(status) {
    if (!statusBadge) return;
    const display = getStatusDisplay(status);
    if (!display) {
      statusBadge.style.display = 'none';
      return;
    }
    statusBadge.style.display = '';
    statusBadge.textContent = display;
    statusBadge.className = 'detail-status-badge';
    if (status === '即将更换包装') statusBadge.classList.add('badge-warn');
    if (status === '即将停售') statusBadge.classList.add('badge-muted');
  }

  // ── SKU Variant Selector ──
  const skuBtns = document.querySelectorAll('.sku-btn');
  if (skuBtns.length > 0) {
    updateStatusBadge(skuBtns[0].dataset.skuStatus);
  } else if (statusBadge && statusBadge.dataset.initStatus) {
    updateStatusBadge(statusBadge.dataset.initStatus);
  }

  skuBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const index = parseInt(btn.dataset.skuIndex);
      skuBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      goTo(index);
      updateStatusBadge(btn.dataset.skuStatus);
    });
  });
});
</script>

<style>
  /* ── Breadcrumb ── */
  .detail-breadcrumb {
    padding: 100px var(--content-padding) var(--space-xl);
  }

  .detail-breadcrumb .breadcrumb-inner {
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  .detail-breadcrumb a {
    font-size: var(--text-xs);
    color: oklch(50% 0.01 260 / 0.6);
    text-decoration: none;
    transition: color var(--duration-fast) ease;
  }

  .detail-breadcrumb a:hover {
    color: var(--color-brand);
  }

  .detail-breadcrumb .sep {
    margin: 0 6px;
    color: oklch(50% 0.01 260 / 0.5);
    font-size: var(--text-xs);
  }

  .detail-breadcrumb .current {
    font-size: var(--text-xs);
    color: oklch(35% 0.015 260 / 0.7);
    font-weight: 500;
  }

  /* ── Hero ── */
  .detail-hero {
    padding: 0 var(--content-padding) var(--space-4xl);
  }

  .detail-hero-inner {
    max-width: var(--content-max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: start;
  }

  /* Gallery */
  .detail-gallery {
    position: sticky;
    top: 120px;
  }

  .detail-gallery-main {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .gallery-track {
    display: flex;
    transition: transform 0.4s var(--ease-out-expo);
    backface-visibility: hidden;
  }

  .gallery-slide {
    min-width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    background: transparent;
    min-height: 420px;
  }

  .gallery-slide img {
    width: 100%;
    max-height: 420px;
    object-fit: contain;
    display: block;
  }

  .gallery-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--color-border-light);
    background: rgba(255, 255, 255, 0.85);
    color: var(--color-text);
    font-size: 1.4rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--duration-fast) ease;
    backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity var(--duration-fast) ease, background var(--duration-fast) ease;
  }

  @media (hover: none) {
    .gallery-arrow {
      opacity: 1;
    }
  }

  .detail-gallery-main:hover .gallery-arrow {
    opacity: 1;
  }

  .gallery-arrow:hover {
    background: var(--color-surface);
    box-shadow: 0 2px 8px oklch(0% 0 0 / 0.10);
  }

  .gallery-prev {
    left: 12px;
  }

  .gallery-next {
    right: 12px;
  }

  .gallery-thumbs {
    display: flex;
    gap: 8px;
    margin-top: 12px;
    overflow-x: auto;
    padding-bottom: 4px;
  }

  .gallery-thumb {
    flex-shrink: 0;
    width: 72px;
    height: 54px;
    border: 2px solid transparent;
    border-radius: var(--radius-sm);
    overflow: hidden;
    cursor: pointer;
    padding: 4px;
    background: transparent;
    transition: border-color var(--duration-fast) ease;
  }

  .gallery-thumb.active {
    border-color: var(--color-brand);
  }

  .gallery-thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .detail-status-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    background: var(--color-brand);
    color: var(--color-text-inverse);
    font-size: var(--text-xs);
    font-weight: 600;
    padding: 4px 12px;
    letter-spacing: var(--tracking-wider);
  }

  .badge-warn {
    background: oklch(0.75 0.10 75);
  }

  .badge-muted {
    background: oklch(0.60 0.02 260);
  }

  /* Info */
  .detail-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .detail-line-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--accent, var(--color-brand));
  }

  .line-en {
    font-weight: 400;
    letter-spacing: var(--tracking-wide);
    margin-left: 8px;
    color: oklch(55% 0.01 260 / 0.6);
  }

  .detail-name {
    font-size: var(--text-2xl);
    font-weight: 400;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    line-height: var(--leading-snug);
  }

  .detail-nickname {
    font-size: var(--text-base);
    color: var(--color-text-soft);
    line-height: var(--leading-relaxed);
  }

  .detail-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .detail-tag {
    font-size: 0.75rem;
    padding: 4px 10px;
    background: var(--color-brand-subtle);
    color: var(--color-brand-dark);
    border-radius: var(--radius-sm);
    font-weight: 500;
  }

  .detail-meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--color-border-light);
  }

  .meta-row {
    display: flex;
    gap: var(--space-md);
    font-size: var(--text-sm);
  }

  .meta-label {
    color: var(--color-text-muted);
    min-width: 80px;
    flex-shrink: 0;
  }

  .meta-value {
    color: var(--color-text-soft);
  }

  /* ── SKU Selector ── */
  .sku-selector {
    padding: var(--space-md) 0;
    border-top: 1px solid var(--color-border-light);
  }

  .sku-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    display: block;
    margin-bottom: 8px;
  }

  .sku-options {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .sku-btn {
    padding: 6px 14px;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all var(--duration-fast) ease;
