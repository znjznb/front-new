---
import ProductLayout from '../../layouts/ProductLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getProductsByLine } from '../../data/products';

const products = getProductsByLine('婴童线');

const breadcrumbs = [
  { label: '首页', href: '/' },
  { label: '产品', href: '/products' },
  { label: '婴童线' },
];
---

<ProductLayout
  title="婴童线｜Primal Comfort — 海得宝 MARTEMPO"
  description="专为婴幼儿娇嫩肌肤打造的温和护理系列，极简配方、入口无毒。"
  breadcrumbs={breadcrumbs}
>
  <section slot="hero" class="category-hero">
    <div class="category-hero-bg"></div>
    <div class="category-hero-content">
      <h1 class="category-hero-title">婴童线</h1>
      <span class="category-hero-sub" style="color:oklch(0.80 0.06 92)">Primal Comfort</span>
      <p class="category-hero-desc">专为婴幼儿娇嫩肌肤打造的温和护理系列。极简配方，入口无毒，从新生儿到儿童都能安心使用。金银花、贻贝提取物等天然成分配合CAPCS®科技，温和舒缓干红痒。</p>
    </div>
  </section>
  <section slot="content">
    <div class="product-grid-header">
      <p class="product-count">{products.length} 件产品</p>
    </div>
    <div class="product-grid">
      {products.map(product => (
        <ProductCard product={product} />
      ))}
    </div>
  </section>
</ProductLayout>

<style>
  .category-hero {
    position: relative;
    padding: var(--space-6xl) var(--content-padding) var(--space-5xl);
    background: linear-gradient(135deg, oklch(96% 0.008 92) 0%, oklch(98% 0.004 92) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 320px;
  }

  .category-hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 600px;
  }

  .category-hero-title {
    font-size: var(--text-3xl);
    font-weight: 400;
    letter-spacing: var(--tracking-normal);
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }
    color: var(--color-text);
    margin-bottom: var(--space-sm);
  }

  .category-hero-sub {
    display: block;
    font-size: var(--text-sm);
    font-weight: 400;
    margin-bottom: var(--space-lg);
  }

  .category-hero-desc {
    font-size: var(--text-sm);
    color: var(--color-text-soft);
    line-height: var(--leading-relaxed);
  }

  .product-grid-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border-light);
  }

  .product-count {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 30px;
  }

  @media (max-width: 768px) {
    .category-hero {
      min-height: 240px;
      padding: var(--space-5xl) var(--content-padding) var(--space-4xl);
    }
    .category-hero-title {
      font-size: var(--text-2xl);
    }
    .product-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-md);
    }
  }

  @media (max-width: 480px) {
    .product-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
