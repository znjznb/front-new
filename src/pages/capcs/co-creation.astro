---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout title="共创实验室 — 海得宝 MARTEMPO" description="海得宝共创实验室：与科研者、皮肤科医生、敏感肌用户共同探索贻贝钙肽CAPCS的无限可能，共创更好的敏感肌护理方案。">
  <Nav />
  <main>

    <!-- ── Hero ── -->
    <section class="coco-hero">
      <div class="coco-hero-img-wrap">
        <img
          src="/assets/co-creation-hero.jpg"
          alt="海得宝共创实验室"
          class="coco-hero-img"
          loading="eager"
          fetchpriority="high"
        />
        <div class="coco-hero-overlay" aria-hidden="true"></div>
      </div>
      <div class="coco-hero-content section-inner">
        <nav class="coco-breadcrumb" aria-label="面包屑导航">
          <a href="/">首页</a>
          <span class="sep">›</span>
          <a href="#">贻贝钙肽CAPCS</a>
          <span class="sep">›</span>
          <span class="current">共创实验室</span>
        </nav>
        <div class="coco-hero-text">
          <div class="coco-hero-accent" aria-hidden="true"></div>
          <h1 class="coco-hero-title">共创实验室</h1>
          <p class="coco-hero-subtitle">与你一同，探索敏感肌护理的科学边界</p>
        </div>
      </div>
    </section>

    <!-- ── 理念 ── -->
    <section class="coco-section reveal reveal-rise">
      <div class="section-inner">
        <div class="coco-intro">
          <h2 class="coco-intro-title">开放的科学，共同的探索</h2>
          <p class="coco-intro-body">
            海得宝相信，最好的护肤解决方案，不是在封闭实验室里单独研发出来的，而是与皮肤科医生、科研机构和千万敏感肌家庭共同创造的。共创实验室是我们打开科研边界的尝试——让每一位关注敏感肌的人，都能参与到更好产品的诞生之中。
          </p>
        </div>
      </div>
    </section>

    <!-- ── 共创方向 ── -->
    <section class="coco-section coco-section--alt reveal reveal-rise">
      <div class="section-inner">
        <div class="coco-section-header">
          <h2 class="coco-section-title">共创方向</h2>
          <p class="coco-section-subtitle">三条路径，共同推进敏感肌护理科学</p>
        </div>
        <div class="coco-pillars">
          <div class="coco-pillar">
            <div class="coco-pillar-num">01</div>
            <h3 class="coco-pillar-title">临床科研合作</h3>
            <p class="coco-pillar-body">与国内顶级皮肤科医疗机构共同开展真实世界研究，将临床洞察转化为产品迭代的核心依据，让每一次配方升级都有循证数据支撑。</p>
          </div>
          <div class="coco-pillar">
            <div class="coco-pillar-num">02</div>
            <h3 class="coco-pillar-title">用户反馈闭环</h3>
            <p class="coco-pillar-body">建立真实用户反馈机制，深度采集敏感肌人群在不同环境、季节、肤况下的使用体验，驱动配方精准迭代，让产品真正"懂"敏感肌。</p>
          </div>
          <div class="coco-pillar">
            <div class="coco-pillar-num">03</div>
            <h3 class="coco-pillar-title">开放成分探索</h3>
            <p class="coco-pillar-body">联合高校、科研机构，围绕贻贝钙肽CAPCS（凯普斯泰）的作用机制持续开展基础研究，探索"钙离子舒缓"在更广泛皮肤问题中的应用潜力。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── 参与方式 ── -->
    <section class="coco-section reveal reveal-rise">
      <div class="section-inner">
        <div class="coco-join">
          <div class="coco-join-text">
            <h2 class="coco-section-title">如何参与</h2>
            <p class="coco-join-body">无论你是皮肤科医生、科研工作者，还是有着深刻护肤体验的敏感肌用户——共创实验室欢迎每一位真诚的探索者。</p>
            <ul class="coco-join-list">
              <li class="coco-join-item">
                <span class="coco-join-dot" aria-hidden="true"></span>
                <span><strong>皮肤科医生 / 研究机构</strong>：联系我们探讨临床合作与联合课题机会</span>
              </li>
              <li class="coco-join-item">
                <span class="coco-join-dot" aria-hidden="true"></span>
                <span><strong>敏感肌用户</strong>：加入产品体验官计划，分享真实肤况反馈，参与新品共测</span>
              </li>
              <li class="coco-join-item">
                <span class="coco-join-dot" aria-hidden="true"></span>
                <span><strong>品牌合作方</strong>：探索围绕敏感肌科学的联名与内容共创可能</span>
              </li>
            </ul>
            <p class="coco-join-contact">合作咨询请通过微信公众号 <strong>「海得宝MARTEMPO」</strong> 与我们取得联系。</p>
          </div>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <script>
    import '../../scripts/reveal.js';
  </script>
</BaseLayout>

<style>
  /* ── Hero ── */
  .coco-hero {
    position: relative;
    width: 100%;
    min-height: 70vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .coco-hero-img-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .coco-hero-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  .coco-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      oklch(10% 0.02 185 / 0.35) 0%,
      oklch(10% 0.02 185 / 0.55) 60%,
      oklch(10% 0.02 185 / 0.72) 100%
    );
  }

  .coco-hero-content {
    position: relative;
    z-index: 1;
    padding-top: 140px;
    padding-bottom: var(--space-5xl);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 70vh;
  }

  .coco-breadcrumb {
    font-size: var(--text-xs);
    margin-bottom: auto;
    padding-bottom: var(--space-4xl);
  }

  .coco-breadcrumb a,
  .coco-breadcrumb .sep,
  .coco-breadcrumb .current {
    color: oklch(95% 0.01 185 / 0.75);
    text-decoration: none;
  }

  .coco-breadcrumb a:hover {
    color: #fff;
  }

  .coco-breadcrumb .sep {
    margin: 0 6px;
  }

  .coco-hero-accent {
    width: 40px;
    height: 2px;
    background: var(--color-brand);
    margin-bottom: var(--space-xl);
  }

  .coco-hero-title {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 200;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-wide);
    color: #ffffff;
    margin-bottom: var(--space-lg);
  }

  .coco-hero-subtitle {
    font-size: var(--text-lg);
    font-weight: 300;
    color: oklch(95% 0.01 185 / 0.85);
    max-width: 44ch;
  }

  /* ── Shared section ── */
  .coco-section {
    padding: var(--space-6xl) var(--content-padding);
    background: #ffffff;
  }

  .coco-section--alt {
    background: var(--color-bg-light);
  }

  .coco-section-header {
    margin-bottom: var(--space-4xl);
  }

  .coco-section-title {
    font-size: var(--text-3xl);
    font-weight: 200;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .coco-section-subtitle {
    font-size: var(--text-base);
    font-weight: 300;
    color: var(--color-text-soft);
  }

  /* ── Intro ── */
  .coco-intro {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }

  .coco-intro-label {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-widest);
    color: var(--color-brand);
    text-transform: uppercase;
    margin-bottom: var(--space-lg);
  }

  .coco-intro-title {
    font-size: var(--text-3xl);
    font-weight: 200;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    margin-bottom: var(--space-xl);
  }

  .coco-intro-body {
    font-size: var(--text-base);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text-soft);
  }

  /* ── Pillars ── */
  .coco-pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .coco-pillar {
    padding: var(--space-2xl);
    background: #ffffff;
    border: 1px solid var(--color-border-light);
    border-top: 3px solid var(--color-brand);
  }

  .coco-pillar-num {
    font-size: clamp(2rem, 3vw, 3rem);
    font-weight: 700;
    color: var(--color-brand-subtle);
    letter-spacing: var(--tracking-tight);
    line-height: 1;
    margin-bottom: var(--space-lg);
  }

  .coco-pillar-title {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-md);
    letter-spacing: var(--tracking-wide);
  }

  .coco-pillar-body {
    font-size: var(--text-sm);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text-soft);
  }

  /* ── Join ── */
  .coco-join {
    max-width: 760px;
  }

  .coco-join-body {
    font-size: var(--text-base);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text-soft);
    margin-bottom: var(--space-2xl);
  }

  .coco-join-list {
    list-style: none;
    margin: 0 0 var(--space-2xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .coco-join-item {
    display: flex;
    gap: var(--space-md);
    font-size: var(--text-sm);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text-soft);
    align-items: baseline;
  }

  .coco-join-dot {
    flex-shrink: 0;
    display: inline-block;
    width: 6px;
    height: 6px;
    margin-top: 0.5em;
    background: var(--color-brand);
    border-radius: 50%;
  }

  .coco-join-contact {
    font-size: var(--text-sm);
    font-weight: 300;
    color: var(--color-text-muted);
    padding: var(--space-lg);
    background: oklch(95% 0.04 185);
    border: 1px solid oklch(85% 0.06 185);
  }

  /* ── Join visual (rings) — removed ── */
  .coco-join-ring {
    display: none;
    align-items: center;
    justify-content: center;
  }

  .coco-join-ring--outer {
    opacity: 0.3;
    animation: ringPulse 4s ease-in-out infinite;
  }

  .coco-join-ring--mid {
    inset: 30px;
    opacity: 0.5;
    animation: ringPulse 4s ease-in-out 0.6s infinite;
  }

  .coco-join-ring--inner {
    inset: 60px;
    background: oklch(95% 0.04 185);
    border-color: var(--color-brand);
  }

  .coco-join-ring-text {
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-brand-dark);
    letter-spacing: var(--tracking-wider);
  }

  @keyframes ringPulse {
    0%, 100% { transform: scale(1); opacity: 0.3; }
    50% { transform: scale(1.04); opacity: 0.6; }
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .coco-pillars {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .coco-join {
      grid-template-columns: 1fr;
    }

    .coco-join-visual {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .coco-hero-content {
      padding-top: 100px;
      min-height: 60vh;
    }

    .coco-section {
      padding: var(--space-4xl) var(--content-padding);
    }
  }
</style>
