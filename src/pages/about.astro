---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="关于品牌 — 海得宝 MarTempo" description="海得宝MARTEMPO，专研敏感肌肤的护肤品牌。立足专利成分贻贝钙肽CAPCS，科学循证临床加持，为敏感肌提供温和有效的解决方案。">
  <Nav />
  <main>
    <!-- ── Hero ── -->
    <section class="about-hero">
      <div class="about-hero-bg" aria-hidden="true"></div>
      <div class="section-inner">
        <nav class="about-breadcrumb" aria-label="面包屑导航">
          <a href="/">首页</a>
          <span class="sep">›</span>
          <span class="current">关于品牌</span>
        </nav>
        <div class="about-hero-content">
          <div class="about-hero-accent" aria-hidden="true"></div>
          <h1 class="about-hero-title">关于品牌</h1>
          <p class="about-hero-subtitle">敏感肌家庭的专业功效护肤品牌</p>
        </div>
        <div class="about-brand-desc">
          <p class="about-brand-desc-text">
            <span class="brand-desc-marker" aria-hidden="true"></span>
            海得宝MARTEMPO，专研敏感肌肤的护肤品牌
          </p>
          <p class="about-brand-desc-text">
            <span class="brand-desc-marker" aria-hidden="true"></span>
            立足专利成分贻贝钙肽CAPCS，源头舒敏
          </p>
          <p class="about-brand-desc-text">
            <span class="brand-desc-marker" aria-hidden="true"></span>
            科学循证临床加持，受1000+皮肤科专家推荐
          </p>
          <p class="about-brand-desc-text">
            <span class="brand-desc-marker" aria-hidden="true"></span>
            用心呵护敏感，用爱守护家庭
          </p>
          <p class="about-brand-desc-text">
            <span class="brand-desc-marker" aria-hidden="true"></span>
            为敏感肌提供温和有效的解决方案
          </p>
        </div>
      </div>
    </section>

    <!-- ── 品牌历程 ── -->
    <section class="about-section about-section--alt reveal reveal-rise">
      <div class="section-inner">
        <div class="about-section-header">
          <h2 class="about-section-title">品牌历程</h2>
          <p class="about-section-subtitle">从实验室到万千家庭，每一步都为了敏感肌</p>
        </div>
        <p class="timeline-h-hint" aria-hidden="true">← 横向滑动浏览 →</p>
        <div class="timeline-h" tabindex="0" role="region" aria-label="品牌历程时间轴，可左右滚动">
          <div class="timeline-h-track">
            <span class="timeline-h-ghost" aria-hidden="true">Historical<br />Process</span>
            <div class="timeline-h-line" aria-hidden="true"></div>
            <ol class="timeline-h-items">
              <li class="tlh-item tlh-item--top">
                <div class="tlh-entry">
                  <div class="tlh-text">
                    <span class="tlh-year">2014</span>
                    <h3 class="tlh-heading">品牌成立</h3>
                    <p class="tlh-body">海得宝母公司贝壳派成立。不甘于"止痒只能靠激素"的科学家，从零开始寻找真正安全、温和且有效的护肤方案。</p>
                  </div>
                </div>
              </li>
              <li class="tlh-item tlh-item--bottom tlh-item--media">
                <div class="tlh-entry">
                  <div class="tlh-text">
                    <span class="tlh-year">2015</span>
                    <h3 class="tlh-heading">技术突破</h3>
                    <p class="tlh-body">创新技术成功萃取出天然贻贝提取物，开启从纯净海洋中寻找敏感肌解决方案的探索之路。</p>
                  </div>
                  <div class="tlh-media">
                    <img src="/assets/scene-flatlay.jpg" alt="" loading="lazy" />
                  </div>
                </div>
              </li>
              <li class="tlh-item tlh-item--top">
                <div class="tlh-entry">
                  <div class="tlh-text">
                    <span class="tlh-year">2016</span>
                    <h3 class="tlh-heading">专利保护</h3>
                    <p class="tlh-body">海得宝核心专利成分贻贝钙肽CAPCS（凯普斯泰）完成产业化生产，为后续产品开发奠定坚实基础。</p>
                  </div>
                </div>
              </li>
              <li class="tlh-item tlh-item--bottom tlh-item--media">
                <div class="tlh-entry">
                  <div class="tlh-text">
                    <span class="tlh-year">2017</span>
                    <h3 class="tlh-heading">品牌诞生</h3>
                    <p class="tlh-body">MARTEMPO海得宝品牌正式成立，敏感肌专业护肤产品上市，首次将"钙离子止痒"从实验室推向市场。</p>
                  </div>
                  <div class="tlh-media">
                    <img src="/assets/scene-flatlay.jpg" alt="" loading="lazy" />
                  </div>
                </div>
              </li>
              <li class="tlh-item tlh-item--top">
                <div class="tlh-entry">
                  <div class="tlh-text">
                    <span class="tlh-year">2018</span>
                    <h3 class="tlh-heading">院线验证</h3>
                    <p class="tlh-body">海得宝无激素止痒凝胶正式进入全国公立医院皮肤科，获得临床医生的初步认可。止痒效果堪比弱效激素，却完全不含激素，悄然改变临床用药习惯。</p>
                  </div>
                </div>
              </li>
              <li class="tlh-item tlh-item--bottom">
                <div class="tlh-entry">
                  <div class="tlh-text">
                    <span class="tlh-year">2019</span>
                    <h3 class="tlh-heading">临床奠基</h3>
                    <p class="tlh-body">贻贝钙肽CAPCS止痒舒缓技术经中山大学附属第五医院、北京友谊医院、四川大学华西医院、中日友好医院四大顶级临床中心严格验证，成果发表于《中华皮肤科杂志》。</p>
                  </div>
                </div>
              </li>
              <li class="tlh-item tlh-item--top tlh-item--media">
                <div class="tlh-entry">
                  <div class="tlh-text">
                    <span class="tlh-year">2020</span>
                    <h3 class="tlh-heading">智造升级</h3>
                    <p class="tlh-body">在安徽合肥建成6000㎡、十万级GMP药厂级生产基地——中国中部超敏肌护理智造中心，实现从研发到生产的高标准自主可控。</p>
                  </div>
                  <div class="tlh-media">
                    <img src="/assets/scene-flatlay.jpg" alt="" loading="lazy" />
                  </div>
                </div>
              </li>
              <li class="tlh-item tlh-item--bottom">
                <div class="tlh-entry">
                  <div class="tlh-text">
                    <span class="tlh-year">2021</span>
                    <h3 class="tlh-heading">走进用户</h3>
                    <p class="tlh-body">海得宝正式入驻小红书，从院线走向大众。大量宝妈、敏感肌自发分享"30秒止痒"的真实体验，口碑裂变自此爆发。</p>
                  </div>
                </div>
              </li>
              <li class="tlh-item tlh-item--top tlh-item--media">
                <div class="tlh-entry">
                  <div class="tlh-text">
                    <span class="tlh-year">2022</span>
                    <h3 class="tlh-heading">学术认可</h3>
                    <p class="tlh-body">贻贝钙肽CAPCS临床研究论文再次登上《中华皮肤科杂志》，学术圈的反复认证让"钙离子舒缓"从一种选择，变为一个标准。</p>
                  </div>
                  <div class="tlh-media">
                    <img src="/assets/scene-flatlay.jpg" alt="" loading="lazy" />
                  </div>
                </div>
              </li>
              <li class="tlh-item tlh-item--bottom">
                <div class="tlh-entry">
                  <div class="tlh-text">
                    <span class="tlh-year">2023</span>
                    <h3 class="tlh-heading">安全新标杆</h3>
                    <p class="tlh-body">产品矩阵扩充至20+款，建立行业首个"科研级五维安全性评价标准"（经口无毒、入眼无刺激、人体斑贴、多次皮肤刺激、4000+争议成分不添加），重新定义敏感肌护理安全高度。</p>
                  </div>
                </div>
              </li>
              <li class="tlh-item tlh-item--top tlh-item--media">
                <div class="tlh-entry">
                  <div class="tlh-text">
                    <span class="tlh-year">2024</span>
                    <h3 class="tlh-heading">品牌焕新</h3>
                    <p class="tlh-body">受邀参加SIA科学护肤创新联盟大会，完成品牌升级，以全新形象和专业理念开启新篇章。海得宝从此成为全家的敏感肌专业护理生活方式。</p>
                  </div>
                  <div class="tlh-media">
                    <img src="/assets/scene-flatlay.jpg" alt="" loading="lazy" />
                  </div>
                </div>
              </li>
              <li class="tlh-item tlh-item--bottom">
                <div class="tlh-entry">
                  <div class="tlh-text">
                    <span class="tlh-year">2025</span>
                    <h3 class="tlh-heading">星推赋能</h3>
                    <p class="tlh-body">官宣董洁为品牌代言人。这位被公认为"真诚、有质感"的女演员，与海得宝"把每个家庭视若珍宝"的品牌理念完美契合，走进更多用户视野。</p>
                  </div>
                </div>
              </li>
              <li class="tlh-item tlh-item--top tlh-item--media">
                <div class="tlh-entry">
                  <div class="tlh-text">
                    <span class="tlh-year">2026</span>
                    <h3 class="tlh-heading">国社背书</h3>
                    <p class="tlh-body">荣获新华社"健康中国践行品牌"及"敏感肌成分领创者"双重认可，标志着品牌在健康中国的宏大叙事中，成为行业标杆。</p>
                  </div>
                  <div class="tlh-media">
                    <img src="/assets/scene-flatlay.jpg" alt="" loading="lazy" />
                  </div>
                </div>
              </li>
            </ol>
          </div>
        </div>
      </div>
    </section>

    <!-- ── 研发力 ── -->
    <section class="about-section reveal reveal-rise">
      <div class="section-inner">
        <div class="about-rd">
          <div class="about-rd-text">
            <h2 class="about-section-title">研发力</h2>
            <p class="about-rd-body">海得宝MARTEMPO拥有专业研发团队与工厂，每一项产品都是严格执行由NMPA（国家药品监督管理局）制定的生产标准来生产的，工厂均拥有ISO9001，ISO9002和GMP认证，经过QC严格质检后才能投放市场。</p>
            <p class="about-rd-body">海得宝MARTEMPO同时也拥有超国标的产品认证标准。除了达到国家对儿童护肤品的基础要求之外，还增加了经口无毒、入眼无刺激、人体斑贴试验无刺激、4000+争议成分不添加这4项高于国家标准检测，来做到海得宝特色的科研级五维安心金标准，为消费者提供更大的信心和满意度。</p>
          </div>
          <div class="about-rd-image">
            <img src="/assets/lab.jpg" alt="海得宝实验室" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <!-- ── 奖项荣誉 ── -->
    <section class="about-section about-section--alt reveal reveal-rise">
      <div class="section-inner">
        <div class="about-section-header">
          <h2 class="about-section-title">奖项荣誉</h2>
          <p class="about-section-subtitle">行业认可，见证实力</p>
        </div>

        <!-- Trophy awards -->
        <div class="awards-wrap">
          <div class="award-card">
            <div class="award-trophy-img">
              <img src="/assets/awards/trophy-tiptop.png" alt="2025年度新势力品牌" loading="lazy" />
            </div>
            <div class="award-label">
              <h3 class="award-title">2025年度新势力品牌</h3>
              <div class="award-logo">
                <img src="/assets/awards/logo-tiptop.png" alt="TIPTOP全球美妆大赏" loading="lazy" />
              </div>
            </div>
          </div>
          <div class="award-card">
            <div class="award-trophy-img">
              <img src="/assets/awards/trophy-beyond.png" alt="亚洲生物科技融合创新奖" loading="lazy" />
            </div>
            <div class="award-label">
              <h3 class="award-title">亚洲生物科技融合创新奖</h3>
              <div class="award-logo">
                <img src="/assets/awards/logo-beyond.png" alt="BEYOND EXPO" loading="lazy" />
              </div>
            </div>
          </div>
          <div class="award-card">
            <div class="award-trophy-img">
              <img src="/assets/awards/trophy-sia100-lip.png" alt="科学功效护肤品奖" loading="lazy" />
            </div>
            <div class="award-label">
              <h3 class="award-title">科学功效护肤品奖 · 唇敏修护唇膏</h3>
              <div class="award-logo">
                <img src="/assets/awards/logo-sia100.png" alt="SIA100" loading="lazy" />
              </div>
            </div>
          </div>
          <div class="award-card">
            <div class="award-trophy-img">
              <img src="/assets/awards/trophy-sia100-cream.png" alt="科学功效护肤品奖" loading="lazy" />
            </div>
            <div class="award-label">
              <h3 class="award-title">科学功效护肤品奖 · 大白管特护霜</h3>
              <div class="award-logo">
                <img src="/assets/awards/logo-sia100.png" alt="SIA100" loading="lazy" />
              </div>
            </div>
          </div>
          <div class="award-card">
            <div class="award-trophy-img">
              <img src="/assets/awards/trophy-meizhuang.png" alt="舒缓修红科学配方奖" loading="lazy" />
            </div>
            <div class="award-label">
              <h3 class="award-title">舒缓修红科学配方奖</h3>
              <div class="award-logo award-logo--sm">
                <img src="/assets/awards/logo-meizhuang.png" alt="美妆头条" loading="lazy" />
              </div>
            </div>
          </div>
        </div>

        <!-- Certificate awards -->
        <div class="awards-wrap">
          <div class="award-card">
            <div class="award-cert-img">
              <img src="/assets/awards/medal-leader.png" alt="敏感肌钙肽修护技术行业领创者" loading="lazy" />
            </div>
            <div class="award-label">
              <h3 class="award-title">敏感肌钙肽修护技术行业领创者</h3>
            </div>
          </div>
          <div class="award-card">
            <div class="award-cert-img">
              <img src="/assets/awards/medal-cream-sales.png" alt="贻贝钙肽舒缓特护霜全国销量第一" loading="lazy" />
            </div>
            <div class="award-label">
              <h3 class="award-title">贻贝钙肽舒缓特护霜全国销量第一</h3>
            </div>
          </div>
          <div class="award-card">
            <div class="award-cert-img">
              <img src="/assets/awards/medal-lip-sales.png" alt="贻贝钙肽修护唇膏全国销量第一" loading="lazy" />
            </div>
            <div class="award-label">
              <h3 class="award-title">贻贝钙肽修护唇膏全国销量第一</h3>
            </div>
          </div>
          <div class="award-card">
            <div class="award-cert-img">
              <img src="/assets/awards/medal-dermatology-journal.png" alt="中华皮肤科杂志" loading="lazy" />
            </div>
            <div class="award-label">
              <h3 class="award-title">《中华皮肤科杂志》</h3>
            </div>
          </div>
          <div class="award-card">
            <div class="award-cert-img">
              <img src="/assets/awards/medal-xinhua.png" alt="新华社权威见证" loading="lazy" />
            </div>
            <div class="award-label">
              <h3 class="award-title">新华社权威见证</h3>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    import '../scripts/reveal.js';
  </script>
</BaseLayout>

<style>
  /* ── Hero ── */
  .about-hero {
    padding: 140px var(--content-padding) var(--space-5xl);
    position: relative;
    overflow: hidden;
  }

  .about-hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, oklch(96% 0.015 185) 0%, oklch(98% 0.008 185) 50%, #ffffff 100%);
    z-index: 0;
  }

  .about-hero > .section-inner {
    position: relative;
    z-index: 1;
  }

  .about-breadcrumb {
    font-size: var(--text-xs);
    margin-bottom: var(--space-3xl);
  }

  .about-breadcrumb a {
    color: oklch(50% 0.01 260 / 0.6);
    text-decoration: none;
    transition: color var(--duration-fast) ease;
  }

  .about-breadcrumb a:hover {
    color: var(--color-brand);
  }

  .about-breadcrumb .sep {
    margin: 0 6px;
    color: oklch(50% 0.01 260 / 0.5);
  }

  .about-breadcrumb .current {
    color: oklch(35% 0.015 260 / 0.7);
    font-weight: 500;
  }

  .about-hero-accent {
    width: 40px;
    height: 2px;
    background: var(--color-brand);
    margin-bottom: var(--space-xl);
  }

  .about-hero-title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 200;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    margin-bottom: var(--space-lg);
  }

  .about-hero-subtitle {
    font-size: var(--text-lg);
    font-weight: 300;
    color: var(--color-text-soft);
    max-width: 40ch;
    margin-bottom: var(--space-3xl);
  }

  .about-brand-desc {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    max-width: 520px;
  }

  .about-brand-desc-text {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    font-size: var(--text-base);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text);
  }

  .brand-desc-marker {
    flex-shrink: 0;
    display: inline-block;
    width: 6px;
    height: 6px;
    margin-top: calc(1em * var(--leading-relaxed) / 2 - 3px);
    background: var(--color-brand);
    border-radius: 1px;
  }

  /* ── Shared section ── */
  .about-section {
    padding: var(--space-6xl) var(--content-padding);
    background: #ffffff;
  }

  .about-section--alt {
    background: var(--color-bg-light);
  }

  .about-section-header {
    margin-bottom: var(--space-4xl);
  }

  .about-section-title {
    font-size: var(--text-3xl);
    font-weight: 200;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .about-section-subtitle {
    font-size: var(--text-base);
    font-weight: 300;
    color: var(--color-text-soft);
    max-width: 40ch;
  }

  /* ── Timeline（横向交错式）── */
  .timeline-h-hint {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wider);
    text-align: right;
    margin-bottom: var(--space-md);
  }

  .timeline-h {
    --tlh-h: 560px;
    --tlh-gap: 28px; /* 内容块与主线之间的竖向连接线长度 */
    overflow-x: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--color-brand-soft) transparent;
  }

  .timeline-h::-webkit-scrollbar {
    height: 6px;
  }

  .timeline-h::-webkit-scrollbar-thumb {
    background: var(--color-brand-subtle);
    border-radius: 3px;
  }

  .timeline-h::-webkit-scrollbar-track {
    background: transparent;
  }

  .timeline-h-track {
    position: relative;
    width: max-content;
    min-width: 100%;
    padding-right: var(--space-3xl);
  }

  .timeline-h-line {
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 2px;
    background: var(--color-brand);
  }

  .timeline-h-ghost {
    position: absolute;
    left: var(--space-md);
    top: 53%;
    font-size: clamp(2.5rem, 2rem + 2vw, 4rem);
    font-weight: 700;
    font-style: italic;
    line-height: 1.05;
    letter-spacing: var(--tracking-tight);
    color: var(--color-brand-subtle);
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
  }

  .timeline-h-items {
    list-style: none;
    margin: 0;
