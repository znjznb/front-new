---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="关于品牌 — 海得宝 MarTempo" description="海得宝MARTEMPO，专研敏感肌肤的护肤品牌。立足专利成分贻贝钙肽CAPCS，科学循证临床加持，为敏感肌提供温和有效的解决方案。">
  <Nav />
  <main>
    <!-- ── Hero ── -->
    <section class="about-hero">
      <div class="about-hero-bg" aria-hidden="true"></div>
      <div class="section-inner">
        <nav class="about-breadcrumb" aria-label="面包屑导航">
          <a href="/">首页</a>
          <span class="sep">›</span>
          <span class="current">关于品牌</span>
        </nav>
        <div class="about-hero-content">
          <div class="about-hero-accent" aria-hidden="true"></div>
          <h1 class="about-hero-title">关于品牌</h1>
          <p class="about-hero-subtitle">敏感肌家庭的专业功效护肤品牌</p>
        </div>
        <div class="about-brand-desc">
          <p class="about-brand-desc-text">
            <span class="brand-desc-marker" aria-hidden="true"></span>
            海得宝MARTEMPO，专研敏感肌肤的护肤品牌
          </p>
          <p class="about-brand-desc-text">
            <span class="brand-desc-marker" aria-hidden="true"></span>
            立足专利成分贻贝钙肽CAPCS，源头舒敏
          </p>
          <p class="about-brand-desc-text">
            <span class="brand-desc-marker" aria-hidden="true"></span>
            科学循证临床加持，受1000+皮肤科专家推荐
          </p>
          <p class="about-brand-desc-text">
            <span class="brand-desc-marker" aria-hidden="true"></span>
            用心呵护敏感，用爱守护家庭
          </p>
          <p class="about-brand-desc-text">
            <span class="brand-desc-marker" aria-hidden="true"></span>
            为敏感肌提供温和有效的解决方案
          </p>
        </div>
      </div>
    </section>

    <!-- ── 品牌历程 ── -->
    <section class="about-section about-section--alt reveal reveal-rise">
      <div class="section-inner">
        <div class="about-section-header">
          <h2 class="about-section-title">品牌历程</h2>
          <p class="about-section-subtitle">从实验室到万千家庭，每一步都为了敏感肌</p>
        </div>
        <div class="timeline">
          <div class="timeline-line" aria-hidden="true"></div>
          <div class="timeline-items">
            <div class="timeline-item">
              <span class="timeline-year">2014</span>
              <div class="timeline-dot" aria-hidden="true"></div>
              <div class="timeline-content">
                <h3 class="timeline-heading">品牌创立</h3>
                <p class="timeline-body">海得宝品牌正式成立，开启敏感肌护理的科研之路</p>
              </div>
            </div>
            <div class="timeline-item">
              <span class="timeline-year">2015</span>
              <div class="timeline-dot" aria-hidden="true"></div>
              <div class="timeline-content">
                <h3 class="timeline-heading">专利突破</h3>
                <p class="timeline-body">贻贝钙肽CAPCS专利成分研发成功，从深海贻贝中提取天然舒敏活性物</p>
              </div>
            </div>
            <div class="timeline-item">
              <span class="timeline-year">2016</span>
              <div class="timeline-dot" aria-hidden="true"></div>
              <div class="timeline-content">
                <h3 class="timeline-heading">临床验证</h3>
                <p class="timeline-body">产品进入多家三甲医院皮肤科临床测试，验证安全性与有效性</p>
              </div>
            </div>
            <div class="timeline-item">
              <span class="timeline-year">2017</span>
              <div class="timeline-dot" aria-hidden="true"></div>
              <div class="timeline-content">
                <h3 class="timeline-heading">口碑积累</h3>
                <p class="timeline-body">获得首批皮肤科专家推荐，在专业医疗渠道建立口碑</p>
              </div>
            </div>
            <div class="timeline-item">
              <span class="timeline-year">2018</span>
              <div class="timeline-dot" aria-hidden="true"></div>
              <div class="timeline-content">
                <h3 class="timeline-heading">产品扩容</h3>
                <p class="timeline-body">拓展产品线，覆盖面部护理、身体护理、婴童护理等多场景</p>
              </div>
            </div>
            <div class="timeline-item">
              <span class="timeline-year">2019</span>
              <div class="timeline-dot" aria-hidden="true"></div>
              <div class="timeline-content">
                <h3 class="timeline-heading">线上启航</h3>
                <p class="timeline-body">开启线上电商渠道，让更多家庭便捷获得专业敏感肌护理产品</p>
              </div>
            </div>
            <div class="timeline-item">
              <span class="timeline-year">2020</span>
              <div class="timeline-dot" aria-hidden="true"></div>
              <div class="timeline-content">
                <h3 class="timeline-heading">科研升级</h3>
                <p class="timeline-body">加大研发投入，建立自有实验室，深化CAPCS成分研究</p>
              </div>
            </div>
            <div class="timeline-item">
              <span class="timeline-year">2021</span>
              <div class="timeline-dot" aria-hidden="true"></div>
              <div class="timeline-content">
                <h3 class="timeline-heading">品牌焕新</h3>
                <p class="timeline-body">品牌形象升级，以"敏感肌家庭的专业护理品牌"全新定位面向消费者</p>
              </div>
            </div>
            <div class="timeline-item">
              <span class="timeline-year">2022</span>
              <div class="timeline-dot" aria-hidden="true"></div>
              <div class="timeline-content">
                <h3 class="timeline-heading">行业认可</h3>
                <p class="timeline-body">荣获多项行业大奖，敏感肌钙肽修护技术获得专业领域权威认可</p>
              </div>
            </div>
            <div class="timeline-item">
              <span class="timeline-year">2023</span>
              <div class="timeline-dot" aria-hidden="true"></div>
              <div class="timeline-content">
                <h3 class="timeline-heading">渠道深耕</h3>
                <p class="timeline-body">进入全国2000+药房及母婴渠道，成为更多家庭信赖的选择</p>
              </div>
            </div>
            <div class="timeline-item">
              <span class="timeline-year">2024</span>
              <div class="timeline-dot" aria-hidden="true"></div>
              <div class="timeline-content">
                <h3 class="timeline-heading">全面领先</h3>
                <p class="timeline-body">获得1000+皮肤科专家推荐，销量持续领先，树立行业标杆</p>
              </div>
            </div>
            <div class="timeline-item">
              <span class="timeline-year">2025</span>
              <div class="timeline-dot" aria-hidden="true"></div>
              <div class="timeline-content">
                <h3 class="timeline-heading">海外布局</h3>
                <p class="timeline-body">启动海外市场拓展，将中国敏感肌护理方案带给全球消费者</p>
              </div>
            </div>
            <div class="timeline-item">
              <span class="timeline-year">2026</span>
              <div class="timeline-dot" aria-hidden="true"></div>
              <div class="timeline-content">
                <h3 class="timeline-heading">未来可期</h3>
                <p class="timeline-body">持续创新，以科学力量守护每一个敏感肌家庭</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── 研发力 ── -->
    <section class="about-section reveal reveal-rise">
      <div class="section-inner">
        <div class="about-rd">
          <div class="about-rd-text">
            <h2 class="about-section-title">研发力</h2>
            <p class="about-rd-body">海得宝MARTEMPO拥有专业研发团队与工厂，每一项产品都是严格执行由NMPA（国家药品监督管理局）制定的生产标准来生产的，工厂均拥有ISO9001，ISO9002和GMP认证，经过QC严格质检后才能投放市场。</p>
            <p class="about-rd-body">海得宝MARTEMPO同时也拥有超国标的产品认证标准。除了达到国家对儿童护肤品的基础要求之外，还增加了经口无毒、入眼无刺激、人体斑贴试验无刺激、4000+争议成分不添加这4项高于国家标准检测，来做到海得宝特色的科研级五维安心金标准，为消费者提供更大的信心和满意度。</p>
          </div>
          <div class="about-rd-image">
            <img src="/assets/skincare/1581182800629.jpg" alt="海得宝实验室" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <!-- ── 奖项荣誉 ── -->
    <section class="about-section about-section--alt reveal reveal-rise">
      <div class="section-inner">
        <div class="about-section-header">
          <h2 class="about-section-title">奖项荣誉</h2>
          <p class="about-section-subtitle">行业认可，见证实力</p>
        </div>

        <!-- Trophy awards -->
        <div class="awards-wrap">
          <div class="award-card">
            <div class="award-trophy-img">
              <img src="/assets/awards/trophy-tiptop.png" alt="2025年度新势力品牌" loading="lazy" />
            </div>
            <div class="award-label">
              <h3 class="award-title">2025年度新势力品牌</h3>
              <div class="award-logo">
                <img src="/assets/awards/logo-tiptop.png" alt="TIPTOP全球美妆大赏" loading="lazy" />
              </div>
            </div>
          </div>
          <div class="award-card">
            <div class="award-trophy-img">
              <img src="/assets/awards/trophy-beyond.png" alt="亚洲生物科技融合创新奖" loading="lazy" />
            </div>
            <div class="award-label">
              <h3 class="award-title">亚洲生物科技融合创新奖</h3>
              <div class="award-logo">
                <img src="/assets/awards/logo-beyond.png" alt="BEYOND EXPO" loading="lazy" />
              </div>
            </div>
          </div>
          <div class="award-card">
            <div class="award-trophy-img">
              <img src="/assets/awards/trophy-sia100-lip.png" alt="科学功效护肤品奖" loading="lazy" />
            </div>
            <div class="award-label">
              <h3 class="award-title">科学功效护肤品奖 · 唇敏修护唇膏</h3>
              <div class="award-logo">
                <img src="/assets/awards/logo-sia100.png" alt="SIA100" loading="lazy" />
              </div>
            </div>
          </div>
          <div class="award-card">
            <div class="award-trophy-img">
              <img src="/assets/awards/trophy-sia100-cream.png" alt="科学功效护肤品奖" loading="lazy" />
            </div>
            <div class="award-label">
              <h3 class="award-title">科学功效护肤品奖 · 大白管特护霜</h3>
              <div class="award-logo">
                <img src="/assets/awards/logo-sia100.png" alt="SIA100" loading="lazy" />
              </div>
            </div>
          </div>
          <div class="award-card">
            <div class="award-trophy-img">
              <img src="/assets/awards/trophy-meizhuang.png" alt="舒缓修红科学配方奖" loading="lazy" />
            </div>
            <div class="award-label">
              <h3 class="award-title">舒缓修红科学配方奖</h3>
              <div class="award-logo award-logo--sm">
                <img src="/assets/awards/logo-meizhuang.png" alt="美妆头条" loading="lazy" />
              </div>
            </div>
          </div>
        </div>

        <!-- Certificate awards -->
        <div class="awards-wrap">
          <div class="award-card">
            <div class="award-cert-img">
              <img src="/assets/awards/medal-leader.png" alt="敏感肌钙肽修护技术行业领创者" loading="lazy" />
            </div>
            <div class="award-label">
              <h3 class="award-title">敏感肌钙肽修护技术行业领创者</h3>
            </div>
          </div>
          <div class="award-card">
            <div class="award-cert-img">
              <img src="/assets/awards/medal-cream-sales.png" alt="贻贝钙肽舒缓特护霜全国销量第一" loading="lazy" />
            </div>
            <div class="award-label">
              <h3 class="award-title">贻贝钙肽舒缓特护霜全国销量第一</h3>
            </div>
          </div>
          <div class="award-card">
            <div class="award-cert-img">
              <img src="/assets/awards/medal-lip-sales.png" alt="贻贝钙肽修护唇膏全国销量第一" loading="lazy" />
            </div>
            <div class="award-label">
              <h3 class="award-title">贻贝钙肽修护唇膏全国销量第一</h3>
            </div>
          </div>
          <div class="award-card">
            <div class="award-cert-img">
              <img src="/assets/awards/medal-dermatology-journal.png" alt="中华皮肤科杂志" loading="lazy" />
            </div>
            <div class="award-label">
              <h3 class="award-title">《中华皮肤科杂志》</h3>
            </div>
          </div>
          <div class="award-card">
            <div class="award-cert-img">
              <img src="/assets/awards/medal-xinhua.png" alt="新华社权威见证" loading="lazy" />
            </div>
            <div class="award-label">
              <h3 class="award-title">新华社权威见证</h3>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    import '../scripts/reveal.js';
  </script>
</BaseLayout>

<style>
  /* ── Hero ── */
  .about-hero {
    padding: 140px var(--content-padding) var(--space-5xl);
    position: relative;
    overflow: hidden;
  }

  .about-hero-bg {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, oklch(96% 0.015 185) 0%, oklch(98% 0.008 185) 50%, #ffffff 100%);
    z-index: 0;
  }

  .about-hero > .section-inner {
    position: relative;
    z-index: 1;
  }

  .about-breadcrumb {
    font-size: var(--text-xs);
    margin-bottom: var(--space-3xl);
  }

  .about-breadcrumb a {
    color: oklch(50% 0.01 260 / 0.6);
    text-decoration: none;
    transition: color var(--duration-fast) ease;
  }

  .about-breadcrumb a:hover {
    color: var(--color-brand);
  }

  .about-breadcrumb .sep {
    margin: 0 6px;
    color: oklch(50% 0.01 260 / 0.5);
  }

  .about-breadcrumb .current {
    color: oklch(35% 0.015 260 / 0.7);
    font-weight: 500;
  }

  .about-hero-accent {
    width: 40px;
    height: 2px;
    background: var(--color-brand);
    margin-bottom: var(--space-xl);
  }

  .about-hero-title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 200;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    margin-bottom: var(--space-lg);
  }

  .about-hero-subtitle {
    font-size: var(--text-lg);
    font-weight: 300;
    color: var(--color-text-soft);
    max-width: 40ch;
    margin-bottom: var(--space-3xl);
  }

  .about-brand-desc {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    max-width: 520px;
  }

  .about-brand-desc-text {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    font-size: var(--text-base);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text);
  }

  .brand-desc-marker {
    flex-shrink: 0;
    display: inline-block;
    width: 6px;
    height: 6px;
    margin-top: calc(1em * var(--leading-relaxed) / 2 - 3px);
    background: var(--color-brand);
    border-radius: 1px;
  }

  /* ── Shared section ── */
  .about-section {
    padding: var(--space-6xl) var(--content-padding);
    background: #ffffff;
  }

  .about-section--alt {
    background: var(--color-bg-light);
  }

  .about-section-header {
    margin-bottom: var(--space-4xl);
  }

  .about-section-title {
    font-size: var(--text-3xl);
    font-weight: 200;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    margin-bottom: var(--space-md);
  }

  .about-section-subtitle {
    font-size: var(--text-base);
    font-weight: 300;
    color: var(--color-text-soft);
    max-width: 40ch;
  }

  /* ── Timeline ── */
  .timeline {
    position: relative;
  }

  .timeline-line {
    position: absolute;
    left: 120px;
    top: 0;
    bottom: 0;
    width: 1px;
    background: oklch(82% 0.04 185);
  }

  .timeline-items {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 104px 32px 1fr;
    align-items: flex-start;
    gap: 0;
  }

  .timeline-year {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-brand);
    letter-spacing: var(--tracking-wider);
    text-align: right;
    padding-right: var(--space-lg);
    padding-top: 2px;
    white-space: nowrap;
  }

  .timeline-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-brand);
    border: 2px solid #ffffff;
    box-shadow: 0 0 0 1px var(--color-brand-subtle);
    position: relative;
    z-index: 1;
    margin-top: 4px;
  }

  .timeline-content {
    padding-left: var(--space-xl);
    padding-bottom: var(--space-lg);
  }

  .timeline-item:last-child .timeline-content {
    padding-bottom: 0;
  }

  .timeline-heading {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-text);
    margin-bottom: var(--space-xs);
    letter-spacing: var(--tracking-wide);
  }

  .timeline-body {
    font-size: var(--text-sm);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text-soft);
    max-width: 360px;
  }

  /* ── R&D ── */
  .about-rd {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: start;
  }

  .about-rd-body {
    font-size: var(--text-sm);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text-soft);
    margin-bottom: var(--space-lg);
  }

  .about-rd-body:last-child {
    margin-bottom: 0;
  }

  .about-rd-image img {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    aspect-ratio: 4/3;
    object-fit: cover;
  }

  /* ── Awards ── */
  /* 每个奖项是「图片 + 灰底文案」自包含单元；列间距为 0，
     灰底画在 .award-label 上，同一行内自然连成一条无缝背景条 */
  .awards-wrap {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    row-gap: var(--space-3xl);
    margin-bottom: var(--space-4xl);
  }

  .awards-wrap:last-child {
    margin-bottom: 0;
  }

  .award-card {
    display: flex;
    flex-direction: column;
    text-align: center;
  }

  .award-title {
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-text);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-wide);
  }

  .award-label .award-title:not(:last-child) {
    margin-bottom: var(--space-lg);
  }

  .award-source {
    font-size: 0.72rem;
    font-weight: 400;
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
  }

  /* ── Grey label band ── */
  .award-label {
    flex: 1;
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--space-lg) var(--space-sm);
    background: oklch(93% 0.01 260 / 0.55);
  }

  /* 桌面端整行时，灰条向内容区两侧各延伸 48px（与原 awards-bar 一致） */
  @media (min-width: 1025px) {
    .award-card:first-child .award-label::before,
    .award-card:last-child .award-label::after {
      content: '';
      position: absolute;
      top: 0;
      bottom: 0;
      width: 48px;
      background: oklch(93% 0.01 260 / 0.55);
    }

    .award-card:first-child .award-label::before {
      right: 100%;
      border-radius: var(--radius-sm) 0 0 var(--radius-sm);
    }

    .award-card:last-child .award-label::after {
      left: 100%;
      border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    }
  }

  /* ── Award images ── */
