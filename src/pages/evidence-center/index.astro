  { icon: 'shell', t: '修屏障', plain: '让皮肤恢复"防水墙"功能', mech: '表皮钙离子梯度调节角质形成细胞分化' },
  { icon: 'verified', t: '抗炎', plain: '让发红、肿胀消下去', mech: '抑制 Th1/Th2/Th17/Th22 多通路炎症因子' },
  { icon: 'microscope', t: '抑菌', plain: '不让坏菌（金葡菌、马拉色菌）繁殖', mech: 'AMP 开"通道"+ 钙离子涌入"致死"' },
  { icon: 'molecule', t: '止痒', plain: '让神经不再"乱叫"', mech: '钙离子调节 G 蛋白偶联受体 + AMP 诱导信号素 3A' },
];
const capcsNone = ['激素', '抗生素', '防腐剂', '香精', '色素'];

// 决策场景（模块 7）— 逐字，来自项目文档
const scenarios = [
  {
    title: '场景 1：我家宝宝（2 岁以上）有湿疹/特应性皮炎',
    refs: '四川大学华西医院儿童 AD 研究（2021）+ 北京中医医院延庆医院儿童急性期 AD 研究（2024）',
    answer: '可以。两项针对 2–12 岁儿童的临床研究都证实了 CAPCS 系列在儿童中的安全性和有效性。',
    rows: [
      { label: '建议剂型', list: ['平时管理 → 凯普斯泰水凝胶/速修精华液', '急性渗出期 → 凯普斯泰速修全域贴 + 配合医生开的弱效/中效激素'] },
    ],
    notice: '2 岁以下婴幼儿、对钙制剂过敏者请先咨询儿科或皮肤科医生。',
    studies: ['pediatric-ad', 'pediatric-acute'],
  },
  {
    title: '场景 2：我是成人，有轻度特应性皮炎/湿疹',
    refs: '北京友谊医院成人 AD 研究（2022）+ 上海多中心 HBL 研究（2026）',
    answer: '可以。两项针对成人的研究证实了显著疗效。',
    rows: [
      { label: '建议剂型', list: ['局部皮损治疗 → 凯普斯泰冷敷凝胶', '大面积日常管理 → 海得宝身体乳（大白管特护霜）'] },
      { label: '核心数据', text: '4 周后约 65%–82% 患者达到 EASI50 改善。' },
    ],
    studies: ['adult-ad', 'multicenter-rct'],
  },
  {
    title: '场景 3：我头皮油、头皮痒、头皮屑多',
    refs: '中日友好医院头皮脂溢性皮炎研究（2021）',
    answer: '可以。研究证实凯普斯泰对引起头皮脂溢性皮炎的糠秕马拉色菌有抑制作用。',
    rows: [
      { label: '核心数据', text: '4 周后 85.18% 患者有效，真菌镜检阴转率 66.67%。' },
      { label: '建议', text: '直接涂抹于头皮患处，每日 3 次。' },
    ],
    studies: ['scalp-seborrheic'],
  },
  {
    title: '场景 4：我有湿疹，但担心长期用激素的副作用',
    refs: '北京友谊医院头对头研究（2022）',
    answer: '海得宝是经过临床验证的非激素方案。在成人轻中度 AD 患者中，单药使用 4 周后疗效优于弱效激素氢化可的松。',
    rows: [
      { label: '特别适合', list: ['不愿长期用激素的患者', '面部、皮肤褶皱部位使用', '维持期长期管理', '对激素不耐受的人群'] },
    ],
    studies: ['adult-ad'],
  },
  {
    title: '场景 5：我家孩子 AD 急性大爆发，渗出、糜烂',
    refs: '北京中医医院延庆医院儿童急性期 AD 研究（2024）',
    answer: '建议采用湿包疗法——这是中国《特应性皮炎诊疗指南》推荐的方法。凯普斯泰速修全域贴是首选湿敷材料。',
    rows: [
      { label: '核心数据', text: '9 天有效率 100%。' },
      { label: '使用方式', text: '先湿敷速修全域贴 15–20 分钟，再涂抹医生开的弱效激素（如丁酸氢化可的松）。' },
    ],
    notice: '急性期严重渗出请先咨询皮肤科医生制定方案。',
    studies: ['pediatric-acute'],
  },
  {
    title: '场景 6：我皮肤敏感，但没有诊断 AD',
    answer: '海得宝贻贝钙肽 CAPCS 系列产品配方温和（无激素、无抗生素、无防腐剂、无香精），临床研究中安全性表现优异（多项研究中不良反应率 0%–1%）。',
    rows: [
      { label: '建议', text: '可作为敏感肌日常修护产品使用，首次使用建议先在耳后或手腕内侧做小范围测试 24 小时。' },
    ],
    studies: [],
  },
];

// JSON-LD：聚合 6 项研究 + 主页 FAQ
const articleList = STUDIES.map((s, i) => ({
  '@type': 'ListItem',
  position: i + 1,
  url: `${'https://www.martempo.com.cn'}/evidence-center/${s.slug}`,
  name: s.cardTitle,
}));
const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: EVIDENCE_META.title,
  description: EVIDENCE_META.description,
  url: 'https://www.martempo.com.cn/evidence-center',
  mainEntity: { '@type': 'ItemList', itemListElement: articleList },
};
---

<BaseLayout title={EVIDENCE_META.title} description={EVIDENCE_META.description}>
  <Nav />
  <main class="ev">
    <!-- ── 模块 1：Hero ── -->
    <section class="ev-hero">
      <div class="ev-wrap">
        <span class="ev-eyebrow">海得宝循证证据中心</span>
        <h1 class="ev-hero-title"><span class="ev-hero-soft">当您为反复发作的皮肤问题焦虑时，</span><br /><span class="ev-hero-strong">请先看看医生们怎么说</span></h1>
        <div class="ev-hero-lead">
          <p>在过去 5 年里，<strong>14 家三甲医院</strong>为海得宝的核心成分做了 <strong>6 项临床与机理研究</strong>，<strong>2 项已发表于国际 SCI 期刊</strong>并被全球医学数据库 PubMed 收录。</p>
          <p>我们把这些研究整理在这里，不是为了说"我们最好"，而是为了让您在做决定之前，能看到真实的、可验证的、可以追溯到原始论文的证据。</p>
        </div>
        <div class="ev-badges">
          {EVIDENCE_META.badges.map((b) => (
            <div class="ev-badge">
              <EvIcon name={b.icon} size={22} class="ev-badge-icon" />
              <span class="ev-badge-value">{b.value}</span>
              <span class="ev-badge-label">{b.label}</span>
            </div>
          ))}
        </div>

        <!-- 发表与收录 logo 带 -->
        <div class="ev-publogos">
          <span class="ev-publogos-label">研究发表于国际 SCI 期刊，并被 PubMed / MEDLINE 收录</span>
          <div class="ev-publogos-row">
            <span class="ev-publogo"><img src="/assets/pubmed-logo.png" alt="PubMed" width="960" height="342" /></span>
            <span class="ev-publogo ev-publogo-wm">Wiley</span>
            <span class="ev-publogo ev-publogo-wm small">Journal of Cosmetic Dermatology</span>
            <span class="ev-publogo"><img src="/assets/mdpi-logo.svg" alt="MDPI" width="599" height="395" /></span>
            <span class="ev-publogo"><img class="ev-publogo-ijms" src="/assets/ijms-logo.png" alt="International Journal of Molecular Sciences" width="650" height="140" /></span>
          </div>
        </div>

        <!-- 参与研究的三甲医院 logo 墙 -->
        <div class="ev-hosplogos">
          <span class="ev-hosplogos-label">参与研究的 14 家三级甲等医院</span>
          <div class="ev-hosplogos-grid">
            {hospitalLogos.map((h) => (
              <figure class="ev-hosplogo" title={h.name}>
                <span class="ev-hosplogo-img"><img src={h.src} alt={h.name} width={h.w} height={h.h} loading="lazy" /></span>
                <figcaption>{h.name}</figcaption>
              </figure>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- 分区吸顶导航 -->
    <nav class="ev-subnav" aria-label="循证中心分区导航">
      <div class="ev-wrap ev-subnav-inner">
        <a href="#overview" data-sec="overview">证据全景</a>
        <a href="#flagship" data-sec="flagship">旗舰研究</a>
        <a href="#mechanism" data-sec="mechanism">机理基石</a>
        <a href="#clinical-evidence" data-sec="clinical-evidence">临床证据</a>
        <a href="#ingredient" data-sec="ingredient">核心成分</a>
        <a href="#decision" data-sec="decision">决策辅助</a>
        <a href="#action" data-sec="action">行动号召</a>
      </div>
    </nav>

    <!-- ── 模块 2：证据全景 ── -->
    <section class="ev-section" id="overview">
      <div class="ev-wrap">
        <header class="ev-head reveal reveal-rise">
          <h2 class="ev-h2">6 项研究，回答 3 个核心问题</h2>
          <p class="ev-sub">我们的循证证据体系，不是零散地证明"某一次有效"，而是系统地回答 3 个问题。</p>
        </header>

        <div class="ev-q3 reveal reveal-rise">
          <div class="ev-q3-item">
            <span class="ev-q3-no"><EvIcon name="microscope" size={20} />问题一</span>
            <h3>为什么有效？</h3>
            <p>2022 年发表于国际 SCI 期刊《International Journal of Molecular Sciences》（影响因子 6.208，PubMed 收录）的分子机理研究，国际首次系统阐明了海得宝核心成分贻贝钙肽CAPCS（钙基抗菌多肽复合物）如何在分子层面治疗特应性皮炎（AD/湿疹）——通过调节 Th1/Th2/Th17/Th22 四大免疫通路、抑制 TLR2/TLR4 信号、修复皮肤屏障。</p>
          </div>
          <div class="ev-q3-item">
            <span class="ev-q3-no"><EvIcon name="hospital" size={20} />问题二</span>
            <h3>对真实患者有效吗？</h3>
            <p>5 项临床研究覆盖了从 2 岁儿童到 75 岁老年、从急性渗出期到慢性稳定期、从头皮到全身的各种使用场景，均显示出确切的疗效与良好的安全性。</p>
          </div>
          <div class="ev-q3-item">
            <span class="ev-q3-no"><EvIcon name="globe" size={20} />问题三</span>
            <h3>经得起国际同行评议吗？</h3>
            <p>2 项研究发表于国际 SCI 期刊，被全球医学数据库 PubMed 收录，全球研究者可免费下载全文（CC BY 4.0 开放获取协议）。其中 2026 年发表的全国 10 家三甲医院多中心 RCT 是国内同类品类罕有的高规格研究。</p>
          </div>
        </div>

        <!-- 矩阵：横向 6 列（6 研究）× 纵向 5 行（关键维度），单元格用图标/彩色标记 -->
        <p class="ev-matrix-hint reveal reveal-rise"><EvIcon name="arrow" size={15} />点击下方<strong>列标题</strong>，即可进入该研究的完整报道</p>
        <div class="ev-matrix-wrap reveal reveal-rise">
          <table class="ev-matrix">
            <thead>
              <tr>
                <th class="ev-matrix-corner">{MATRIX.cornerLabel}</th>
                {MATRIX.columns.map((c) => (
                  <th><a href={`/evidence-center/${c.slug}`}>{c.short}<span class="ev-matrix-arrow">↗</span></a></th>
                ))}
              </tr>
            </thead>
            <tbody>
              {MATRIX.rows.map((row) => (
                <tr>
                  <th scope="row">{row.label}</th>
                  {row.cells.map((cell, ci) => (
                    <td>{row.sci && row.sci[ci] && <EvIcon name="globe" size={13} class="ev-matrix-sci" />}{cell}</td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- 中国地图 -->
        <div class="ev-mapblock reveal reveal-rise">
          <h3 class="ev-map-title">14 家三甲医院 · 全国东西南北中覆盖</h3>
          <EvidenceMap />
        </div>
      </div>
    </section>

    <!-- ── 模块 3：旗舰研究 ── -->
    <section class="ev-section ev-flagship-section" id="flagship">
      <div class="ev-wrap">
        <div class="ev-flagship reveal reveal-rise">
          <div class="ev-flag-head">
            <figure class="ev-flag-cover">
              <img src="/assets/flagship-journal-cover.jpg" alt="Journal of Cosmetic Dermatology 期刊封面" width="1794" height="2359" loading="lazy" />
              <figcaption>Journal of Cosmetic Dermatology<br />2026 · 发表期刊封面</figcaption>
            </figure>
            <div class="ev-flag-headtext">
              <span class="ev-flag-tag">旗舰研究</span>
              <h2 class="ev-flag-title">{rct.cardTitle}</h2>
              <p class="ev-flag-meta">{rct.hospital}　|　{rct.journal}（{rct.journalNote}）</p>
            </div>
          </div>

          <div class="ev-statrow">
            {rct.keyStats.map((s) => (
              <div class="ev-stat">
                <span class="ev-stat-v">{s.value}</span>
                <span class="ev-stat-l">{s.label}</span>
                {s.sub && <span class="ev-stat-sub">{s.sub}</span>}
              </div>
            ))}
          </div>

          <!-- 这项研究做了什么 -->
          <div class="ev-flag-sec">
            <h3>{flagIntro.h}</h3>
            {flagIntro.blocks.map((bl) => (
              bl.p ? <p>{bl.p}</p> :
              bl.list ? <ul class="ev-flag-list">{bl.list.map((li) => <li>{li}</li>)}</ul> : null
            ))}
          </div>

          <!-- 研究结果 + 柱状图（进入视口时生长） -->
          <div class="ev-flag-sec">
            <h3>研究结果说明了什么？</h3>
            <div class="ev-chart" data-chart>
              <div class="ev-chart-head">
                <span class="ev-chart-title">{chart.title}</span>
                <div class="ev-chart-legend">
                  <span><i class="lg-a"></i>{chart.legendA}</span>
                  <span><i class="lg-b"></i>{chart.legendB}</span>
                </div>
              </div>
              {chart.groups.map((g) => {
                const max = g.scale || 100;
                return (
                  <div class="ev-bargroup">
                    <span class="ev-bar-label">{g.label}</span>
                    <div class="ev-bars">
                      <div class="ev-bar-track">
                        <div class="ev-bar a" style={`--target:${(g.a / max) * 100}%`}><span class="ev-bar-num">{g.a}{g.suffix}</span></div>
                      </div>
                      <div class="ev-bar-track">
                        <div class="ev-bar b" style={`--target:${(g.b / max) * 100}%`}><span class="ev-bar-num">{g.b}{g.suffix}</span></div>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>

          <!-- 4 项指标 -->
          {flagFindings.map((sec) => (
            <div class="ev-flag-sec">
              <h3>{sec.h}</h3>
              {sec.blocks.map((bl) => (
                bl.p ? <p>{bl.p}</p> :
                bl.list ? <ul class="ev-flag-list">{bl.list.map((li) => <li>{li}</li>)}</ul> : null
              ))}
            </div>
          ))}

          <!-- 特别意义 -->
          <div class="ev-flag-sec">
            <h3>{flagMeaning.h}</h3>
            {flagMeaning.blocks.map((bl) => (
              bl.p ? <p>{bl.p}</p> :
              bl.list ? <ul class="ev-flag-list">{bl.list.map((li) => <li>{li}</li>)}</ul> : null
            ))}
          </div>

          <!-- 论文获取 -->
          <div class="ev-flag-sec">
            <h3>论文获取</h3>
            <ul class="ev-flag-list">
              <li>期刊：Journal of Cosmetic Dermatology（Wiley 出版）</li>
              <li>DOI：10.1111/jocd.70978</li>
              <li>全文链接：<a href="https://doi.org/10.1111/jocd.70978" target="_blank" rel="noopener">https://doi.org/10.1111/jocd.70978</a>（开放获取，任何人可免费下载）</li>
              <li>配套研究方案：JMIR Research Protocols 2025;14:e71255</li>
            </ul>
          </div>

          <a href={`/evidence-center/${rct.slug}`} class="ev-cta-btn">查看完整报道<i>→</i></a>
        </div>
      </div>
    </section>

    <!-- ── 模块 4：机理基石 ── -->
    <section class="ev-mechanism" id="mechanism">
      <div class="ev-wrap">
        <header class="ev-mech-header reveal reveal-rise">
          <span class="ev-flag-tag dark">机理基石</span>
          <h2 class="ev-h2 light">不只是"有效"，而是"为什么有效"</h2>
          <p class="ev-mech-sub">{mechSub}</p>
          <div class="ev-mech-intro">
            {mechIntro.map((para) => <p>{para}</p>)}
          </div>
          <div class="ev-mech-logos">
            <span class="ev-mech-logo"><img src="/assets/pubmed-logo.png" alt="PubMed 收录" /></span>
            <span class="ev-mech-logo"><img src="/assets/mdpi-logo.svg" alt="MDPI 出版" /></span>
            <span class="ev-mech-logo-text">PubMed / MEDLINE 收录 · MDPI 出版 · CC BY 4.0 开放获取</span>
          </div>
        </header>

        <div class="ev-mech-diagram reveal reveal-rise">
          <MechanismDiagram />
        </div>

        <div class="ev-mech-body reveal reveal-rise">
          {mechFindings.map((sec) => (
            <div class="ev-mech-sec">
              <h3>{sec.h}</h3>
              {sec.blocks.map((bl) => (
                bl.p ? <p>{bl.p}</p> :
                bl.list ? <ul class="ev-mech-ul">{bl.list.map((li) => <li>{li}</li>)}</ul> :
                bl.ol ? <ol class="ev-mech-ol">{bl.ol.map((li) => <li>{li}</li>)}</ol> :
                bl.checks ? (
                  <ul class="ev-mech-checks">
                    {bl.checks.map((c) => <li><EvIcon name="verified" size={17} class="ev-mech-check-icon" />{c}</li>)}
                  </ul>
                ) : null
              ))}
            </div>
          ))}

          <!-- 论文获取 -->
          <div class="ev-mech-sec">
            <h3>论文获取</h3>
            <ul class="ev-mech-ul">
              <li>期刊：International Journal of Molecular Sciences（IF 6.208）</li>
              <li>DOI：10.3390/ijms231911371</li>
              <li>PubMed 收录 + 开放获取（CC BY 4.0）</li>
              <li>全文链接：<a href="https://doi.org/10.3390/ijms231911371" target="_blank" rel="noopener">https://doi.org/10.3390/ijms231911371</a></li>
            </ul>
          </div>

          <a href={`/evidence-center/${sci.slug}`} class="ev-cta-btn light ev-mech-cta">查看完整机理研究<i>→</i></a>
        </div>
      </div>
    </section>

    <!-- ── 模块 5：4 项支撑临床证据 ── -->
    <section class="ev-section" id="clinical-evidence">
      <div class="ev-wrap">
        <header class="ev-head reveal reveal-rise">
          <h2 class="ev-h2">4 项支撑临床证据 · 全人群 / 全病程覆盖</h2>
          <p class="ev-sub">除了 2026 年的旗舰研究和 2022 年的机理研究外，还有 4 项核心临床研究，分别在不同患者群体中验证了海得宝核心成分的疗效与安全性。</p>
        </header>
        <div class="ev-clinic-grid">
          {clinicalCards.map((c) => (
            <article class="ev-clinic-card reveal reveal-rise" style={`--accent:${c.color}`}>
              <div class="ev-clinic-head">{c.org} · {c.year}</div>
              <h3 class="ev-clinic-title"><a href={`/evidence-center/${c.slug}`}>{c.title}</a></h3>

              <div class="ev-clinic-block">
                <p class="ev-clinic-label">这项研究的特别之处</p>
                {c.special.map((p) => <p>{p}</p>)}
              </div>

              <div class="ev-clinic-block">
                <p class="ev-clinic-label">{c.resultLabel}</p>
                <ul class="ev-clinic-list">{c.results.map((r) => <li>{r}</li>)}</ul>
              </div>

              <div class="ev-clinic-block">
                <p class="ev-clinic-label">这意味着什么</p>
                <p>{c.meaning}</p>
              </div>

              <div class="ev-clinic-paper">
                <p class="ev-clinic-label">论文</p>
                <p>{c.paper}</p>
                {c.paperUrl
                  ? <a class="ev-clinic-doi" href={c.paperUrl} target="_blank" rel="noopener">立即阅读全文<EvIcon name="arrow" size={15} /></a>
