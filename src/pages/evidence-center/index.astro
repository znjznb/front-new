  .ev-flag-tag::before { content: ''; width: 26px; height: 2px; background: var(--color-brand); border-radius: 1px; flex-shrink: 0; }
  .ev-flag-tag.dark { color: #fff; }
  .ev-flag-title { font-size: clamp(1.375rem, 1rem + 1.6vw, 2rem); font-weight: 300; line-height: 1.4; color: var(--color-text); margin-bottom: var(--space-sm); }
  .ev-flag-meta { font-size: 0.875rem; color: var(--color-text-muted); margin-bottom: var(--space-2xl); }
  .ev-flag-sec { margin-top: var(--space-2xl); }
  .ev-flag-sec > h3 { font-size: 1.125rem; font-weight: 500; color: var(--color-text); margin-bottom: var(--space-md); }
  .ev-flag-sec > h3::before { content: ''; display: block; width: 28px; height: 2px; background: var(--color-brand); border-radius: 1px; margin-bottom: 12px; }
  .ev-flag-sec p { font-size: 0.9375rem; line-height: 1.85; color: var(--color-text-soft); font-weight: 300; margin-bottom: var(--space-md); }
  .ev-flag-list { list-style: none; display: flex; flex-direction: column; gap: var(--space-sm); margin-top: var(--space-sm); }
  .ev-flag-list li { position: relative; padding-left: var(--space-lg); font-size: 0.9375rem; line-height: 1.75; color: var(--color-text-soft); font-weight: 300; }
  .ev-flag-list li::before { content: ''; position: absolute; left: 0; top: 0.65em; width: 6px; height: 6px; border-radius: 50%; background: var(--color-brand); }
  .ev-flag-list a { color: var(--color-brand-dark); word-break: break-all; }
  .ev-flagship > .ev-cta-btn { margin-top: var(--space-2xl); }

  .ev-statrow { display: grid; grid-template-columns: repeat(5, 1fr); gap: var(--space-md); margin-bottom: var(--space-2xl); }
  .ev-stat { text-align: center; padding: var(--space-lg) var(--space-sm); background: var(--color-bg-light); border-radius: var(--radius); }
  .ev-stat-v { display: block; font-size: 1.75rem; font-weight: 600; color: var(--color-brand-dark); line-height: 1; }
  .ev-stat-l { display: block; font-size: 0.8125rem; color: var(--color-text); margin-top: 8px; }
  .ev-stat-sub { display: block; font-size: 0.7rem; color: var(--color-text-muted); margin-top: 2px; }

  /* Chart */
  .ev-chart { margin-bottom: var(--space-2xl); }
  .ev-chart-head { display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: var(--space-md); margin-bottom: var(--space-lg); }
  .ev-chart-title { font-size: 0.9375rem; font-weight: 500; color: var(--color-text); }
  .ev-chart-legend { display: flex; gap: var(--space-lg); font-size: 0.75rem; color: var(--color-text-soft); }
  .ev-chart-legend span { display: inline-flex; align-items: center; gap: 6px; }
  .ev-chart-legend i { width: 12px; height: 12px; border-radius: 3px; }
  .lg-a { background: var(--color-brand-dark); }
  .lg-b { background: oklch(55% 0.025 235); }
  .ev-bargroup { margin-bottom: var(--space-md); }
  .ev-bar-label { display: block; font-size: 0.8125rem; color: var(--color-text-soft); margin-bottom: 6px; }
  .ev-bars { display: flex; flex-direction: column; gap: 6px; }
  .ev-bar-track { background: oklch(90% 0.012 200); border-radius: var(--radius-sm); overflow: hidden; }
  .ev-bar { position: relative; height: 26px; min-width: 36px; width: var(--target); border-radius: var(--radius-sm); overflow: hidden; }
  .ev-bar::before { content: ''; position: absolute; inset: 0; border-radius: inherit; transform-origin: left center; }
  .ev-bar.a::before { background: var(--color-brand-dark); }
  .ev-bar.b::before { background: oklch(55% 0.025 235); }
  .ev-bar-num { position: absolute; right: 10px; top: 50%; transform: translateY(-50%); z-index: 1; font-size: 0.75rem; font-weight: 600; color: #fff; }
  .ev-bar.b .ev-bar-num { color: #fff; }
  /* 进入视口时用 transform 生长（不触发布局；无 JS / reduced-motion 时直接满格显示） */
  .ev-chart.js-grow .ev-bar::before { transform: scaleX(0); transition: transform 1.1s var(--ease-out-expo); }
  .ev-chart.js-grow.in-view .ev-bar::before { transform: scaleX(1); }
  .ev-chart.js-grow .ev-bar-num { opacity: 0; transition: opacity 0.5s ease 0.5s; }
  .ev-chart.js-grow.in-view .ev-bar-num { opacity: 1; }

  /* CTA buttons */
  .ev-cta-btn { display: inline-flex; align-items: center; gap: 10px; height: 46px; padding: 0 var(--space-xl); background: var(--color-text); color: var(--color-surface); border-radius: var(--radius); font-size: 0.875rem; letter-spacing: 0.04em; transition: transform 0.3s ease, background 0.3s ease; }
  .ev-cta-btn i { font-style: normal; }
  .ev-cta-btn:hover { transform: scale(1.03); background: var(--color-brand-dark); }
  .ev-cta-btn.light { background: #fff; color: var(--color-text); }

  /* Mechanism (dark) */
  .ev-mechanism { padding: var(--space-5xl) 0; background: linear-gradient(135deg, #2b3a67, #1f2a4d); color: #fff; }
  .ev-mech-header { max-width: 900px; margin: 0 auto var(--space-3xl); }
  .ev-mech-sub { font-size: 1.0625rem; line-height: 1.6; color: #fff; font-weight: 400; margin: var(--space-md) 0 var(--space-lg); }
  .ev-mech-intro p { font-size: 0.9375rem; line-height: 1.85; color: rgba(255,255,255,0.74); font-weight: 300; margin-bottom: var(--space-md); }
  .ev-mech-logos { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-md); margin-top: var(--space-xl); }
  .ev-mech-logo { display: inline-flex; align-items: center; height: 40px; padding: 0 16px; background: #fff; border-radius: var(--radius-sm); }
  .ev-mech-logo img { height: 22px; width: auto; display: block; }
  .ev-mech-logo-text { font-size: 0.8125rem; color: rgba(255,255,255,0.6); }
  .ev-mech-diagram { max-width: 880px; margin: 0 auto var(--space-3xl); }
  .ev-mech-body { max-width: 900px; margin: 0 auto; }
  .ev-mech-sec { margin-top: var(--space-2xl); }
  .ev-mech-sec > h3 { font-size: 1.125rem; font-weight: 500; color: #fff; margin-bottom: var(--space-md); }
  .ev-mech-sec > h3::before { content: ''; display: block; width: 28px; height: 2px; background: var(--color-brand); border-radius: 1px; margin-bottom: 12px; }
  .ev-mech-sec p { font-size: 0.9375rem; line-height: 1.85; color: rgba(255,255,255,0.78); font-weight: 300; margin-bottom: var(--space-md); }
  .ev-mech-ul { list-style: none; display: flex; flex-direction: column; gap: var(--space-sm); margin: var(--space-sm) 0 var(--space-md); }
  .ev-mech-ul li { position: relative; padding-left: var(--space-lg); font-size: 0.9375rem; line-height: 1.75; color: rgba(255,255,255,0.78); font-weight: 300; }
  .ev-mech-ul li::before { content: ''; position: absolute; left: 0; top: 0.65em; width: 6px; height: 6px; border-radius: 50%; background: var(--color-brand); }
  .ev-mech-ul a { color: #fff; text-decoration: underline; text-underline-offset: 3px; word-break: break-all; }
  .ev-mech-ol { list-style: none; counter-reset: mech; display: flex; flex-direction: column; gap: var(--space-sm); margin: var(--space-sm) 0 var(--space-md); }
  .ev-mech-ol li { counter-increment: mech; position: relative; padding-left: 2.2em; font-size: 0.9375rem; line-height: 1.75; color: rgba(255,255,255,0.82); font-weight: 300; }
  .ev-mech-ol li::before { content: counter(mech); position: absolute; left: 0; top: 0.05em; width: 1.5em; height: 1.5em; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 600; color: #fff; background: var(--color-brand); border-radius: 50%; }
  .ev-mech-checks { list-style: none; display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px var(--space-lg); margin: var(--space-sm) 0 var(--space-md); }
  .ev-mech-checks li { display: flex; align-items: center; gap: 9px; font-size: 0.9375rem; line-height: 1.5; color: rgba(255,255,255,0.86); font-weight: 300; }
  .ev-mech-checks :global(.ev-mech-check-icon) { color: var(--color-brand); flex-shrink: 0; }
  .ev-mech-cta { margin-top: var(--space-2xl); }

  /* 支撑临床证据卡片（2×2，每张按人群配色） */
  .ev-clinic-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-xl); }
  .ev-clinic-card { display: flex; flex-direction: column; padding: var(--space-2xl); background: #fff; border: 1px solid var(--color-border-light); border-radius: var(--radius-lg); transition: transform 0.4s var(--ease-out-quint), border-color 0.4s ease; }
  .ev-clinic-card:hover { transform: translateY(-4px); border-color: var(--accent); }
  .ev-clinic-head { display: flex; align-items: center; gap: 9px; font-size: 0.8125rem; font-weight: 600; color: var(--accent); margin-bottom: var(--space-sm); }
  .ev-clinic-head::before { content: ''; width: 10px; height: 10px; border-radius: 50%; background: var(--accent); flex-shrink: 0; }
  .ev-clinic-title { font-size: 1.0625rem; font-weight: 500; line-height: 1.55; color: var(--color-text); margin-bottom: var(--space-md); }
  .ev-clinic-title a { color: inherit; transition: color 0.2s ease; }
  .ev-clinic-title a:hover { color: var(--accent); }
  .ev-clinic-block { margin-top: var(--space-md); }
  .ev-clinic-label { font-size: 0.8125rem; font-weight: 600; color: var(--color-text); margin-bottom: 6px; }
  .ev-clinic-card p { font-size: 0.875rem; line-height: 1.8; color: var(--color-text-soft); font-weight: 300; margin-bottom: var(--space-sm); }
  .ev-clinic-card p:last-child { margin-bottom: 0; }
  .ev-clinic-list { list-style: none; display: flex; flex-direction: column; gap: 5px; }
  .ev-clinic-list li { position: relative; padding-left: var(--space-md); font-size: 0.875rem; line-height: 1.7; color: var(--color-text-soft); font-weight: 300; }
  .ev-clinic-list li::before { content: ''; position: absolute; left: 0; top: 0.62em; width: 5px; height: 5px; border-radius: 50%; background: var(--accent); }
  .ev-clinic-paper { margin-top: auto; padding-top: var(--space-lg); }
  .ev-clinic-paper > p { font-size: 0.8125rem; color: var(--color-text-muted); line-height: 1.6; }
  .ev-clinic-doi { display: inline-flex; align-items: center; gap: 6px; font-size: 0.8125rem; font-weight: 500; color: var(--accent); margin-top: 4px; }

  /* 收尾：完整证据闭环 */
  .ev-closeloop { max-width: 760px; margin: var(--space-4xl) auto 0; padding-top: var(--space-2xl); border-top: 1px solid var(--color-border); }
  .ev-closeloop-h, .ev-closeloop-intro { text-align: center; }
  .ev-closeloop-list { max-width: 560px; margin: 0 auto; }
  .ev-closeloop-h { font-size: 1.25rem; font-weight: 500; line-height: 1.5; color: var(--color-text); margin-bottom: var(--space-md); }
  .ev-closeloop-intro { font-size: 0.9375rem; color: var(--color-text-soft); font-weight: 300; margin-bottom: var(--space-lg); }
  .ev-closeloop-list { list-style: none; display: flex; flex-direction: column; gap: var(--space-sm); }
  .ev-closeloop-list li { position: relative; padding-left: var(--space-lg); font-size: 0.9375rem; line-height: 1.7; color: var(--color-text-soft); font-weight: 300; }
  .ev-closeloop-list li::before { content: ''; position: absolute; left: 0; top: 0.62em; width: 6px; height: 6px; border-radius: 50%; background: var(--color-brand); }
  .ev-closeloop-list strong { color: var(--color-text); font-weight: 600; }

  /* CAPCS 核心成分 */
  .ev-capcs { background: var(--color-bg-cream); }
  .ev-capcs-intro { max-width: 760px; margin: var(--space-md) auto 0; text-align: left; }
  .ev-capcs-intro p { font-size: 1rem; line-height: 1.85; color: var(--color-text-soft); font-weight: 300; margin-bottom: var(--space-sm); }
  .ev-capcs-blocks { display: flex; flex-direction: column; gap: 0; max-width: 880px; margin: 0 auto; }
  .ev-capcs-block { padding: var(--space-3xl) 0; }
  .ev-capcs-block:first-child { padding-top: var(--space-lg); }
  .ev-capcs-block + .ev-capcs-block { border-top: 1px solid var(--color-border); }
  .ev-ic-brand { color: var(--color-brand-dark); display: inline-flex; align-items: center; }
  .ev-ic-mute { color: var(--color-text-muted); display: inline-flex; align-items: center; }
  .ev-capcs-h { display: flex; align-items: center; gap: 10px; font-size: 1.25rem; font-weight: 500; color: var(--color-text); margin-bottom: var(--space-md); }
  .ev-capcs-block > p { font-size: 0.9375rem; line-height: 1.85; color: var(--color-text-soft); font-weight: 300; margin-bottom: var(--space-sm); }
  .ev-capcs-block > p.ev-capcs-summary { color: var(--color-text); font-weight: 400; margin-top: var(--space-md); margin-bottom: 0; }
  .ev-capcs-block > p.ev-capcs-safe { margin-bottom: 0; }

  /* 来源解构图 + 文案 */
  .ev-capcs-origin { display: grid; grid-template-columns: 260px 1fr; gap: var(--space-2xl); align-items: center; }
  .ev-capcs-fig { margin: 0; }
  .ev-capcs-fig img { display: block; width: 100%; height: auto; }
  .ev-capcs-origin-text > p:first-child { margin-top: 0; }
  @media (max-width: 720px) {
    .ev-capcs-origin { grid-template-columns: 1fr; gap: var(--space-lg); }
    .ev-capcs-fig { max-width: 240px; margin: 0 auto; }
  }

  /* 来源 2 项 */
  .ev-capcs-source { display: grid; grid-template-columns: 1fr; gap: var(--space-md); margin-top: var(--space-lg); }
  .ev-capcs-source-item { display: flex; gap: var(--space-md); padding-top: var(--space-md); border-top: 1px solid var(--color-border); align-items: flex-start; }
  .ev-capcs-source-no { flex-shrink: 0; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; font-size: 0.875rem; font-weight: 600; color: #fff; background: var(--color-brand); border-radius: 50%; }
  .ev-capcs-source-item strong { display: block; font-size: 1rem; color: var(--color-text); margin-bottom: 4px; }
  .ev-capcs-source-item p { font-size: 0.875rem; line-height: 1.7; color: var(--color-text-soft); font-weight: 300; }

  /* 4 作用通路 */
  .ev-capcs-paths { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-xl); margin: var(--space-lg) 0; }
  .ev-capcs-path { display: flex; flex-direction: column; gap: 7px; padding-top: var(--space-md); border-top: 2px solid var(--color-text); }
  .ev-capcs-path .ev-ic-brand { margin-bottom: 2px; }
  .ev-capcs-path strong { font-size: 1.0625rem; color: var(--color-text); font-weight: 600; }
  .ev-capcs-path-plain { font-size: 0.9375rem; line-height: 1.55; color: var(--color-text-soft); font-weight: 400; }
  .ev-capcs-path-mech { font-size: 0.75rem; line-height: 1.6; color: var(--color-text-muted); font-weight: 300; margin-top: auto; padding-top: 8px; }

  /* 不含 */
  .ev-capcs-none { display: flex; flex-wrap: wrap; gap: var(--space-sm); margin: var(--space-sm) 0 var(--space-md); }
  .ev-capcs-none-item { display: inline-flex; align-items: center; gap: 7px; padding: 8px 16px; background: var(--color-bg-light); border: 1px solid var(--color-border-light); border-radius: var(--radius-pill); font-size: 0.875rem; color: var(--color-text); }

  /* Scenarios */
  .ev-scenarios { max-width: 820px; margin: 0 auto; display: flex; flex-direction: column; gap: var(--space-sm); }
  .ev-scenario { border: 1px solid var(--color-border-light); border-radius: var(--radius); background: #fff; overflow: hidden; }
  .ev-scenario summary { display: flex; align-items: center; gap: var(--space-md); padding: var(--space-lg); font-size: 1rem; font-weight: 500; color: var(--color-text); cursor: pointer; list-style: none; }
  .ev-scenario summary::-webkit-details-marker { display: none; }
  .ev-scenario summary::after { content: '+'; margin-left: auto; font-size: 1.3rem; color: var(--color-text-muted); }
  .ev-scenario[open] summary::after { content: '−'; color: var(--color-brand); }
  .ev-sc-body { padding: 0 var(--space-lg) var(--space-lg); }
  .ev-sc-body p { font-size: 0.875rem; line-height: 1.8; color: var(--color-text-soft); font-weight: 300; margin-bottom: var(--space-sm); }
  .ev-sc-body p:last-child { margin-bottom: 0; }
  .ev-sc-answer strong, .ev-sc-refs strong, .ev-sc-notice strong { color: var(--color-text); font-weight: 600; }
  .ev-sc-body p.ev-sc-refs { font-size: 0.8125rem; color: var(--color-text-muted); }
  .ev-sc-row { margin: var(--space-sm) 0; }
  .ev-sc-rowlabel { display: inline-block; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.02em; color: var(--color-brand-dark); margin-bottom: 5px; }
  .ev-sc-list { list-style: none; display: flex; flex-direction: column; gap: 5px; }
  .ev-sc-list li { position: relative; padding-left: var(--space-md); font-size: 0.875rem; line-height: 1.7; color: var(--color-text-soft); font-weight: 300; }
  .ev-sc-list li::before { content: ''; position: absolute; left: 0; top: 0.62em; width: 5px; height: 5px; border-radius: 50%; background: var(--color-brand); }
  .ev-sc-body p.ev-sc-notice { font-size: 0.8125rem; color: var(--color-text-soft); background: var(--color-bg-cream); border-radius: var(--radius-sm); padding: 10px 14px; margin-top: var(--space-md); }
  .ev-sc-links { display: flex; flex-wrap: wrap; gap: var(--space-md); margin-top: var(--space-md); padding-top: var(--space-md); border-top: 1px solid var(--color-border-light); }
  .ev-sc-links a { font-size: 0.8125rem; color: var(--color-brand-dark); font-weight: 500; }

  /* CTA section */
  .ev-ctas { background: var(--color-bg-cream); }
  .ev-cta-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-xl); margin-bottom: var(--space-2xl); }
  .ev-cta-card { display: flex; flex-direction: column; padding: var(--space-2xl); background: #fff; border-radius: var(--radius-lg); }
  .ev-cta-card h3 { display: flex; align-items: center; gap: 10px; font-size: 1.25rem; font-weight: 500; margin-bottom: var(--space-sm); color: var(--color-text); }
  .ev-cta-card p { font-size: 0.9375rem; line-height: 1.8; color: var(--color-text-soft); font-weight: 300; margin-bottom: var(--space-lg); }
  .ev-cta-card p.ev-cta-lead { font-size: 0.875rem; color: var(--color-text-muted); margin-bottom: var(--space-sm); }
  .ev-doi-list { list-style: none; display: flex; flex-direction: column; gap: var(--space-md); }
  .ev-doi-list li { display: flex; flex-direction: column; gap: 2px; }
  .ev-doi-link { display: inline-flex; align-items: center; gap: 6px; font-size: 0.875rem; color: var(--color-brand-dark); font-weight: 500; }
  .ev-doi-num { font-size: 0.75rem; color: var(--color-text-muted); }
  .ev-doi-list.plain li { display: list-item; position: relative; padding-left: var(--space-md); font-size: 0.875rem; color: var(--color-text-soft); }
  .ev-doi-list.plain li::before { content: ''; position: absolute; left: 0; top: 0.7em; width: 5px; height: 5px; border-radius: 50%; background: var(--color-brand); }
  .ev-cta-foot { display: inline-flex; align-items: center; gap: 6px; margin-top: var(--space-lg); padding-top: var(--space-lg); border-top: 1px solid var(--color-border-light); font-size: 0.875rem; font-weight: 600; color: var(--color-text); }
  .ev-cta-foot:hover { color: var(--color-brand-dark); }
  /* 社群二维码占位 */
  .ev-qr { display: flex; align-items: center; gap: var(--space-lg); margin-top: auto; padding-top: var(--space-lg); }
  .ev-qr-box { flex-shrink: 0; width: 96px; height: 96px; display: flex; align-items: center; justify-content: center; text-align: center; font-size: 0.75rem; line-height: 1.5; color: var(--color-text-muted); background: var(--color-bg-cream); border: 1px dashed var(--color-border); border-radius: var(--radius); }
  .ev-qr-meta { display: flex; flex-direction: column; gap: 4px; }
  .ev-qr-meta strong { font-size: 0.9375rem; color: var(--color-text); font-weight: 600; }
  .ev-qr-meta span { font-size: 0.8125rem; color: var(--color-text-muted); font-weight: 300; line-height: 1.5; }
  .ev-footer-info { display: grid; grid-template-columns: 1.4fr 1fr; gap: var(--space-2xl); max-width: 900px; margin: 0 auto; padding-top: var(--space-xl); border-top: 1px solid var(--color-border-light); }
  .ev-footer-col h4 { font-size: 0.9375rem; font-weight: 600; color: var(--color-text); margin-bottom: var(--space-md); }
  .ev-footer-col p { font-size: 0.8125rem; color: var(--color-text-soft); margin-bottom: var(--space-sm); }
  .ev-footer-col ul { list-style: none; display: flex; flex-direction: column; gap: var(--space-sm); }
  .ev-footer-col li { font-size: 0.8125rem; line-height: 1.7; color: var(--color-text-soft); }
  .ev-footer-col strong { color: var(--color-text); font-weight: 600; }

  /* Responsive */
  @media (max-width: 900px) {
    .ev-q3 { grid-template-columns: 1fr; }
    .ev-clinic-grid, .ev-cta-grid, .ev-footer-info { grid-template-columns: 1fr; }
    .ev-capcs-paths { grid-template-columns: repeat(2, 1fr); }
    .ev-badges { grid-template-columns: repeat(3, 1fr); }
    .ev-statrow { grid-template-columns: repeat(2, 1fr); }
    .ev-closeloop { padding-top: var(--space-xl); }
