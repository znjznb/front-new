---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import EvidenceMap from '../../components/EvidenceMap.astro';
import MechanismDiagram from '../../components/MechanismDiagram.astro';
import EvIcon from '../../components/EvIcon.astro';
import { EVIDENCE_META, MATRIX, STUDIES, getStudy } from '../../data/evidence.js';

const rct = getStudy('multicenter-rct');
const sci = getStudy('mechanism-sci');
const support = STUDIES.filter((s) => !s.flagship);
const chart = rct.chart;

// 参与研究的 14 家三甲医院 logo（用户提供权威版，按区域排列，与模块2地图一致）
const hospitalLogos = [
