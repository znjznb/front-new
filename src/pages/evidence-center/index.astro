// ── 模块 3 旗舰研究正文（逐字，来自项目文档，不改写文字内容）──
const flagIntro = {
  h: '这项研究做了什么？',
  blocks: [
    { p: '2023 年 10 月到 2025 年 6 月，由上海皮肤病医院牵头，联合北京大学第三医院、华西医院的姐妹机构等全国 10 家三级甲等医院，对 200 位 18–55 岁的轻度特应性皮炎患者开展了一项多中心、随机、双盲、安慰剂对照临床试验。' },
    { p: '这是国内同类品类罕有的研究规格——它的方法学严谨度与国际新药临床试验的标准相当。' },
    { p: '患者被随机分为两组（每组 100 人）：' },
    { list: [
      '试验组：使用含贻贝钙肽 CAPCS 的海得宝身体乳（HBL，即俗称的"大白管特护霜""5X 身体乳"）',
      '对照组：使用不含贻贝钙肽 CAPCS 的同款基质（外观、质地、使用方式完全一致——这是医学界用来排除"心理作用"和"基础保湿效果"的关键设计）',
    ] },
    { p: '每天 3 次，连续 4 周。所有受试者和研究者均不知道自己分配到哪一组（双盲）。' },
  ],
};
const flagFindings = [
  { h: '皮损改善：远超安慰剂', blocks: [
    { p: '衡量 AD 严重程度最权威的国际指标是 EASI 评分。"EASI50"意味着皮损减轻 50% 以上，"EASI75"意味着减轻 75% 以上——这是新药临床试验的金标准。' },
    { list: [
      '第 2 周：HBL 组 37% 的患者达到 EASI50，对照组只有 19%',
      '第 4 周：HBL 组 65% 达到 EASI50（对照组 41%）',
      '第 4 周：HBL 组 42% 达到 EASI75（对照组 19%）',
    ] },
    { p: '4 周后，每 10 个使用海得宝身体乳（大白管特护霜）的患者中，约 6.5 人皮损减轻一半以上，4.2 人皮损减轻 75% 以上。' },
  ] },
  { h: '瘙痒缓解：从"难以忍受"到"几乎不痒"', blocks: [
    { p: '瘙痒是 AD 最让人崩溃的症状。研究用 0–10 分的 NRS 瘙痒评分（数字评分量表，数字越大越痒）来衡量。' },
    { list: [
      'HBL 组瘙痒评分从基线下降 2.9 分',
      '对照组只下降 1.6 分',
      '组间差异 1.3 分（P < 0.001，有强统计学意义）',
    ] },
    { p: '如果之前是"非常痒"（7 分），用了 4 周后大多数患者降到了"基本不痒"（2 分以下）。' },
  ] },
  { h: '生活质量：6.7 分的巨大提升', blocks: [
    { p: '皮肤病生活质量指数 DLQI 评估皮肤病对日常生活、社交、睡眠、心理的影响。' },
    { list: [
      'HBL 组 DLQI 评分下降 6.7 分（对照组 3.7 分）',
      '这意味着患者从"皮肤病严重影响生活"恢复到"基本不影响生活"',
    ] },
  ] },
  { h: '安全性：与"无活性安慰剂"一样安全', blocks: [
    { list: [
      'HBL 组不良反应率：1%（1/100）',
      '对照组不良反应率：1%（1/100）',
      '两组完全一致，零严重不良事件，零退出',
    ] },
    { p: '含贻贝钙肽 CAPCS 的海得宝身体乳和"什么都没有的基础保湿剂"一样温和。' },
  ] },
];
const flagMeaning = {
  h: '这项研究的特别意义',
  blocks: [
    { p: '这项研究还首次揭示了一个有趣的发现：' },
    { p: '女性患者获益更显著——女性受试者在 EASI50 和 EASI75 应答率上都明显高于男性。研究团队给出的科学解释是：女性体内的雌激素会增强 Th2 细胞活性、上调内源性抗菌肽（如 LL-37）的表达、促进皮肤屏障修复，而贻贝钙肽 CAPCS 中的抗菌肽和钙离子刚好与这些女性内源性的修复机制形成协同。' },
    { p: '此外，研究中面部和头部 AD 患者占 HBL 组的 30%——这是个特别重要的群体，因为长期在面部使用强效激素会导致口周皮炎、毛细血管扩张、痤疮，眼周长期使用甚至可能引起白内障和青光眼。含贻贝钙肽 CAPCS 的海得宝身体乳（大白管特护霜）为面部和颈部的长期管理提供了一个安全的非激素替代方案。' },
  ],
};

// ── 模块 4 机理基石正文（逐字，来自项目文档，不改写文字内容）──
const mechSub = '四川大学华西医院在国际 SCI 期刊首次系统阐明贻贝钙肽 CAPCS 的分子作用机制';
const mechIntro = [
  '2022 年 9 月，四川大学华西医院皮肤性病科的研究团队（黎静宜教授等）在国际 SCI 期刊《International Journal of Molecular Sciences》（影响因子 6.208，PubMed/MEDLINE 收录）发表了一项国际首次系统阐明 CAPCS 作用机制的研究。',
  '这项研究填补了海得宝核心成分贻贝钙肽 CAPCS 的科学机制空白，也让海得宝从"经验性产品"跨入"循证产品"的行列。',
];
const mechFindings = [
  { h: '研究发现了什么？', blocks: [
    { p: '研究人员用 DNFB（一种化学物质）诱导小鼠产生特应性皮炎样的皮肤病变，然后比较 4 组小鼠：什么都不做的、只涂基质的、涂 CAPCS 的、涂弱效激素（地奈德）的。结果发现：' },
  ] },
  { h: '发现 1：贻贝钙肽 CAPCS 全面抑制 4 大炎症通路', blocks: [
    { p: '特应性皮炎的本质是免疫系统过度反应。免疫系统中有 4 种"T 细胞兵种"——Th1、Th2、Th17、Th22——它们分泌的多种炎症因子（IFN-γ、IL-4、IL-5、IL-13、IL-31、IL-17、IL-22）在 AD 患者皮肤上"开战"，造成红斑、瘙痒、糜烂。' },
    { p: '研究证实：贻贝钙肽 CAPCS 能同时降低这 4 类兵种产生的所有炎症因子，抗炎广度与弱效激素地奈德相当。' },
  ] },
  { h: '发现 2：贻贝钙肽 CAPCS 调节关键 TLR 信号', blocks: [
    { p: 'AD 患者皮肤上的 TLR2 和 TLR4 受体表达异常——这是为什么 AD 患者特别容易感染金黄色葡萄球菌的核心原因。贻贝钙肽 CAPCS 能够直接调节这两个受体的表达，纠正 AD 患者特有的免疫异常。' },
  ] },
  { h: '发现 3：贻贝钙肽 CAPCS 的"双重杀菌"机制（首次详细阐述）', blocks: [
    { p: '贻贝钙肽 CAPCS 的杀菌方式很特别，论文中是这样描述的：' },
    { ol: [
      '抗菌肽（AMP）在细菌细胞膜上开"通道"',
      '钙离子通过这些通道快速涌入细菌细胞',
      '细胞内钙离子浓度急剧升高，代谢系统崩溃',
      '细胞器泄漏，细菌死亡',
    ] },
    { p: '这种"开门 + 涌入"的协同杀菌方式，比单独使用抗菌肽或钙离子的效果更彻底。' },
  ] },
  { h: '发现 4：止痒效果显著', blocks: [
    { p: '用"抓挠次数"来衡量瘙痒——这是动物实验的金标准：' },
    { list: [
      '模型组（涂基质）：10 分钟抓挠 33 次',
      '贻贝钙肽 CAPCS 组：10 分钟抓挠 0.67 次（几乎完全消除）',
      '地奈德激素组：10 分钟抓挠 0 次',
    ] },
  ] },
  { h: '贻贝钙肽 CAPCS 的安全性证据', blocks: [
    { p: '论文中也详细披露了 CAPCS 的多项毒理学测试结果——全部为阴性：' },
    { checks: [
      '染色体畸变测试 — 无',
      '体外细胞毒性 — 无',
      '小鼠急性系统毒性 — 无',
      '大鼠亚急性系统毒性 — 无',
      '豚鼠皮肤致敏 — 无',
      '兔皮下与皮内反应 — 无',
    ] },
    { p: '结论：贻贝钙肽 CAPCS 在正常皮肤上未观察到任何副作用。' },
  ] },
];

