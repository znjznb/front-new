  <script>
    // 内容定制动效：柱状图生长 + 地图标点依次点亮。无 JS / reduced-motion 时内容默认可见。
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!reduce && 'IntersectionObserver' in window) {
      // 1) 柱状图生长
      document.querySelectorAll('[data-chart]').forEach((chart) => {
        chart.classList.add('js-grow');
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) { e.target.classList.add('in-view'); io.unobserve(e.target); }
          });
        }, { threshold: 0.3 });
        io.observe(chart);
      });
      // 2) 地图标点依次点亮
      const map = document.querySelector('.evmap-svg');
      if (map) {
        const pins = map.querySelectorAll('.evmap-pin');
        pins.forEach((p, i) => { p.style.opacity = '0'; p.style.setProperty('--d', i * 70 + 'ms'); });
        const mio = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              pins.forEach((p) => {
                p.style.transition = 'opacity .5s ease var(--d), transform .5s var(--d)';
                p.style.opacity = '1';
              });
              mio.disconnect();
            }
          });
        }, { threshold: 0.25 });
        mio.observe(map);
      }
    }

    // 分区吸顶导航：平滑滚动 + 当前分区高亮
    const subnav = document.querySelector('.ev-subnav');
    if (subnav) {
      const links = [...subnav.querySelectorAll('a[data-sec]')];
      const byId = new Map(links.map((a) => [a.dataset.sec, a]));
      // 平滑滚动（reduced-motion 时直接跳转，scroll-margin-top 保证落点正确）
      links.forEach((a) => {
        a.addEventListener('click', (e) => {
          const target = document.getElementById(a.dataset.sec);
          if (!target) return;
          e.preventDefault();
          target.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth', block: 'start' });
        });
      });
      // 当前分区高亮
      if ('IntersectionObserver' in window) {
        const setActive = (id) => links.forEach((a) => a.classList.toggle('active', a.dataset.sec === id));
        const spy = new IntersectionObserver(
          (entries) => {
            entries.forEach((en) => { if (en.isIntersecting) setActive(en.target.id); });
          },
          { rootMargin: '-140px 0px -55% 0px', threshold: 0 }
        );
        byId.forEach((_, id) => { const s = document.getElementById(id); if (s) spy.observe(s); });
      }
    }
  </script>
