---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import QaSection from '../components/QaSection.astro';
import Footer from '../components/Footer.astro';
import faqCategories from '../data/faq';

// FAQPage schema —— 用已有 32 组问答，让 AI/百度/豆包"答案优先"提取
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  '@id': 'https://www.martempo.com.cn/faq#faqpage',
  inLanguage: 'zh-CN',
  mainEntity: faqCategories.flatMap((c) => c.items).map((it) => ({
    '@type': 'Question',
    name: it.q,
    acceptedAnswer: { '@type': 'Answer', text: it.a },
  })),
};
---

<BaseLayout
  title="常见问题 — 海得宝 MARTEMPO"
  description="海得宝品牌、成分、产品功效的常见问题解答"
  jsonld={faqLd}
>
  <Nav />
  <main>
    <section class="faq-hero">
      <div class="faq-hero-content">
        <h1 class="faq-hero-title">常见问题</h1>
        <p class="faq-hero-desc">关于产品/品牌/功效/护肤问题</p>
      </div>
    </section>
    <QaSection showHeader={false} />
  </main>
  <Footer />
</BaseLayout>

<style>
  .faq-hero {
    padding: var(--space-5xl) var(--content-padding) var(--space-lg);
    background: linear-gradient(135deg, oklch(96% 0.01 185) 0%, oklch(98% 0.005 185) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 160px;
  }

  .faq-hero-content {
    text-align: center;
    max-width: 600px;
  }

  .faq-hero-title {
    font-size: var(--text-3xl);
    font-weight: 200;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    margin-bottom: var(--space-md);
    text-wrap: balance;
  }

  .faq-hero-desc {
    font-size: var(--text-lg);
    font-weight: 300;
    color: var(--color-text-soft);
  }
</style>
