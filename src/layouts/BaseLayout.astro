---
import '../styles/global.css';
import CookieConsent from '../components/CookieConsent.astro';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const SITE_URL = 'https://www.martempo.com.cn';

const {
  title = '海得宝MARTEMPO官网｜敏感肌家庭的专业功效护肤品牌',
  description = '海得宝MARTEMPO，专研贻贝钙肽CAPCS功效护肤品牌。海得宝官网为您提供：敏感肌面部、身体、手唇等家庭护肤产品及最新品牌资讯，欢迎访问官网了解更多详情。',
  image = '/assets/social-share.png',
} = Astro.props;

// Open Graph / 社交分享需要绝对 URL（微信、QQ 等爬虫不解析相对路径）
const canonicalURL = new URL(Astro.url.pathname, SITE_URL).href;
const ogImageURL = new URL(image, SITE_URL).href;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="theme-color" content="#FAF6EE" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- Open Graph（微信、QQ、微博、Facebook 等分享卡片） -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="海得宝 MARTEMPO" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="zh_CN" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Sora:wght@200;300;400;500;600;700&family=Noto+Sans+SC:wght@300;400;500;600;700&display=swap" />
  </head>
  <body>
    <slot />
    <CookieConsent />
  </body>
</html>
