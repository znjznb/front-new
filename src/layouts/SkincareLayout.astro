---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import RelatedArticles from '../components/RelatedArticles.astro';

export interface Props {
  title: string;
  description: string;
  category: string;
  topicSlug: string;
}

const { title, description, category, topicSlug } = Astro.props;

// 病症指南结构化数据（MedicalWebPage + BreadcrumbList）—— GEO
// 注：reviewedBy / lastReviewed 需指定真实医学审核人后补充（属 B 组）
const SITE_URL = 'https://www.martempo.com.cn';
const pageUrl = `${SITE_URL}/skincare/${topicSlug}`;
const HUB_URL = `${SITE_URL}/skincare/knowledge`; // 科学护肤总览页（真实存在）
const crumbName = title.replace(/\s*—\s*海得宝科学护肤$/, ''); // 去掉标题后缀，面包屑只显示病症名
const skincareLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'MedicalWebPage',
      '@id': `${pageUrl}#webpage`,
      name: title,
      description,
      url: pageUrl,
      inLanguage: 'zh-CN',
      isPartOf: { '@id': `${SITE_URL}/#website` },
      publisher: { '@id': `${SITE_URL}/#organization` },
    },
    {
      // 清晰三级层级（无自指 / 无重复目标）：首页 › 科学护肤 › 当前病症
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: '首页', item: `${SITE_URL}/` },
        { '@type': 'ListItem', position: 2, name: '科学护肤', item: HUB_URL },
        { '@type': 'ListItem', position: 3, name: crumbName, item: pageUrl },
      ],
    },
  ],
};
---

<BaseLayout title={title} description={description} jsonld={skincareLd}>
  <Nav />
  <main>
    <div class="skincare-hero">
      <div class="skincare-hero-inner">
        <nav class="breadcrumb" aria-label="面包屑导航">
          <a href="/">首页</a>
          <span class="sep">›</span>
          <a href="/skincare/knowledge">科学护肤</a>
          <span class="sep">›</span>
          <span class="current">{crumbName}</span>
        </nav>
      </div>
    </div>
    <div class="skincare-main">
      <slot />
    </div>
  </main>
  <RelatedArticles currentSlug={topicSlug} />
  <Footer />
</BaseLayout>

<style>
  .skincare-hero {
    padding: 100px var(--content-padding) var(--space-xl);
    background: #ffffff;
  }

  .skincare-hero-inner {
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  .breadcrumb {
    font-size: var(--text-xs);
  }

  .breadcrumb a {
    color: oklch(50% 0.01 260 / 0.6);
    text-decoration: none;
    transition: color var(--duration-fast) ease;
  }

  .breadcrumb a:hover {
    color: var(--color-brand);
  }

  .breadcrumb .sep {
    margin: 0 6px;
    color: oklch(50% 0.01 260 / 0.5);
  }

  .breadcrumb .current {
    color: oklch(35% 0.015 260 / 0.7);
    font-weight: 500;
  }

  .skincare-main {
    padding: var(--space-5xl) var(--content-padding) var(--space-6xl);
    background: #ffffff;
  }

  @media (max-width: 768px) {
    .skincare-hero {
      padding: 90px var(--content-padding) var(--space-lg);
    }
    .skincare-main {
      padding: var(--space-3xl) var(--content-padding) var(--space-5xl);
    }
  }
</style>
