---
// News Section: Latest brand news summary grid

import { getCollection } from 'astro:content';

const news = (await getCollection('news'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const latest = news.slice(0, 4);
---

<section id="news" class="section news">
  <div class="section-inner">
    <div class="news-header reveal reveal-rise">
      <div class="news-accent-line" aria-hidden="true"></div>
      <h2 class="news-title">新闻动态</h2>
      <p class="news-subtitle">品牌最新资讯与科研进展</p>
    </div>

    <div class="news-grid">
      {latest.map((item, i) => (
        <a href={`/news/${item.id.replace(/\.md$/, '')}/`} class="news-card reveal reveal-rise" class:list={{ [`reveal-delay-${(i % 4) + 1}`]: true }}>
          <time class="news-date">{new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }).format(item.data.date)}</time>
          <h3 class="news-card-title">{item.data.title}</h3>
          <p class="news-card-summary">{item.data.summary}</p>
          <span class="news-readmore">阅读详情 →</span>
        </a>
      ))}
    </div>
    {news.length > 4 && (
      <div class="news-footer reveal reveal-rise">
        <a href="/news/" class="news-all-link">查看全部新闻 →</a>
      </div>
    )}
  </div>
</section>

<style>
  .news {
    background: var(--color-bg);
    padding-top: var(--space-6xl);
    padding-bottom: var(--space-6xl);
    position: relative;
  }

  .news::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-brand-subtle), transparent);
  }

  .news-header {
    text-align: center;
    margin-bottom: var(--space-4xl);
  }

  .news-accent-line {
    width: 40px;
    height: 2px;
    background: var(--color-brand);
    margin: 0 auto var(--space-lg);
  }

  .news-title {
    font-size: var(--text-3xl);
    font-weight: 200;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-md);
  }

  .news-subtitle {
    font-size: var(--text-lg);
    font-weight: 300;
    color: var(--color-text-soft);
  }

  .news-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-xl);
  }

  .news-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-xl);
    background: var(--color-surface);
    text-decoration: none;
    transition: background var(--duration-fast) ease, transform var(--duration-fast) var(--ease-out-expo);
  }

  .news-card:hover {
    background: var(--color-surface-alt);
    transform: translateY(-2px);
  }

  .news-date {
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: var(--tracking-wide);
    color: var(--color-brand);
    margin-bottom: var(--space-md);
  }

  .news-card-title {
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--color-text);
    margin-bottom: var(--space-md);
    letter-spacing: var(--tracking-wide);
    line-height: var(--leading-snug);
  }

  .news-card-summary {
    font-size: var(--text-sm);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text-soft);
    margin-bottom: var(--space-lg);
    flex: 1;
  }

  .news-readmore {
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--color-brand-dark);
    transition: gap var(--duration-fast) ease;
  }

  .news-card:hover .news-readmore {
    text-decoration: underline;
  }

  .news-footer {
    text-align: center;
    margin-top: var(--space-2xl);
  }

  .news-all-link {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--color-brand-dark);
    text-decoration: none;
    padding: var(--space-sm) var(--space-lg);
    border: 1px solid var(--color-brand-dark);
    border-radius: var(--radius-pill);
    transition: background var(--duration-fast) ease, color var(--duration-fast) ease;
  }

  .news-all-link:hover {
    background: var(--color-brand-dark);
    color: var(--color-text-inverse);
  }

  @media (max-width: 768px) {
    .news-grid {
      grid-template-columns: 1fr;
    }

    .news-card {
      padding: var(--space-lg);
    }
  }
</style>
