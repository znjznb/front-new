  <!-- Mobile Menu -->
  <div class="mobile-overlay" id="mobileOverlay"></div>
  <div class="mobile-menu" id="mobileMenu">
    <button class="mobile-close" id="mobileClose" aria-label="关闭菜单">&times;</button>
    <div class="mobile-menu-body"></div>
  </div>
</nav>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const hamburger = document.getElementById('navHamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  const mobileOverlay = document.getElementById('mobileOverlay');
  const mobileClose = document.getElementById('mobileClose');
  const mobileBody = mobileMenu.querySelector('.mobile-menu-body');

  const navItems = document.querySelectorAll('.nav-links > .nav-item');
  mobileBody.innerHTML = '';
  navItems.forEach(item => {
    const topLink = item.querySelector('.nav-link');
    const subLinks = item.querySelectorAll('.mega-link');
    const section = document.createElement('div');
    section.className = 'mobile-section';

    const header = document.createElement('div');
    header.className = 'mobile-section-header';
    header.textContent = topLink.textContent;
    section.appendChild(header);

    if (subLinks.length) {
      const body = document.createElement('div');
      body.className = 'mobile-section-body';
      const inner = document.createElement('div');
      inner.className = 'mobile-section-body-inner';
      subLinks.forEach(link => {
        const a = document.createElement('a');
        a.href = link.getAttribute('href') || '#';
        a.className = 'mobile-section-link';
        a.textContent = link.textContent;
        inner.appendChild(a);
      });
      body.appendChild(inner);
      section.appendChild(body);
      header.addEventListener('click', () => {
        header.classList.toggle('active');
        body.classList.toggle('open');
      });
    }

    mobileBody.appendChild(section);
  });

  function openMobile() {
    mobileMenu.classList.add('open');
    mobileOverlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeMobile() {
    mobileMenu.classList.remove('open');
    mobileOverlay.classList.remove('open');
    document.body.style.overflow = '';
  }

  hamburger.addEventListener('click', openMobile);
  mobileClose.addEventListener('click', closeMobile);
  mobileOverlay.addEventListener('click', closeMobile);
});
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-nav);
    padding: var(--space-md) var(--content-padding);
    background: #ffffff;
    min-height: 82px;
  }

  .nav-inner {
    max-width: var(--content-max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-weight: 600;
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    text-decoration: none;
  }

  .nav-logo-img {
    display: block;
    width: 96px;
    height: auto;
  }

  /* ── Hamburger ── */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    z-index: 2;
  }

  .hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-text);
    border-radius: var(--radius-sm);
  }

  /* ── Nav Links (desktop) ── */
  .nav-links {
    display: flex;
    position: relative;
  }

  .nav-item {
    position: static;
  }

  .nav-link {
    position: relative;
    display: block;
    padding: 10px 24px 16px;
    font-size: var(--text-sm);
    font-weight: 600;
    line-height: 1.4;
    color: var(--color-text);
    transition: color var(--duration-fast) ease;
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
  }

  /* Invisible hover extension below each nav-link — only covers this item's width */
  .nav-link::before {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    height: 28px;
  }

  .nav-link:hover {
    color: var(--color-brand);
  }

  @media (min-width: 1024px) {
    .nav-link::after {
      content: '';
      display: block;
      position: absolute;
      bottom: 8px;
      left: 0.8rem;
      width: calc(100% - 1.6rem);
      height: 3px;
      border-radius: var(--radius-sm);
      background: transparent;
      transition: background-color 0.2s ease;
      pointer-events: none;
    }
    .nav-item:hover > .nav-link::after {
      background-color: var(--color-brand);
    }
  }

  /* ── Mega Menu ── */
  .mega-menu {
    visibility: hidden;
    opacity: 0;
    transform: scaleY(0.85);
    transform-origin: top center;
    position: absolute;
    left: -32px;
    right: -32px;
    top: 100%;
    z-index: 9;
    pointer-events: none;
    backface-visibility: hidden;
    /* Exit: fast slide up + compress + fade out */
    transition:
      visibility 0s 0.15s,
      opacity 0.15s ease,
      transform 0.15s ease;
  }

  .nav-item:hover .mega-menu {
    visibility: visible;
    opacity: 1;
    transform: scaleY(1);
    pointer-events: auto;
    z-index: 10;
    /* Enter: slow extend downward + fade in */
    transition:
      visibility 0s 0s,
      opacity 1.5s cubic-bezier(0.12, 0.9, 0.2, 1),
      transform 1.5s cubic-bezier(0.12, 0.9, 0.2, 1);
  }

  .mega-menu-inner {
    background: #ffffff;
    padding: var(--space-md) var(--space-lg);
    overflow: hidden;
  }

  .mega-menu-content {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .mega-link {
    display: inline-block;
    padding: 6px 0;
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--color-text-soft);
    text-decoration: none;
    transition: color var(--duration-fast) ease;
    width: auto;
  }

  .mega-link:hover {
    color: var(--color-brand);
  }

  /* ── Multi-column grid menus ── */
  .mega-menu-grid {
    display: grid;
    gap: var(--space-xl);
  }

  .grid-2col {
    grid-template-columns: 1fr 1fr;
  }

  .grid-3col {
    grid-template-columns: 1fr 1fr 1fr;
  }

  .grid-4col {
    grid-template-columns: 1fr 1fr 1fr 1fr;
  }

  .mega-menu-column {
    display: flex;
    flex-direction: column;
  }

  .mega-menu-title {
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-text);
    padding: 8px 0 4px;
    margin-bottom: 6px;
  }

  .mega-menu-subcols {
    display: flex;
    gap: var(--space-xl);
  }

  .mega-menu-subcol {
    display: flex;
    flex-direction: column;
  }

  /* ── Mobile Menu ── */
  .mobile-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: oklch(0% 0 0 / 0.3);
    z-index: 98;
  }
  .mobile-overlay.open { display: block; }

  .mobile-menu {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 80%;
    max-width: 360px;
    background: #ffffff;
    z-index: 99;
    padding: 80px var(--space-lg) var(--space-lg);
    overflow-y: auto;
    box-shadow: 2px 0 16px oklch(0% 0 0 / 0.08);
  }
  .mobile-menu.open { display: block; }

  .mobile-close {
    position: absolute;
    top: 20px;
    right: var(--space-lg);
    font-size: 1.8rem;
    border: none;
    background: none;
    cursor: pointer;
    color: var(--color-text);
    line-height: 1;
  }

  :global(.mobile-section) {
    border-bottom: 1px solid #f0f0f0;
  }

  :global(.mobile-section-header) {
    padding: 16px 0;
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--color-text);
    cursor: pointer;
    position: relative;
    letter-spacing: 0.02em;
  }

  :global(.mobile-section-header::after) {
    content: '+';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.2rem;
    color: var(--color-text-muted);
    transition: transform 0.2s;
  }

  :global(.mobile-section-header.active::after) {
    content: '−';
    color: var(--color-brand);
  }

  :global(.mobile-section-body) {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows var(--duration-medium) var(--ease-out-expo);
  }

  :global(.mobile-section-body.open) {
    grid-template-rows: 1fr;
  }

  :global(.mobile-section-body-inner) {
    overflow: hidden;
  }

  :global(.mobile-section-link) {
    display: block;
    padding: 12px 0 12px var(--space-md);
    font-size: 0.95rem;
    font-weight: 300;
    color: var(--color-text-soft);
    text-decoration: none;
    border-top: 1px solid var(--color-border-light);
  }

  :global(.mobile-section-link:hover) {
    color: var(--color-brand-dark);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .nav-inner {
      position: relative;
      justify-content: center;
    }

    .nav-hamburger {
      display: flex;
      position: absolute;
      left: 0;
    }

    .nav-links {
      display: none;
    }
  }
</style>
</nav>
