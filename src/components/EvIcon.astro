  arrow: '<path d="M5 12h13M13 6l6 6-6 6"/>',
};
const inner = P[name] || '';
---
<svg class={`evicon ${cls}`} width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={inner}></svg>

<style>
  .evicon { display: inline-block; flex-shrink: 0; vertical-align: middle; }
</style>
