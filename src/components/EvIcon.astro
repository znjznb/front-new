  users: '<circle cx="9" cy="8.5" r="3"/><path d="M3.5 19a5.5 5.5 0 0 1 11 0"/><path d="M16 6.2a3 3 0 0 1 0 5.6M16.5 14a5.5 5.5 0 0 1 4 5"/>',
  calendar: '<rect x="4" y="5.5" width="16" height="15" rx="1.5"/><path d="M4 9.5h16M8 3.5v4M16 3.5v4"/><path d="M8.5 14h2M13.5 14h2M8.5 17h2M13.5 17h2"/>',
  shell: '<path d="M12 20C6 16 3.5 11 5 7c4-2 10-2 14 0 1.5 4-1 9-7 13z"/><path d="M12 20c0-5-1-9-3-13M12 20c0-5 1-9 3-13M12 20c0-5 0-9 0-13"/>',
  molecule: '<circle cx="6" cy="17" r="2.2"/><circle cx="18" cy="17" r="2.2"/><circle cx="12" cy="6.5" r="2.2"/><path d="M7.8 15.6 10.4 8M13.6 8l2.6 7.6M8.2 17h7.6"/>',
