---
// 14 家研究医院 · 全国分布图（真实中国省界 SVG + 真实经纬度标点）
import { CHINA_VIEWBOX, CHINA_PATHS, CHINA_HOSPITALS } from '../data/china-map.js';

const regionColor = {
  华北: '#1f7a8c',
  华东: '#3a6ea5',
  华中: '#7b5ea7',
  西南: '#e07a3f',
  东北: '#2b3a67',
};
const regions = ['华北', '华东', '华中', '西南', '东北'];
const byRegion = regions.map((r) => ({
  region: r,
  color: regionColor[r],
  list: CHINA_HOSPITALS.filter((h) => h.region === r),
}));
---

<div class="evmap">
  <div class="evmap-stage">
    <svg viewBox={CHINA_VIEWBOX} class="evmap-svg" role="img" aria-label="14 家研究医院全国分布图（真实中国地图）">
      <g class="evmap-land">
        {CHINA_PATHS.map((d) => <path d={d}></path>)}
      </g>
      {CHINA_HOSPITALS.map((h) => {
        const sub = `${h.region}${h.note ? ' · ' + h.note : ''}`;
        // 名称 30px/字、副标题 22px/字，取较宽的一行 + 内边距，确保背景始终包住文字
        const w = Math.max(h.name.length * 30, sub.length * 22) + 48;
        return (
          <g class="evmap-pin" tabindex="0" aria-label={`${h.name}（${h.region}）`}>
            <circle class="evmap-halo" cx={h.x} cy={h.y} r="14" style={`fill:${regionColor[h.region]}`}></circle>
            <circle class="evmap-dot" cx={h.x} cy={h.y} r="6.5" style={`fill:${regionColor[h.region]}`}></circle>
            <g class="evmap-tip" transform={`translate(${h.x}, ${h.y})`}>
              <rect x={-w / 2} y="-92" width={w} height="68" rx="12"></rect>
              <text x="0" y="-60" text-anchor="middle" class="evmap-tip-name">{h.name}</text>
              <text x="0" y="-36" text-anchor="middle" class="evmap-tip-sub">{sub}</text>
              <path class="evmap-tip-arrow" d="M-11 -24 L11 -24 L0 -12 Z"></path>
            </g>
          </g>
        );
      })}
    </svg>
  </div>

  <!-- 图示：一个点代表一家医院 -->
  <div class="evmap-legend">
    {byRegion.map((grp) => (
      <div class="evmap-legend-col" style={`--rc:${grp.color}`}>
        <div class="evmap-legend-region">{grp.region}<em>{grp.list.length} 家</em></div>
        {grp.list.map((h) => (
          <span class="evmap-legend-item">{h.name}{h.note ? `（${h.note}）` : ''}</span>
        ))}
      </div>
    ))}
  </div>
</div>

<style>
  .evmap { width: 100%; }
  .evmap-stage { width: 100%; max-width: 700px; margin: 0 auto; }
  .evmap-svg { width: 100%; height: auto; overflow: visible; }
  .evmap-land path {
    fill: var(--color-bg-alt);
    stroke: var(--color-border);
    stroke-width: 0.8;
    stroke-linejoin: round;
  }
  .evmap-pin { cursor: pointer; outline: none; }
  .evmap-halo {
    opacity: 0.18;
    transform-box: fill-box;
    transform-origin: center;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .evmap-dot { transition: r 0.2s ease; }
  .evmap-pin:hover .evmap-halo,
  .evmap-pin:focus .evmap-halo { opacity: 0.34; transform: scale(1.3); }
  /* hover 信息卡：字号放大，确保看得清 */
  .evmap-tip { opacity: 0; pointer-events: none; transition: opacity 0.2s ease; }
  .evmap-pin:hover .evmap-tip,
  .evmap-pin:focus .evmap-tip { opacity: 1; }
  .evmap-tip rect { fill: var(--color-text); }
  .evmap-tip-arrow { fill: var(--color-text); }
  .evmap-tip-name { fill: #fff; font-size: 30px; font-weight: 600; }
  .evmap-tip-sub { fill: rgba(255, 255, 255, 0.78); font-size: 22px; }
  /* 图示：5 区等宽列，一个点 = 一家医院 */
  .evmap-legend {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-xl);
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border-light);
  }
  .evmap-legend-col { display: flex; flex-direction: column; gap: 10px; }
  .evmap-legend-region {
    display: flex; align-items: center; gap: 7px;
    font-size: 0.875rem; font-weight: 600; color: var(--color-text);
  }
  .evmap-legend-region::before {
    content: ''; width: 10px; height: 10px; border-radius: 50%;
    background: var(--rc); flex-shrink: 0;
  }
  .evmap-legend-region em { font-style: normal; color: var(--color-text-muted); font-weight: 400; font-size: 0.8125rem; }
  .evmap-legend-item {
    font-size: 0.8125rem; color: var(--color-text-soft); line-height: 1.5; padding-left: 17px;
  }
  @media (max-width: 860px) {
    .evmap-legend { grid-template-columns: repeat(2, 1fr); gap: var(--space-lg); }
  }
  @media (max-width: 480px) {
    .evmap-legend { grid-template-columns: 1fr; }
  }
</style>
