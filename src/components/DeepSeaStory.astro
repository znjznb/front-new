---
// Brand story editorial panels – Aesop-inspired layout
// Panel 1: text left 50% / landscape image right 50%
// Panel 2: near-square image left 40% / text right 60%
// Panel 3: text left 60% / near-square image right 40%
---

<section id="story" class="story">

  <!-- Panel 1: Our Story — text left, landscape image right -->
  <div class="story-panel sp1">
    <div class="sp1-text story-text">
      <span class="story-eyebrow">我们的故事</span>
      <p class="story-year">海得宝成立于2014年</p>
      <p class="story-body">海得宝一直秉持坚定的信念，开发一系列专业肌肤及身体护理产品。我们致力于在科学验证功效的基础上，用独家专利成分贻贝钙肽CAPCS。所有配方有效亦安全。</p>
      <p class="story-body">因为爱家人，呵护敏感肌家庭。所以选择最严苛的实验，用科研践行“用心呵护敏感，用爱温暖家庭”的承诺。</p>
    </div>
    <div class="sp1-visual story-visual reveal">
      <img class="story-img" src="/assets/story-origin.webp" alt="海得宝 · 我们的故事" loading="eager" width="972" height="610" />
    </div>
  </div>

  <!-- Panel 2: Family — near-square image left, text right -->
  <div class="story-panel sp2">
    <div class="sp2-visual story-visual reveal">
      <img class="story-img" src="/assets/lifestyle-mother.webp" alt="海得宝 · 家庭温暖呵护" loading="lazy" width="751" height="712" />
    </div>
    <div class="sp2-text story-text">
      <span class="story-eyebrow">家庭的温暖陪伴者</span>
      <h2 class="story-title">照顾每一个家庭成员的敏感需求</h2>
      <p class="story-body">海得宝的产品线覆盖婴童、女性、成人等全年龄段。以同一核心成分贻贝钙CAPCS®为基础，针对不同肤质和使用场景进行研发，实现从面部到身体、从急性舒缓到长期维稳的完整护理方案。</p>
      <a href="/products/series" class="story-cta">
        <span>探索产品线</span>
        <i class="story-cta-arrow">→</i>
      </a>
    </div>
  </div>

  <!-- Panel 3: Trust — text left, near-square image right -->
  <div class="story-panel sp3">
    <div class="sp3-text story-text">
      <span class="story-eyebrow">陪伴式的信赖</span>
      <p class="story-body">海得宝专业护肤顾问将1v1接待用户</p>
      <p class="story-body">不只是服务，更是倾听，帮助您与家人修护肌肤状态</p>
      <p class="story-body">当您在使用中遇到任何困惑，我们都在线</p>
      <p class="story-body">为您提供贴心、增值服务，以提升您的护肤体验</p>
      <a href="#" class="story-cta">
        <span>更多会员服务</span>
        <i class="story-cta-arrow">→</i>
      </a>
    </div>
    <div class="sp3-visual story-visual reveal">
      <img class="story-img" src="/assets/lab.jpg" alt="海得宝 · 专业服务" loading="lazy" width="751" height="712" />
    </div>
  </div>

</section>

<style>
  /* ── Section ───────────────────────────────────────────── */
  .story {
    position: relative;
    background: var(--color-surface);
    padding-top: var(--space-6xl);
    /* Always full-width — images bleed to viewport edges */
  }

  /* ── Panel shared ──────────────────────────────────────── */
  .story-panel {
    display: flex;
    align-items: stretch;
    padding-bottom: var(--space-4xl); /* ~100px */
  }

  /* ── Panel 1 ───────────────────────────────────────────── */
  /* Text left (flex:1), landscape image right (50%, max 800px) */
  .sp1 {
    align-items: flex-start;
  }

  .sp1-text {
    flex: 1;
    min-width: 320px;
    min-height: 400px;
    padding-top: var(--space-5xl);
    padding-right: var(--space-4xl);
    padding-bottom: var(--space-3xl);
    /* Left aligns with the rest of the page's content grid */
    padding-left: clamp(var(--space-3xl), calc((100vw - 1200px) / 2), var(--space-6xl));
  }

  .sp1-visual {
    width: 50%;
    max-width: 972px; /* never grows beyond Aesop 1 native size */
    flex-shrink: 0;
    overflow: hidden;
  }

  .sp1-visual .story-img {
    /* Landscape ratio matching Aesop 1: 972×610 */
    aspect-ratio: 972 / 610;
    width: 100%;
    object-fit: cover;
    object-position: center 25%;
    display: block;
  }

  /* ── Panel 2 ───────────────────────────────────────────── */
  /* Near-square image left 40% (max 640px), text right */
  .sp2-visual {
    width: 40%;
    max-width: 751px; /* never grows beyond Aesop 2 native size */
    flex-shrink: 0;
    overflow: hidden;
  }

  .sp2-visual .story-img {
    /* Near-square ratio matching Aesop 2: 751×712 */
    aspect-ratio: 751 / 712;
    width: 100%;
    object-fit: cover;
    object-position: center 48%;
    display: block;
  }

  .sp2-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-left: var(--space-4xl);
    padding-right: clamp(var(--space-3xl), calc((100vw - 1200px) / 2), var(--space-6xl));
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-2xl);
  }

  /* ── Panel 3 ───────────────────────────────────────────── */
  /* Text left, near-square image right 40% (max 640px) */
  .sp3 {
    justify-content: space-between;
  }

  .sp3-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-left: clamp(var(--space-3xl), calc((100vw - 1200px) / 2), var(--space-6xl));
    padding-right: var(--space-4xl);
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-2xl);
  }

  .sp3-visual {
    width: 40%;
    max-width: 751px; /* never grows beyond Aesop 3 native size */
    flex-shrink: 0;
    display: flex;
    justify-content: flex-end;
    overflow: hidden;
  }

  .sp3-visual .story-img {
    /* Near-square ratio matching Aesop 3: 751×712 */
    aspect-ratio: 751 / 712;
    width: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }

  /* ── Typography ────────────────────────────────────────── */
  /* Aesop contrast: title ~26px, body ~13px (2:1 ratio) */

  .story-eyebrow {
    display: block;
    font-size: 1.875rem;        /* 30px */
    font-weight: 300;
    line-height: 1.3;
    letter-spacing: 0.01em;
    color: var(--color-text);
    margin-bottom: var(--space-xl);
  }

  .story-lead {
    font-size: 0.9375rem;       /* 15px */
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-text-soft);
    max-width: 380px;
    margin-bottom: var(--space-xl);
  }

  .story-year {
    font-size: 0.9375rem;       /* 15px */
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-text-soft);
    max-width: 380px;
    margin-bottom: var(--space-xl);
  }

  .story-title {
    font-size: 1.875rem;        /* 30px */
    font-weight: 300;
    line-height: 1.6;
    letter-spacing: 0.01em;
    color: var(--color-text);
    margin-bottom: var(--space-xl);
  }

  .story-body {
    font-size: 0.9375rem;       /* 15px */
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-text-soft);
    margin-bottom: var(--space-lg);
    max-width: 42ch;
  }

  .story-body:last-of-type {
    margin-bottom: 0;
  }

  /* ── CTA button (Aesop-style border button) ────────────── */
  .story-cta {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
    margin-top: var(--space-2xl);
    padding: 0 var(--space-md);
    height: 40px;
    width: max-content;
    min-width: 120px;
    border: 1px solid rgba(15, 15, 15, 0.2);
    border-radius: var(--radius);
    color: var(--color-text);
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: background 0.3s ease, color 0.3s ease;
  }

  .story-cta:hover {
    background: var(--color-text);
    color: var(--color-surface);
  }

  .story-cta-arrow {
    font-style: normal;
    font-size: 0.75rem;
  }

  /* ── Image parallax ────────────────────────────────────── */
  .story-img {
    will-change: transform;
    transition: transform 0.1s linear;
  }

  /* ── Mobile ────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .story {
      padding-top: var(--space-4xl);
    }

    /* All panels stack: image on top, text below */
    .sp1 { flex-direction: column-reverse; } /* text first in DOM → reverse puts image on top */
    .sp2 { flex-direction: column; }         /* image first in DOM → column keeps image on top */
    .sp3 { flex-direction: column-reverse; } /* text first in DOM → reverse puts image on top */

    .sp1-text, .sp2-text, .sp3-text {
      width: 100%;
      padding: var(--space-xl) var(--content-padding);
      min-height: 0;
    }

    .sp1-visual, .sp2-visual, .sp3-visual {
      width: 100%;
    }

    .sp1-visual .story-img,
    .sp2-visual .story-img,
    .sp3-visual .story-img {
      aspect-ratio: auto;
      height: auto;
    }

    .story-panel {
      padding-bottom: var(--space-3xl);
    }

    .story-eyebrow,
    .story-title {
      font-size: 1.25rem;
    }

    .story-body,
    .story-lead {
      max-width: 100%;
      font-size: 0.875rem;
    }

    .story-cta {
      width: 100%;
    }
  }
</style>

<script>
  // Subtle parallax on scroll: images translate slightly as page scrolls
  function updateParallax() {
    document.querySelectorAll('.story-visual').forEach(function(container) {
      var img = container.querySelector('.story-img');
      if (!img) return;
      var rect = container.getBoundingClientRect();
      var vh = window.innerHeight;
      // progress: -1 (above viewport) → 0 (center) → 1 (below)
      var progress = (rect.top + rect.height / 2 - vh / 2) / (vh * 0.8);
      var offset = progress * 24; // max 24px shift
      img.style.transform = 'translateY(' + offset + 'px) scale(1.04)';
    });
  }

  if (window.matchMedia('(prefers-reduced-motion: no-preference)').matches) {
    window.addEventListener('scroll', updateParallax, { passive: true });
    updateParallax();
  }
</script>
