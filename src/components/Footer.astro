<script>
document.addEventListener('DOMContentLoaded', () => {
  const qrOverlay = document.getElementById('qrOverlay');
  const verifyOverlay = document.getElementById('verifyOverlay');
  const verifyClose = document.getElementById('verifyClose');

  document.querySelectorAll('.js-qr-trigger').forEach(el => {
    el.addEventListener('click', () => {
      qrOverlay.classList.add('open');
    });
  });

  qrOverlay.addEventListener('click', () => {
    qrOverlay.classList.remove('open');
  });

  document.querySelectorAll('.js-verify-trigger').forEach(el => {
    el.addEventListener('click', () => {
      verifyOverlay.classList.add('open');
      document.body.style.overflow = 'hidden';
    });
  });

  function closeVerify() {
    verifyOverlay.classList.remove('open');
    document.body.style.overflow = '';
  }

  verifyOverlay.addEventListener('click', closeVerify);
  if (verifyClose) verifyClose.addEventListener('click', closeVerify);
});
</script>

<style>
  .footer {
    background: var(--color-brand);
    padding: var(--space-4xl) var(--content-padding) var(--space-xl);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 120px 1fr 1fr 1fr 1fr;
    gap: var(--space-4xl) var(--space-4xl);
    padding-bottom: var(--space-3xl);
    border-bottom: 1px solid oklch(95% 0.04 185);
  }

  .footer-logo-col {
    display: flex;
    align-items: flex-start;
    padding-top: 4px;
  }

  .footer-logo-img {
    display: block;
    width: 120px;
    height: auto;
    filter: brightness(0) invert(1);
    -webkit-filter: brightness(0) invert(1);
  }

  .footer-social-item {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
    color: #ffffff;
    font-size: var(--text-sm);
    font-weight: 400;
    margin-bottom: var(--space-md);
    transition: opacity var(--duration-fast) ease;
  }

  .footer-social-item:hover {
    opacity: 0.7;
  }

  .footer-social-icon {
    display: block;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
    filter: brightness(0) invert(1);
    -webkit-filter: brightness(0) invert(1);
    object-fit: contain;
  }

  .footer-social-douyin {
    display: block;
    width: 20px;
    height: 20px;
    border-radius: 4px;
    background: #ffffff;
    flex-shrink: 0;
    position: relative;
  }

  .footer-social-douyin-icon {
    position: absolute;
    inset: 0;
    background: var(--color-brand);
    mask-image: url('/tik%20tok.svg');
    mask-size: contain;
    mask-repeat: no-repeat;
    -webkit-mask-image: url('/tik%20tok.svg');
    -webkit-mask-size: contain;
    -webkit-mask-repeat: no-repeat;
  }

.footer-col-title {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-lg);
    color: #ffffff;
  }

  .footer-link {
    display: block;
    font-size: var(--text-sm);
    font-weight: 400;
    color: #ffffff;
    text-decoration: none;
    margin-bottom: var(--space-md);
    transition: opacity var(--duration-fast) ease;
  }

  .footer-link:hover {
    opacity: 0.7;
  }

  .footer-link-btn {
    display: block;
    font-size: var(--text-sm);
    font-weight: 400;
    color: #ffffff;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    font-family: inherit;
    text-align: left;
    margin-bottom: var(--space-md);
    transition: opacity var(--duration-fast) ease;
  }

  .footer-link-btn:hover {
    opacity: 0.7;
  }

  .footer-bottom {
    padding-top: var(--space-lg);
    text-align: center;
  }

  .footer-bottom-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .footer-copy {
    font-size: var(--text-xs);
    font-weight: 400;
    color: #ffffff;
  }

  .footer-address {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-size: var(--text-xs);
    font-weight: 400;
    color: #ffffff;
    margin-top: var(--space-sm);
  }

  .footer-address-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    fill: #ffffff;
  }

  .footer-icp {
    font-size: var(--text-xs);
    font-weight: 400;
    color: #ffffff;
    text-decoration: none;
    transition: color var(--duration-fast) ease;
  }

  .footer-icp:hover {
    color: #ffffff;
  }

  /* ── QR Overlay ── */
  .qr-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: oklch(0% 0 0 / 0.4);
    z-index: var(--z-modal);
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .qr-overlay.open {
    display: flex;
  }

  .qr-popup {
    background: #ffffff;
    padding: 20px;
    border-radius: var(--radius);
    box-shadow: 0 8px 32px oklch(0% 0 0 / 0.2);
    cursor: default;
  }

  .qr-popup-img {
    display: block;
    width: 200px;
    height: auto;
    max-width: none;
  }

  /* ── Verification Overlay ── */
  .verify-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: oklch(0% 0 0 / 0.5);
    z-index: var(--z-modal);
    align-items: center;
    justify-content: center;
    cursor: pointer;
    padding: var(--space-lg);
  }

  .verify-overlay.open {
    display: flex;
  }

  .verify-popup {
    position: relative;
    background: #ffffff;
    border-radius: var(--radius);
    max-width: 560px;
    width: 100%;
    max-height: 85vh;
    overflow-y: auto;
    cursor: default;
    box-shadow: 0 8px 40px oklch(0% 0 0 / 0.25);
  }

  .verify-close {
    position: sticky;
    top: 0;
    float: right;
    margin: 8px 12px 0 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    line-height: 1;
    color: var(--color-text-muted);
    background: oklch(100% 0 0 / 0.85);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    z-index: 1;
    transition: color var(--duration-fast) ease;
  }

  .verify-close:hover {
    color: var(--color-text);
  }

  .verify-img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
    }

    .verify-popup {
      max-height: 90vh;
      max-width: 100%;
    }
  }
</style>
