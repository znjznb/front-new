<style>
  .footer {
    background: oklch(70% 0.18 185);
    color: #ffffff;
    padding: var(--space-4xl) var(--content-padding) var(--space-xl);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-4xl) var(--space-4xl);
    padding-bottom: var(--space-3xl);
    border-bottom: 1px solid oklch(80% 0.12 185);
  }

  .footer-brand-col {
    display: flex;
    flex-direction: column;
  }

  .footer-logo-img {
    display: block;
    width: 100px;
    height: auto;
    filter: brightness(0) invert(1);
    -webkit-filter: brightness(0) invert(1);
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .footer-col-title {
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-lg);
    color: #ffffff;
  }

  .footer-link {
    display: block;
    font-size: var(--text-sm);
    font-weight: 400;
    color: oklch(93% 0.04 185);
    text-decoration: none;
    margin-bottom: var(--space-md);
    transition: color var(--duration-fast) ease;
  }

  .footer-link:hover {
    color: #ffffff;
  }

  .footer-social {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    gap: 8px;
    padding-top: var(--space-sm);
  }

  .footer-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    transition: opacity var(--duration-fast) ease;
    text-decoration: none;
  }

  .footer-social-link:hover .footer-social-icon {
    opacity: 0.75;
  }

  .footer-social-icon {
    display: block;
    width: 22px;
    height: 22px;
    filter: brightness(0) invert(1);
    -webkit-filter: brightness(0) invert(1);
    transition: opacity var(--duration-fast) ease;
  }

  .footer-social-wechat {
    position: relative;
  }

  .wechat-popup {
    visibility: hidden;
    opacity: 0;
    position: absolute;
    bottom: calc(100% + 12px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    background: #ffffff;
    padding: 8px;
    border-radius: 8px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.15);
    transition: opacity 0.3s ease, transform 0.3s ease, visibility 0s 0.3s;
    z-index: 10;
  }

  .wechat-popup::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 6px solid transparent;
    border-top-color: #ffffff;
  }

  .footer-social-wechat:hover .wechat-popup {
    visibility: visible;
    opacity: 1;
    transform: translateX(-50%) translateY(0);
    transition: opacity 0.3s ease, transform 0.3s ease, visibility 0s 0s;
  }

  .wechat-popup-img {
    display: block;
    width: 136px;
    height: auto;
    max-width: none;
  }

  .footer-bottom {
    padding-top: var(--space-lg);
  }

  .footer-copy {
    font-size: var(--text-xs);
    font-weight: 400;
    color: oklch(90% 0.04 185);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
    .footer-links {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>
