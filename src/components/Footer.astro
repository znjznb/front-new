        <a href="https://haidebaomy.tmall.com/?spm=a1z10.5-b-s.w15914064-24941704239.6.1e8877bdPyAuWS&scene=taobao_shop" target="_blank" rel="noopener noreferrer" class="footer-social-link" aria-label="天猫">
          <img src="/天猫.svg" alt="天猫" class="footer-social-icon" />
        </a>
        <a href="https://weibo.com/u/6207838250" target="_blank" rel="noopener noreferrer" class="footer-social-link" aria-label="微博">
