---
// Hero: Full-screen brand entry
---

<section class="hero section-full">
  <div class="hero-bg-video" aria-hidden="true">
    <video
      class="hero-video"
      src="/assets/brand-video.mp4"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
    ></video>
    <div class="hero-video-overlay"></div>
  </div>
  <div class="hero-body">
    <div class="hero-center">
      <h1 class="hero-logo">
        <img
          src="/assets/logo.png"
          alt="海得宝 MARTEMPO"
          class="hero-logo-img"
          width="600"
          height="200"
        />
      </h1>
      <p class="hero-subtitle">
        敏感肌家庭的专业功效护肤品牌
      </p>
      <p class="hero-desc">
        贻贝钙肽CAPCS® 专研根源修护成分<br />
        1000+ 公立医院皮肤科临床选用
      </p>
    </div>
    <div class="hero-bottom">
      <div class="hero-actions">
        <a href="#story" class="btn btn-outline">探索品牌故事</a>
      </div>
      <div class="hero-scroll-hint" aria-hidden="true">
        <span class="hero-scroll-text">滚动探索</span>
        <span class="hero-scroll-line"></span>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Section: override .section-full centering → column filling viewport ── */
  .hero {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    padding: 0;
    min-height: 100vh;
  }

  .hero-bg-video {
    position: absolute;
    top: 82px;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 0;
  }

  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-video-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      oklch(0% 0 0 / 0.55) 0%,
      oklch(0% 0 0 / 0.35) 50%,
      oklch(0% 0 0 / 0.6) 100%
    );
  }

  /* ── Flex column that fills the section ── */
  .hero-body {
    position: relative;
    z-index: 1;
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    padding: 120px var(--content-padding) 0;
  }

  /* ── Center block: grows to fill space, centers logo+text ── */
  .hero-center {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    max-width: 800px;
    width: 100%;
  }

  .hero-logo {
    margin-bottom: var(--space-xl);
  }

  .hero-logo-img {
    display: block;
    width: clamp(240px, 50vw, 520px);
    height: auto;
    margin: 0 auto;
  }

  .hero-subtitle {
    font-size: var(--text-2xl);
    font-weight: 300;
    letter-spacing: var(--tracking-wide);
    color: #fff;
    text-shadow: 0 2px 16px rgba(0,0,0,0.4);
    margin-bottom: var(--space-lg);
    width: clamp(240px, 50vw, 520px);
  }

  .hero-desc {
    font-size: var(--text-base);
    font-weight: 400;
    color: rgba(255,255,255,0.85);
    text-shadow: 0 1px 12px rgba(0,0,0,0.35);
    line-height: var(--leading-relaxed);
    margin-bottom: 0;
  }

  /* ── Bottom block: sits at viewport bottom ── */
  .hero-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
    padding-bottom: var(--space-2xl);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-actions .btn-primary {
    background: white;
    color: var(--color-text);
    border-color: white;
  }

  .hero-actions .btn-primary:hover {
    background: transparent;
    color: white;
    transform: scale(1.03);
  }

  .hero-actions .btn-outline {
    border-color: rgba(255,255,255,0.6);
    color: rgba(255,255,255,0.9);
  }

  .hero-actions .btn-outline:hover {
    background: white;
    color: var(--color-text);
    border-color: white;
    transform: scale(1.03);
  }

  .hero-scroll-hint {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    opacity: 0.4;
  }

  .hero-scroll-text {
    font-size: 0.625rem;
    font-weight: 400;
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
  }

  .hero-scroll-line {
    width: 1px;
    height: 32px;
    background: rgba(255,255,255,0.5);
    animation: scrollPulse 2s var(--ease-out-expo) infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.5); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  @media (max-width: 768px) {
    .hero-body {
      padding-top: 100px;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .hero-bottom {
      padding-bottom: var(--space-lg);
      gap: var(--space-lg);
    }
  }
</style>
