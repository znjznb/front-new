---
// 贻贝钙肽 CAPCS 分子作用机制 · 流程图（暗色板块内使用）
const mechs = [
  { y: 12, t: '抑制 4 大炎症通路', s: 'Th1 · Th2 · Th17 · Th22 炎症因子' },
  { y: 100, t: '调节 TLR2 / TLR4 信号', s: '纠正免疫异常 · 抗金黄色葡萄球菌' },
  { y: 188, t: '“双重杀菌”机制', s: 'AMP 开膜 ＋ 钙离子涌入致死' },
  { y: 276, t: '调节瘙痒信号（止痒）', s: '钙离子 · GPCR · 信号素 3A' },
];
const NW = 300, NH = 72;
const cap = { x: 30, y: 135, w: 210, h: 90 };
const out = { x: 730, y: 125, w: 200, h: 110 };
---

<figure class="mechdiag">
  <svg viewBox="0 0 960 360" role="img" aria-label="贻贝钙肽 CAPCS 分子作用机制流程图" class="mechdiag-svg">
    <defs>
      <marker id="mdarrow" markerWidth="9" markerHeight="9" refX="7" refY="4.5" orient="auto">
        <path d="M1 1 L7.5 4.5 L1 8" fill="none" stroke="rgba(255,255,255,0.45)" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path>
      </marker>
    </defs>

    <!-- 连接线：CAPCS → 各机制 -->
    {mechs.map((m) => (
      <path
        class="mechdiag-link"
        d={`M${cap.x + cap.w} ${cap.y + cap.h / 2} C ${cap.x + cap.w + 60} ${cap.y + cap.h / 2}, ${375 - 60} ${m.y + NH / 2}, ${375} ${m.y + NH / 2}`}
        marker-end="url(#mdarrow)"
      ></path>
    ))}
    <!-- 连接线：各机制 → 结果 -->
    {mechs.map((m) => (
      <path
        class="mechdiag-link"
        d={`M${375 + NW} ${m.y + NH / 2} C ${375 + NW + 55} ${m.y + NH / 2}, ${out.x - 55} ${out.y + out.h / 2}, ${out.x} ${out.y + out.h / 2}`}
        marker-end="url(#mdarrow)"
      ></path>
    ))}

    <!-- CAPCS 来源节点 -->
    <g class="mechdiag-node mechdiag-source">
      <rect x={cap.x} y={cap.y} width={cap.w} height={cap.h} rx="14"></rect>
      <text x={cap.x + cap.w / 2} y={cap.y + 38} text-anchor="middle" class="mechdiag-title-lg">贻贝钙肽 CAPCS</text>
      <text x={cap.x + cap.w / 2} y={cap.y + 64} text-anchor="middle" class="mechdiag-sub-light">活性钙 Ca²⁺ ＋ 抗菌肽 AMP</text>
    </g>

    <!-- 4 个机制节点 -->
    {mechs.map((m) => (
      <g class="mechdiag-node">
        <rect x="375" y={m.y} width={NW} height={NH} rx="12"></rect>
        <text x={375 + NW / 2} y={m.y + 31} text-anchor="middle" class="mechdiag-title">{m.t}</text>
        <text x={375 + NW / 2} y={m.y + 53} text-anchor="middle" class="mechdiag-sub">{m.s}</text>
      </g>
    ))}

    <!-- 结果节点 -->
    <g class="mechdiag-node mechdiag-out">
      <rect x={out.x} y={out.y} width={out.w} height={out.h} rx="14"></rect>
      <text x={out.x + out.w / 2} y={out.y + 46} text-anchor="middle" class="mechdiag-title-lg">修复皮肤屏障</text>
      <text x={out.x + out.w / 2} y={out.y + 72} text-anchor="middle" class="mechdiag-sub-light">缓解特应性皮炎 AD</text>
    </g>
  </svg>
  <figcaption>贻贝钙肽 CAPCS 分子作用机制示意（基于华西医院 IJMS 2022 机理研究）</figcaption>
</figure>

<style>
  .mechdiag { margin: 0; }
  .mechdiag-svg { width: 100%; height: auto; overflow: visible; }
  .mechdiag-link { fill: none; stroke: rgba(255, 255, 255, 0.22); stroke-width: 1.4; }
  .mechdiag-node rect { fill: rgba(255, 255, 255, 0.05); stroke: rgba(255, 255, 255, 0.2); stroke-width: 1; }
  .mechdiag-source rect { fill: var(--color-brand); stroke: var(--color-brand); }
  .mechdiag-out rect { fill: rgba(31, 122, 140, 0.28); stroke: var(--color-brand); stroke-width: 1.4; }
  .mechdiag-title-lg { fill: #fff; font-size: 19px; font-weight: 600; }
  .mechdiag-title { fill: #fff; font-size: 16px; font-weight: 500; }
  .mechdiag-sub { fill: rgba(255, 255, 255, 0.62); font-size: 12.5px; }
  .mechdiag-sub-light { fill: rgba(255, 255, 255, 0.82); font-size: 12.5px; }
  .mechdiag figcaption { margin-top: var(--space-md); font-size: 0.75rem; color: rgba(255, 255, 255, 0.55); text-align: center; }
  @media (max-width: 640px) {
    .mechdiag-title { font-size: 18px; }
    .mechdiag-sub, .mechdiag-sub-light { font-size: 14px; }
    .mechdiag-title-lg { font-size: 21px; }
  }
</style>
