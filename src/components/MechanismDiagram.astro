---
// 贻贝钙肽 CAPCS 分子作用机制 · 流程图（暗色板块内使用）
const mechs = [
  { y: 44, t: '抑制 4 大炎症通路', s: 'Th1 · Th2 · Th17 · Th22 炎症因子' },
  { y: 132, t: '调节 TLR2 / TLR4 信号', s: '纠正免疫异常 · 抗金黄色葡萄球菌' },
  { y: 220, t: '“双重杀菌”机制', s: 'AMP 开膜 ＋ 钙离子涌入致死' },
  { y: 308, t: '调节瘙痒信号（止痒）', s: '钙离子 · GPCR · 信号素 3A' },
];
const NW = 300, NH = 70;
const MX = 380;                 // 机制节点左缘
const cap = { x: 40, y: 168, w: 210, h: 96 };
const out = { x: 775, y: 166, w: 190, h: 100 };
const LBUS = 315, RBUS = 745;   // 左右汇流总线 x
const cy = (m) => m.y + NH / 2; // 机制节点中心 y
const topC = cy(mechs[0]), botC = cy(mechs[mechs.length - 1]);
---

<figure class="mechdiag">
  <svg viewBox="0 0 1000 400" role="img" aria-label="贻贝钙肽 CAPCS 分子作用机制流程图" class="mechdiag-svg">
    <defs>
      <marker id="mdarrow" markerWidth="9" markerHeight="9" refX="6.4" refY="4" orient="auto" markerUnits="userSpaceOnUse">
        <path d="M0.5 0.8 L7 4 L0.5 7.2 Z" fill="rgba(255,255,255,0.6)"></path>
      </marker>
      <filter id="mdglow" x="-50%" y="-50%" width="200%" height="200%">
        <feDropShadow dx="0" dy="0" stdDeviation="7" flood-color="#1f7a8c" flood-opacity="0.55"></feDropShadow>
      </filter>
    </defs>

    <!-- 阶段标签 -->
    <text x={cap.x + cap.w / 2} y="22" text-anchor="middle" class="mechdiag-stage" fill="rgba(255,255,255,0.62)">核心成分</text>
    <text x={MX + NW / 2} y="22" text-anchor="middle" class="mechdiag-stage" fill="rgba(255,255,255,0.62)">分子层面 · 四大作用</text>
    <text x={out.x + out.w / 2} y="22" text-anchor="middle" class="mechdiag-stage" fill="rgba(255,255,255,0.62)">临床获益</text>

    <!-- 连接：左侧总线（CAPCS → 机制） -->
    <g class="mechdiag-link">
      <path d={`M${cap.x + cap.w} ${cap.y + cap.h / 2} H${LBUS}`}></path>
      <path d={`M${LBUS} ${topC} V${botC}`}></path>
      {mechs.map((m) => <path d={`M${LBUS} ${cy(m)} H${MX}`} marker-end="url(#mdarrow)"></path>)}
    </g>
    <!-- 连接：右侧总线（机制 → 结果） -->
    <g class="mechdiag-link">
      {mechs.map((m) => <path d={`M${MX + NW} ${cy(m)} H${RBUS}`}></path>)}
      <path d={`M${RBUS} ${topC} V${botC}`}></path>
      <path d={`M${RBUS} ${out.y + out.h / 2} H${out.x}`} marker-end="url(#mdarrow)"></path>
    </g>
    <!-- 连接点 -->
    <circle class="mechdiag-dot" cx={cap.x + cap.w} cy={cap.y + cap.h / 2} r="3.2"></circle>
    {mechs.map((m) => <circle class="mechdiag-dot" cx={MX + NW} cy={cy(m)} r="3.2"></circle>)}

    <!-- CAPCS 来源节点 -->
    <g class="mechdiag-node mechdiag-source">
      <rect x={cap.x} y={cap.y} width={cap.w} height={cap.h} rx="16" filter="url(#mdglow)"></rect>
      <text x={cap.x + cap.w / 2} y={cap.y + 42} text-anchor="middle" class="mechdiag-title-lg">贻贝钙肽 CAPCS</text>
      <text x={cap.x + cap.w / 2} y={cap.y + 68} text-anchor="middle" class="mechdiag-sub-light">活性钙 Ca²⁺ ＋ 抗菌肽 AMP</text>
    </g>

    <!-- 4 个机制节点 -->
    {mechs.map((m, i) => (
      <g class="mechdiag-node">
        <rect x={MX} y={m.y} width={NW} height={NH} rx="12"></rect>
        <circle class="mechdiag-idx" cx={MX + 26} cy={cy(m)} r="13" fill="#1f7a8c"></circle>
        <text x={MX + 26} y={cy(m) + 4.5} text-anchor="middle" class="mechdiag-idx-t" fill="#fff">{i + 1}</text>
        <text x={MX + 50} y={cy(m) - 5} class="mechdiag-title">{m.t}</text>
        <text x={MX + 50} y={cy(m) + 16} class="mechdiag-sub">{m.s}</text>
      </g>
    ))}

    <!-- 结果节点 -->
    <g class="mechdiag-node mechdiag-out">
      <rect x={out.x} y={out.y} width={out.w} height={out.h} rx="16" filter="url(#mdglow)"></rect>
      <text x={out.x + out.w / 2} y={out.y + 46} text-anchor="middle" class="mechdiag-title-lg">修复皮肤屏障</text>
      <text x={out.x + out.w / 2} y={out.y + 72} text-anchor="middle" class="mechdiag-sub-light">缓解特应性皮炎 AD</text>
    </g>
  </svg>
  <figcaption>贻贝钙肽 CAPCS 分子作用机制示意（基于华西医院 IJMS 2022 机理研究）</figcaption>
</figure>

<style>
  .mechdiag { margin: 0; }
  .mechdiag-svg { width: 100%; height: auto; overflow: visible; }
  .mechdiag-link path { fill: none; stroke: rgba(255, 255, 255, 0.28); stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; }
  .mechdiag-dot { fill: rgba(255, 255, 255, 0.5); }
  .mechdiag-node rect { fill: rgba(255, 255, 255, 0.045); stroke: rgba(255, 255, 255, 0.16); stroke-width: 1; }
  .mechdiag-source rect { fill: var(--color-brand); stroke: none; }
  .mechdiag-out rect { fill: rgba(31, 122, 140, 0.32); stroke: var(--color-brand); stroke-width: 1.5; }
  .mechdiag-idx { fill: #1f7a8c; stroke: none; }
  .mechdiag-idx-t { fill: #fff; font-size: 13px; font-weight: 600; }
  .mechdiag-stage { fill: rgba(255, 255, 255, 0.62); font-size: 12px; font-weight: 500; letter-spacing: 0.14em; }
  .mechdiag-title-lg { fill: #fff; font-size: 19px; font-weight: 600; letter-spacing: 0.01em; }
  .mechdiag-title { fill: #fff; font-size: 16px; font-weight: 500; }
  .mechdiag-sub { fill: rgba(255, 255, 255, 0.6); font-size: 12.5px; }
  .mechdiag-sub-light { fill: rgba(255, 255, 255, 0.85); font-size: 12.5px; }
  .mechdiag figcaption { margin-top: var(--space-lg); font-size: 0.75rem; color: rgba(255, 255, 255, 0.5); text-align: center; }
  @media (max-width: 640px) {
    .mechdiag-title { font-size: 18px; }
    .mechdiag-sub, .mechdiag-sub-light { font-size: 14px; }
    .mechdiag-title-lg { font-size: 21px; }
    .mechdiag-stage { font-size: 14px; }
  }
</style>
