---
// FAQ: Single-level accordion — click question to expand answer
import faqCategories from '../data/faq';

interface SubItem {
  q: string;
  a: string;
}

export interface Props {
  maxItems?: number;
  showHeader?: boolean;
}

const { maxItems, showHeader = true } = Astro.props;

// Flatten all categories into a single question list
let allItems: SubItem[] = faqCategories.flatMap(cat => cat.items);
if (maxItems && maxItems > 0) {
  allItems = allItems.slice(0, maxItems);
}
---

<section id="qa" class="section qa">
  <div class="section-inner">
    {showHeader && (
    <div class="qa-header">
      <div class="qa-accent-line" aria-hidden="true"></div>
      <h2 class="qa-title">常见问题</h2>
      <p class="qa-subtitle">关于产品/品牌/功效/护肤问题</p>
    </div>
    )}

    <div class="qa-list">
      <div class="qa-col">
        {allItems.filter((_, i) => i % 2 === 0).map((item, index) => (
          <div class="qa-item">
            <button class="qa-btn" data-index={index * 2} aria-expanded="false">
              <span class="qa-icon" aria-hidden="true">Q</span>
              <span class="qa-question">{item.q}</span>
            </button>
            <div class="qa-body">
              <div class="qa-body-inner">
                <div class="qa-answer">
                  <span class="qa-answer-label" aria-hidden="true">A</span>
                  <p class="qa-answer-text">{item.a}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
      <div class="qa-col">
        {allItems.filter((_, i) => i % 2 === 1).map((item, index) => (
          <div class="qa-item">
            <button class="qa-btn" data-index={index * 2 + 1} aria-expanded="false">
              <span class="qa-icon" aria-hidden="true">Q</span>
              <span class="qa-question">{item.q}</span>
            </button>
            <div class="qa-body">
              <div class="qa-body-inner">
                <div class="qa-answer">
                  <span class="qa-answer-label" aria-hidden="true">A</span>
                  <p class="qa-answer-text">{item.a}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    {maxItems && (
      <div class="qa-footer">
        <a href="/faq" class="qa-view-all">查看全部 FAQ →</a>
      </div>
    )}
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.querySelectorAll('.qa-btn').forEach(btn => {
    let animating = false;

    btn.addEventListener('click', () => {
      if (animating) return;

      const item = btn.closest('.qa-item');
      const body = item.querySelector('.qa-body');
      const inner = body.querySelector('.qa-body-inner');
      const isOpen = item.classList.contains('qa-expanded');

      const done = () => {
        animating = false;
        body.removeEventListener('transitionend', done);
      };
      body.addEventListener('transitionend', done, { once: true });

      if (isOpen) {
        body.style.height = body.scrollHeight + 'px';
        requestAnimationFrame(() => {
          body.style.height = '0px';
        });
        item.classList.remove('qa-expanded');
        btn.setAttribute('aria-expanded', 'false');
      } else {
        item.classList.add('qa-expanded');
        const fullHeight = inner.scrollHeight;
        body.style.height = (prefersReduced ? fullHeight : fullHeight) + 'px';
        btn.setAttribute('aria-expanded', 'true');
      }

      if (prefersReduced) {
        animating = false;
      }
    });
  });
});
</script>

<style>
  .qa {
    background: var(--color-bg);
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-6xl);
    position: relative;
  }

  .qa::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-brand-subtle), transparent);
  }

  /* ── Header ── */
  .qa-header {
    text-align: center;
    margin-bottom: var(--space-4xl);
  }

  .qa-accent-line {
    width: 40px;
    height: 2px;
    background: var(--color-brand);
    margin: 0 auto var(--space-lg);
  }

  .qa-title {
    font-size: var(--text-3xl);
    font-weight: 200;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-md);
  }

  .qa-subtitle {
    font-size: var(--text-lg);
    font-weight: 300;
    color: var(--color-text-soft);
  }

  /* ── Question list ── */
  .qa-list {
    display: flex;
    gap: var(--space-4xl);
  }

  .qa-col {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .qa-item {
    border-bottom: 1px solid var(--color-border-light);
    border-top: 1px solid var(--color-border-light);
  }

  .qa-item:first-child {
    border-top: 1px solid var(--color-border-light);
  }

  .qa-btn {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    width: 100%;
    padding: var(--space-xl) 0;
    border: none;
    background: none;
    cursor: pointer;
    font-family: inherit;
    text-align: left;
    transition: color var(--duration-fast) ease;
  }

  .qa-btn:hover {
    color: var(--color-brand-dark);
  }

  .qa-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-brand);
    border: 1px solid var(--color-brand-subtle);
    border-radius: 50%;
    margin-top: 2px;
  }

  .qa-question {
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--color-text);
    line-height: 1.5;
    flex: 1;
    padding-top: 2px;
  }

  .qa-btn:hover .qa-question {
    color: var(--color-brand-dark);
  }

  .qa-btn::after {
    content: '+';
    margin-left: auto;
    flex-shrink: 0;
    font-size: var(--text-lg);
    font-weight: 300;
    color: var(--color-text-muted);
    line-height: 1.3;
    padding-top: 2px;
    transition: transform 0.3s var(--ease-out-expo);
  }

  .qa-expanded .qa-btn::after {
    content: '−';
    color: var(--color-brand-dark);
  }

  /* ── Answer body ── */
  .qa-body {
    height: 0;
    overflow: hidden;
    transition: height 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  @media (prefers-reduced-motion: reduce) {
    .qa-body {
      transition: none;
    }
  }

  .qa-answer {
    display: flex;
    gap: var(--space-md);
    padding: 0 0 var(--space-xl);
    padding-left: calc(24px + var(--space-md));
  }

  .qa-answer-label {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-inverse);
    background: var(--color-brand);
    border-radius: 50%;
  }

  .qa-answer-text {
    font-size: var(--text-base);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text-soft);
    max-width: 70ch;
    padding-top: 2px;
  }

  /* ── Footer / view all ── */
  .qa-footer {
    text-align: center;
    margin-top: var(--space-3xl);
  }

  .qa-view-all {
    display: inline-block;
    padding: 12px 36px;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
    border: 1px solid var(--color-text);
    text-decoration: none;
    transition: all var(--duration-medium) var(--ease-out-expo);
    letter-spacing: var(--tracking-wider);
    border-radius: var(--radius-pill);
  }

  .qa-view-all:hover {
    background: var(--color-brand);
    border-color: var(--color-brand);
    color: var(--color-text-inverse);
  }

  @media (max-width: 1024px) {
    .qa-list {
      flex-direction: column;
      gap: 0;
    }
    .qa-item {
      border-top: none;
    }
    .qa-col > .qa-item:first-child {
      border-top: none;
    }
    .qa-list > .qa-col:first-child > .qa-item:first-child {
      border-top: 1px solid var(--color-border-light);
    }
  }

  @media (max-width: 768px) {
    .qa-btn {
      padding: var(--space-lg) 0;
      gap: var(--space-sm);
    }

    .qa-question {
      font-size: var(--text-base);
    }

    .qa-answer {
      flex-direction: column;
      gap: var(--space-sm);
      padding-left: 0;
    }
  }
</style>
