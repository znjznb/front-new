---
// FAQ: Two-level accordion — click main category to reveal sub-questions, click sub-question to reveal answer
import faqCategories from '../data/faq';

interface SubItem {
  q: string;
  a: string;
}

interface Category {
  title: string;
  items: SubItem[];
}

export interface Props {
  maxItems?: number;
}

const { maxItems } = Astro.props;

// Limit total items across all categories when maxItems is set
let categories: Category[] = faqCategories;
if (maxItems && maxItems > 0) {
  let remaining = maxItems;
  categories = faqCategories
    .map(cat => {
      const sliced = cat.items.slice(0, remaining);
      remaining -= sliced.length;
      return { ...cat, items: sliced };
    })
    .filter(cat => cat.items.length > 0);
}
---

<section id="qa" class="section qa">
  <div class="section-inner">
    <div class="qa-header reveal reveal-rise">
      <div class="qa-accent-line" aria-hidden="true"></div>
      <h2 class="qa-title">常见问题</h2>
      <p class="qa-subtitle">关于海得宝、产品功效与购买渠道的常见疑问</p>
    </div>

    <div class="qa-list">
      {categories.map((cat, catIdx) => (
        <div class="qa-category reveal reveal-rise">
          <button class="qa-category-btn" data-category={catIdx} aria-expanded="false">
            <span class="qa-category-title">{cat.title}</span>
            <span class="qa-category-icon" aria-hidden="true">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                <path d="M7 1v12M1 7h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </span>
          </button>
          <div class="qa-category-body">
            <div class="qa-sub-list">
              {cat.items.map((item, itemIdx) => (
                <div class="qa-sub-item">
                  <button class="qa-sub-btn" data-category={catIdx} data-item={itemIdx} aria-expanded="false">
                    <span class="qa-sub-icon" aria-hidden="true">Q</span>
                    <span class="qa-sub-title">{item.q}</span>
                  </button>
                  <div class="qa-sub-body">
                    <div class="qa-answer">
                      <span class="qa-answer-label" aria-hidden="true">A</span>
                      <p class="qa-answer-text">{item.a}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    {maxItems && (
      <div class="qa-footer reveal reveal-rise">
        <a href="/faq" class="qa-view-all">查看全部 FAQ →</a>
      </div>
    )}
  </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const CATEGORY_EXPANDED = 'qa-expanded';
  const SUB_EXPANDED = 'qa-sub-expanded';

  document.querySelectorAll('.qa-category-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.closest('.qa-category');
      const isOpen = cat.classList.contains(CATEGORY_EXPANDED);

      // Close other categories
      document.querySelectorAll('.qa-category.' + CATEGORY_EXPANDED).forEach(other => {
        if (other !== cat) {
          other.classList.remove(CATEGORY_EXPANDED);
          other.querySelector('.qa-category-btn').setAttribute('aria-expanded', 'false');
        }
      });

      // Toggle this one
      if (isOpen) {
        cat.classList.remove(CATEGORY_EXPANDED);
        btn.setAttribute('aria-expanded', 'false');
      } else {
        cat.classList.add(CATEGORY_EXPANDED);
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  document.querySelectorAll('.qa-sub-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const subItem = btn.closest('.qa-sub-item');
      const isOpen = subItem.classList.contains(SUB_EXPANDED);

      if (isOpen) {
        subItem.classList.remove(SUB_EXPANDED);
        btn.setAttribute('aria-expanded', 'false');
      } else {
        subItem.classList.add(SUB_EXPANDED);
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
});
</script>

<style>
  .qa {
    background: var(--color-bg);
    padding-top: var(--space-6xl);
    padding-bottom: var(--space-6xl);
    position: relative;
  }

  .qa::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-brand-subtle), transparent);
  }

  /* ── Header ── */
  .qa-header {
    text-align: center;
    margin-bottom: var(--space-5xl);
  }

  .qa-accent-line {
    width: 40px;
    height: 2px;
    background: var(--color-brand);
    margin: 0 auto var(--space-lg);
  }

  .qa-title {
    font-size: var(--text-3xl);
    font-weight: 200;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-md);
  }

  .qa-subtitle {
    font-size: var(--text-lg);
    font-weight: 300;
    color: var(--color-text-soft);
  }

  /* ── Category accordion ── */
  .qa-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .qa-category {
    border-bottom: 1px solid var(--color-border-light);
  }

  .qa-category:first-child {
    border-top: 1px solid var(--color-border-light);
  }

  .qa-category-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--space-xl) 0;
    border: none;
    background: none;
    cursor: pointer;
    font-family: inherit;
    text-align: left;
    transition: color var(--duration-fast) ease;
  }

  .qa-category-btn:hover {
    color: var(--color-brand-dark);
  }

  .qa-category-title {
    font-size: var(--text-xl);
    font-weight: 350;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
  }

  .qa-category-btn:hover .qa-category-title {
    color: var(--color-brand-dark);
  }

  .qa-category-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    flex-shrink: 0;
    color: var(--color-text-muted);
    transition: transform 0.4s var(--ease-out-expo), color var(--duration-fast) ease;
  }

  .qa-expanded .qa-category-icon {
    transform: rotate(45deg);
    color: var(--color-brand-dark);
  }

  /* ── Category body (sub-questions) ── */
  .qa-category-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s var(--ease-out-quart);
  }

  .qa-expanded .qa-category-body {
    max-height: 1200px;
  }

  .qa-sub-list {
    padding-bottom: var(--space-xl);
    padding-left: 0;
  }

  /* ── Sub-question ── */
  .qa-sub-item {
    border-top: 1px solid var(--color-border-light);
  }

  .qa-sub-item:first-child {
    border-top: none;
  }

  .qa-sub-btn {
    display: flex;
    align-items: flex-start;
    gap: var(--space-md);
    width: 100%;
    padding: var(--space-lg) 0;
    border: none;
    background: none;
    cursor: pointer;
    font-family: inherit;
    text-align: left;
    transition: color var(--duration-fast) ease;
  }

  .qa-sub-btn:hover {
    color: var(--color-brand-dark);
  }

  .qa-sub-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-brand);
    border: 1px solid var(--color-brand-subtle);
    border-radius: 50%;
  }

  .qa-sub-title {
    font-size: var(--text-base);
    font-weight: 350;
    color: var(--color-text-soft);
    line-height: 1.5;
    padding-top: 2px;
  }

  .qa-sub-btn:hover .qa-sub-title {
    color: var(--color-brand-dark);
  }

  .qa-sub-btn::after {
    content: '+';
    margin-left: auto;
    flex-shrink: 0;
    font-size: var(--text-lg);
    font-weight: 300;
    color: var(--color-text-muted);
    line-height: 1.3;
    transition: transform 0.3s var(--ease-out-expo);
  }

  .qa-sub-expanded .qa-sub-btn::after {
    content: '−';
    color: var(--color-brand-dark);
  }

  /* ── Sub-question body (answer) ── */
  .qa-sub-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s var(--ease-out-quart);
  }

  .qa-sub-expanded .qa-sub-body {
    max-height: 600px;
  }

  .qa-answer {
    display: flex;
    gap: var(--space-md);
    padding: 0 0 var(--space-xl);
  }

  .qa-answer-label {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-inverse);
    background: var(--color-brand);
    border-radius: 50%;
  }

  .qa-answer-text {
    font-size: var(--text-sm);
    font-weight: 300;
    line-height: var(--leading-relaxed);
    color: var(--color-text-soft);
    max-width: 70ch;
    padding-top: 2px;
  }

  /* ── Footer / view all ── */
  .qa-footer {
    text-align: center;
    margin-top: var(--space-3xl);
  }

  .qa-view-all {
    display: inline-block;
    padding: 12px 36px;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
    border: 1px solid var(--color-text);
    text-decoration: none;
    transition: all var(--duration-medium) var(--ease-out-expo);
    letter-spacing: var(--tracking-wider);
    border-radius: var(--radius-pill);
  }

  .qa-view-all:hover {
    background: var(--color-brand);
    border-color: var(--color-brand);
    color: var(--color-text-inverse);
  }

  @media (max-width: 768px) {
    .qa-category-btn {
      padding: var(--space-lg) 0;
    }

    .qa-category-title {
      font-size: var(--text-lg);
    }

    .qa-sub-btn {
      padding: var(--space-md) 0;
      gap: var(--space-sm);
    }

    .qa-sub-title {
      font-size: var(--text-sm);
    }

    .qa-answer {
      flex-direction: column;
      gap: var(--space-sm);
    }
  }
</style>
