---
import ProductCard from './ProductCard.astro';
import { getAllProducts } from '../data/products';

const products = getAllProducts().slice(0, 6);
---

<section id="products" class="section products">
  <div class="section-inner">
    <div class="products-header reveal reveal-rise">
      <div class="products-accent-line" aria-hidden="true"></div>
      <h2 class="products-title">以专业，呵护每一寸敏感</h2>
      <p class="products-subtitle">为全家人不同肤质量身打造</p>
    </div>

    <div class="products-grid">
      {products.map(product => (
        <ProductCard product={product} />
      ))}
    </div>

    <div class="products-footer">
      <a href="/products" class="products-link">查看全部商品 →</a>
    </div>
  </div>
</section>

<style>
  .products {
    background: var(--color-surface);
    padding-top: var(--space-6xl);
    padding-bottom: var(--space-6xl);
  }

  .products-header {
    text-align: center;
    margin-bottom: var(--space-4xl);
  }

  .products-accent-line {
    width: 40px;
    height: 2px;
    background: var(--color-brand);
    margin: 0 auto var(--space-lg);
  }

  .products-title {
    font-size: var(--text-3xl);
    font-weight: 200;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-md);
  }

  .products-subtitle {
    font-size: var(--text-lg);
    font-weight: 300;
    color: var(--color-text-soft);
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .products-footer {
    text-align: center;
    margin-top: var(--space-3xl);
  }

  .products-link {
    display: inline-flex;
    align-items: center;
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    padding: 12px 36px;
    border: 1px solid var(--color-text);
    border-radius: var(--radius-pill);
    transition: all var(--duration-medium) var(--ease-out-expo);
    letter-spacing: var(--tracking-wider);
  }

  .products-link:hover {
    background: var(--color-text);
    color: var(--color-text-inverse);
  }

  @media (max-width: 1024px) {
    .products-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
