---
// Product Gallery: Artful product display with abstract shapes
// Data managed via src/content/products/*.json

import { getCollection } from 'astro:content';

const products = (await getCollection('products'))
  .sort((a, b) => a.data.order - b.data.order);
---

<section id="products" class="section products">
  <div class="section-inner">
    <div class="products-header reveal reveal-rise">
      <div class="products-accent-line" aria-hidden="true"></div>
      <h2 class="products-title">以专业，呵护每一寸敏感</h2>
      <p class="products-subtitle">为全家人不同肤质量身打造</p>
    </div>

    <div class="products-grid">
      {products.map((product, i) => (
        <article class="product-card reveal reveal-rise" class:list={{ [`reveal-delay-${(i % 4) + 1}`]: true }}>
          <div class="product-visual">
            <img
              class="product-visual-img"
              src={product.data.image}
              alt={product.data.name}
              loading="lazy"
              width="800"
              height="600"
            />
          </div>
          <div class="product-info">
            <h3 class="product-name">{product.data.name}</h3>
            <p class="product-line">{product.data.line}</p>
            <p class="product-desc">{product.data.desc}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .products {
    background: var(--color-surface);
    padding-top: var(--space-6xl);
    padding-bottom: var(--space-6xl);
  }

  .products-header {
    text-align: center;
    margin-bottom: var(--space-4xl);
  }

  .products-accent-line {
    width: 40px;
    height: 2px;
    background: var(--color-brand);
    margin: 0 auto var(--space-lg);
  }

  .products-title {
    font-size: var(--text-3xl);
    font-weight: 200;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-md);
  }

  .products-subtitle {
    font-size: var(--text-lg);
    font-weight: 300;
    color: var(--color-text-soft);
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .product-card {
    overflow: hidden;
  }

  .product-visual {
    aspect-ratio: 3/2;
    overflow: hidden;
  }

  .product-visual-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-out-expo);
  }

  .product-card:hover .product-visual-img {
    transform: scale(1.04);
  }

  .product-info {
    padding: var(--space-lg) 0 0;
  }

  .product-name {
    font-size: var(--text-lg);
    font-weight: 400;
    margin-bottom: var(--space-xs);
    color: var(--color-text);
  }

  .product-line {
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: var(--tracking-wide);
    color: var(--color-brand);
    margin-bottom: var(--space-sm);
  }

  .product-desc {
    font-size: var(--text-sm);
    font-weight: 300;
    color: var(--color-text-muted);
    line-height: var(--leading-relaxed);
  }

  @media (max-width: 1024px) {
    .products-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
