---
// Navigation with mega-menu dropdowns
---

<nav class="nav" role="navigation" aria-label="主导航">
  <div class="nav-inner">
    <button class="nav-hamburger" id="navHamburger" aria-label="菜单">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
    <a href="/" class="nav-logo" aria-label="海得宝首页">
      <img src="/assets/single_logo.png" alt="海得宝" class="nav-logo-img" width="96" height="96" />
    </a>
    <div class="nav-links" id="navLinks">
      <div class="nav-item">
        <a href="#story" class="nav-link">品牌故事</a>
        <div class="mega-menu">
          <div class="mega-menu-inner">
            <div class="mega-menu-content">
              <a href="#" class="mega-link">品牌历程</a>
              <a href="#" class="mega-link">代言人</a>
              <a href="#" class="mega-link">公益</a>
              <a href="#" class="mega-link">环保</a>
              <a href="#" class="mega-link">新华社见证</a>
              <a href="#" class="mega-link">新闻更新板块</a>
            </div>
          </div>
        </div>
      </div>
      <div class="nav-item">
        <a href="#science" class="nav-link">贻贝钙肽CAPCS</a>
        <div class="mega-menu">
          <div class="mega-menu-inner">
            <div class="mega-menu-content">
              <a href="#" class="mega-link">成分来源及物理渗透原理</a>
              <a href="#" class="mega-link">成分背书</a>
              <a href="#" class="mega-link">科研实验</a>
              <a href="#" class="mega-link">医院临床</a>
              <a href="#" class="mega-link">工厂建设</a>
            </div>
          </div>
        </div>
      </div>
      <div class="nav-item">
        <a href="#products" class="nav-link">产品矩阵</a>
        <div class="mega-menu">
          <div class="mega-menu-inner">
            <div class="mega-menu-content">
              <a href="#" class="mega-link">产品系列</a>
              <a href="#" class="mega-link">肌肤类型</a>
              <a href="#" class="mega-link">肌肤问题</a>
              <a href="#" class="mega-link">产品类型</a>
            </div>
          </div>
        </div>
      </div>
      <div class="nav-item">
        <a href="#" class="nav-link">科学护肤</a>
        <div class="mega-menu">
          <div class="mega-menu-inner">
            <div class="mega-menu-content">
              <a href="#" class="mega-link">皮肤科学</a>
              <a href="#" class="mega-link">护肤方式</a>
              <a href="#" class="mega-link">护肤1v1</a>
            </div>
          </div>
        </div>
      </div>
      <div class="nav-item">
        <a href="#" class="nav-link">关于海得宝</a>
        <div class="mega-menu">
          <div class="mega-menu-inner">
            <div class="mega-menu-content">
              <a href="#" class="mega-link">皮肤科学验证</a>
              <a href="#" class="mega-link">敏感问题急救</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-overlay" id="mobileOverlay"></div>
  <div class="mobile-menu" id="mobileMenu">
    <button class="mobile-close" id="mobileClose" aria-label="关闭菜单">&times;</button>
    <div class="mobile-menu-body"></div>
  </div>
</nav>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const hamburger = document.getElementById('navHamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  const mobileOverlay = document.getElementById('mobileOverlay');
  const mobileClose = document.getElementById('mobileClose');
  const mobileBody = mobileMenu.querySelector('.mobile-menu-body');

  const navItems = document.querySelectorAll('.nav-links > .nav-item');
  mobileBody.innerHTML = '';
  navItems.forEach(item => {
    const topLink = item.querySelector('.nav-link');
    const subLinks = item.querySelectorAll('.mega-link');
    const section = document.createElement('div');
    section.className = 'mobile-section';

    const header = document.createElement('div');
    header.className = 'mobile-section-header';
    header.textContent = topLink.textContent;
    section.appendChild(header);

    if (subLinks.length) {
      const body = document.createElement('div');
      body.className = 'mobile-section-body';
      subLinks.forEach(link => {
        const a = document.createElement('a');
        a.href = link.getAttribute('href') || '#';
        a.className = 'mobile-section-link';
        a.textContent = link.textContent;
        body.appendChild(a);
      });
      section.appendChild(body);
      header.addEventListener('click', () => {
        header.classList.toggle('active');
        body.classList.toggle('open');
      });
    }

    mobileBody.appendChild(section);
  });

  function openMobile() {
    mobileMenu.classList.add('open');
    mobileOverlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeMobile() {
    mobileMenu.classList.remove('open');
    mobileOverlay.classList.remove('open');
    document.body.style.overflow = '';
  }

  hamburger.addEventListener('click', openMobile);
  mobileClose.addEventListener('click', closeMobile);
  mobileOverlay.addEventListener('click', closeMobile);
});
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-nav);
    padding: var(--space-md) var(--content-padding);
    background: #ffffff;
  }

  .nav-inner {
    max-width: var(--content-max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-weight: 600;
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    text-decoration: none;
  }

  .nav-logo-img {
    display: block;
    width: 96px;
    height: auto;
  }

  /* ── Hamburger ── */
  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    z-index: 2;
  }

  .hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-text);
    border-radius: 1px;
  }

  /* ── Nav Links (desktop) ── */
  .nav-links {
    display: flex;
  }

  .nav-item {
    position: static;
  }

  .nav-link {
    display: block;
    padding: 8px 18px;
    font-size: var(--text-sm);
    font-weight: 400;
    letter-spacing: var(--tracking-wide);
    color: var(--color-text-soft);
    transition: color var(--duration-fast) ease;
    text-decoration: none;
    white-space: nowrap;
    cursor: pointer;
  }

  .nav-link:hover {
    color: var(--color-text);
  }

  /* ── Mega Menu (80% width, centered) ── */
  .mega-menu {
    visibility: hidden;
    opacity: 0;
    position: absolute;
    left: 10%;
    top: calc(100% - var(--space-md));
    width: 80%;
    z-index: 9;
    transition: opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1), visibility 0s 0.5s;
  }

  /* full-width bridge to eliminate gap during animation */
  .mega-menu::before {
    content: '';
    position: absolute;
    top: -4px;
    left: -12.5%;
    width: 125%;
    height: 4px;
    background: #ffffff;
  }

  .nav-item:hover .mega-menu {
    visibility: visible;
    opacity: 1;
    transition: opacity 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) 0.15s, visibility 0s 0.15s;
  }

  .mega-menu-inner {
    background: #ffffff;
    transform: translateY(-20px);
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    padding: var(--space-md) var(--space-lg);
  }

  .nav-item:hover .mega-menu-inner {
    transform: translateY(0);
    transition: transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) 0.15s;
  }

  .mega-menu-content {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .mega-link {
    display: inline-block;
    padding: 6px 0;
    font-size: var(--text-sm);
    font-weight: 300;
    color: var(--color-text-soft);
    text-decoration: none;
    transition: color var(--duration-fast) ease;
    width: auto;
  }

  .mega-link:hover {
    color: var(--color-brand-dark);
  }

  /* ── Mobile Menu ── */
  .mobile-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.3);
    z-index: 98;
  }
  .mobile-overlay.open { display: block; }

  .mobile-menu {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 80%;
    max-width: 360px;
    background: #ffffff;
    z-index: 99;
    padding: 80px var(--space-lg) var(--space-lg);
    overflow-y: auto;
    box-shadow: 2px 0 16px rgba(0,0,0,0.08);
  }
  .mobile-menu.open { display: block; }

  .mobile-close {
    position: absolute;
    top: 20px;
    right: var(--space-lg);
    font-size: 1.8rem;
    border: none;
    background: none;
    cursor: pointer;
    color: var(--color-text);
    line-height: 1;
  }

  :global(.mobile-section) {
    border-bottom: 1px solid #f0f0f0;
  }

  :global(.mobile-section-header) {
    padding: 16px 0;
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--color-text);
    cursor: pointer;
    position: relative;
    letter-spacing: 0.02em;
  }

  :global(.mobile-section-header::after) {
    content: '+';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.2rem;
    color: var(--color-text-muted);
    transition: transform 0.2s;
  }

  :global(.mobile-section-header.active::after) {
    content: '−';
    color: var(--color-brand);
  }

  :global(.mobile-section-body) {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  :global(.mobile-section-body.open) {
    max-height: 500px;
  }

  :global(.mobile-section-link) {
    display: block;
    padding: 12px 0 12px var(--space-md);
    font-size: 0.95rem;
    font-weight: 300;
    color: var(--color-text-soft);
    text-decoration: none;
    border-top: 1px solid #f8f8f8;
  }

  :global(.mobile-section-link:hover) {
    color: var(--color-brand-dark);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .nav-inner {
      position: relative;
      justify-content: center;
    }

    .nav-hamburger {
      display: flex;
      position: absolute;
      left: 0;
    }

    .nav-links {
      display: none;
    }
  }
</style>
</nav>
